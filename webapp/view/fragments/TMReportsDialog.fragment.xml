<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">
    <Dialog 
        title="T&amp;M Reports - {dialog>/activityCode}"
        contentWidth="90%"
        contentHeight="80%"
        draggable="true"
        resizable="true"
    >
        <content>
            <VBox class="sapUiMediumMargin">
                
                <!-- Header Info -->
                <VBox class="sapUiSmallMarginBottom">
                    <Title text="Activity: {dialog>/activityCode}" level="H4" class="sapUiTinyMarginBottom"/>
                    <Title text="{dialog>/activitySubject}" level="H5" class="sapUiSmallMarginBottom"/>
                </VBox>
                
                <!-- Activity Details Grid (moved from Activity card) -->
                <VBox class="activityQuickInfo sapUiSmallMarginBottom">
                    <l:Grid defaultSpan="XL6 L6 M12 S12" hSpacing="2" vSpacing="1" containerQuery="true">
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL6 L6 M12 S12"/>
                            </layoutData>
                            <Label text="Planned Start:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/formattedStartDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL6 L6 M12 S12"/>
                            </layoutData>
                            <Label text="Planned End:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/formattedEndDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL6 L6 M12 S12"/>
                            </layoutData>
                            <Label text="Duration:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/formattedDuration}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL6 L6 M12 S12"/>
                            </layoutData>
                            <Label text="Quantity:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/quantity}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL6 L6 M12 S12"/>
                            </layoutData>
                            <Label text="Unit of Measure:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/quantityUoM}" class="infoValue detailFieldValue"/>
                        </VBox>
                    </l:Grid>
                </VBox>
                
                <!-- Total Reports -->
                <Text text="Total Reports: {dialog>/reportCount}" class="sapUiSmallMarginBottom"/>
                
                <!-- T&M Entry Cards -->
                <List
                    items="{
                        path: 'dialog>/reports',
                        templateShareable: false
                    }"
                    mode="None"
                    showSeparators="None"
                >
                    <CustomListItem type="Inactive">
                        <Panel
                            headerText="{dialog>entryHeaderText}"
                            expandable="true"
                            expanded="true"
                            class="tmEntryPanel"
                        >
                            <headerToolbar>
                                <OverflowToolbar design="Info">
                                    <core:Icon 
                                        src="{= ${dialog>type} === 'Time Effort' ? 'sap-icon://time-entry-request' : 
                                              ${dialog>type} === 'Material' ? 'sap-icon://product' :
                                              ${dialog>type} === 'Expense' ? 'sap-icon://money-bills' : 'sap-icon://car-rental'}"
                                        class="sapUiSmallMarginEnd"
                                    />
                                    <Title 
                                        text="{dialog>entryHeaderText}" 
                                        level="H5"
                                    />
                                    <ToolbarSpacer />
                                    <ObjectStatus
                                        text="{dialog>decisionStatusText}"
                                        state="{dialog>decisionStatusState}"
                                        class="decisionStatusValue sapUiSmallMarginEnd"
                                    />
                                    <Label text="ID: {dialog>id}"/>
                                </OverflowToolbar>
                            </headerToolbar>
                            
                            <content>
                                <!-- Card Content with 2-Column Layout -->
                                <l:Grid defaultSpan="XL6 L6 M12 S12" hSpacing="1" vSpacing="0">
                                    
                                    <!-- Left Column -->
                                    <VBox class="tmFieldGroup">
                                        <layoutData>
                                            <l:GridData span="XL6 L6 M12 S12"/>
                                        </layoutData>
                                        
                                        <!-- ===============================
                                             TIME EFFORT FIELDS
                                             =============================== -->
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Time Effort'}">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>durationText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Time Effort'}">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{
                                                path: 'dialog>startDateTime', 
                                                formatter: '.formatter.formatDateTime'
                                            }" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Time Effort'}">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{
                                                path: 'dialog>endDateTime', 
                                                formatter: '.formatter.formatDateTime'
                                            }" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <!-- ===============================
                                             MATERIAL FIELDS
                                             =============================== -->
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Material'}">
                                            <Label text="Quantity:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>quantityText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Material'}">
                                            <Label text="Item:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>itemDisplayText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <!-- ===============================
                                             EXPENSE FIELDS
                                             =============================== -->
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Expense'}">
                                            <Label text="External Amount:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>externalAmountText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Expense'}">
                                            <Label text="Internal Amount:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>internalAmountText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Expense'}">
                                            <Label text="Expense Type:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>expenseTypeDisplayText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <!-- ===============================
                                             MILEAGE FIELDS
                                             =============================== -->
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Mileage'}">
                                            <Label text="Mileage Type:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>mileageTypeDisplayText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Mileage'}">
                                            <Label text="Distance:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>distanceText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Mileage'}">
                                            <Label text="Route:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>routeText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Mileage'}">
                                            <Label text="Travel Start:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{
                                                path: 'dialog>travelStartDateTime', 
                                                formatter: '.formatter.formatDateTime'
                                            }" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Mileage'}">
                                            <Label text="Travel End:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{
                                                path: 'dialog>travelEndDateTime', 
                                                formatter: '.formatter.formatDateTime'
                                            }" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <!-- ===============================
                                             SHARED FIELDS (LEFT)
                                             =============================== -->
                                        <!-- Date (Material + Expense + Mileage) -->
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Material' || ${dialog>type} === 'Expense' || ${dialog>type} === 'Mileage'}">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>dateText}" class="tmFieldValue"/>
                                        </VBox>
                                    </VBox>

                                    <!-- Right Column -->
                                    <VBox class="tmFieldGroup">
                                        <layoutData>
                                            <l:GridData span="XL6 L6 M12 S12"/>
                                        </layoutData>
                                        
                                        <!-- ===============================
                                             TIME EFFORT FIELDS (RIGHT)
                                             =============================== -->
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Time Effort'}">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>taskDisplayText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <!-- ===============================
                                             MILEAGE FIELDS (RIGHT)
                                             =============================== -->
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Mileage'}">
                                            <Label text="Driver:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>driverText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Mileage'}">
                                            <Label text="Private Car:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>privateCarText}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <!-- ===============================
                                             SHARED FIELDS (RIGHT)
                                             =============================== -->
                                        <!-- Decision Status (All types) - with colored styling -->
                                        <VBox class="tmField">
                                            <Label text="Decision Status:" design="Bold" class="tmFieldLabel"/>
                                            <ObjectStatus 
                                                text="{dialog>decisionStatusText}" 
                                                state="{dialog>decisionStatusState}"
                                                class="decisionStatusValue"
                                            />
                                        </VBox>
                                        
                                        <!-- Charge Option (All types) -->
                                        <VBox class="tmField">
                                            <Label text="Charge Option:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>chargeOption}" class="tmFieldValue"/>
                                        </VBox>
                                        
                                        <!-- UDF Values (Time Effort and Mileage only) -->
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Time Effort' || ${dialog>type} === 'Mileage'}">
                                            <Label text="UDF Values:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>udfValuesText}" class="tmFieldValue tmFieldValueSmall" wrapping="true"/>
                                        </VBox>
                                        
                                        <!-- Internal Remarks (Time Effort only) -->
                                        <VBox class="tmField" visible="{= ${dialog>type} === 'Time Effort'}">
                                            <Label text="Internal Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{= ${dialog>internalRemarks} || 'N/A'}" class="tmFieldValue" wrapping="true"/>
                                        </VBox>
                                        
                                        <!-- Remarks (All types) -->
                                        <VBox class="tmField">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{= ${dialog>remarks} || 'N/A'}" class="tmFieldValue" wrapping="true"/>
                                        </VBox>
                                    </VBox>
                                    
                                </l:Grid>
                            </content>
                        </Panel>
                    </CustomListItem>
                </List>
                
            </VBox>
        </content>
        
        <buttons>
            <Button text="Close" press=".onCloseTMReportsDialog"/>
            <Button text="Add New T&amp;M" type="Emphasized" press=".onAddTMReport"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>