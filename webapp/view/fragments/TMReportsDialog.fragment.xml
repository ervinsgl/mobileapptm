<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">
    <!-- 
        TMReportsDialog Fragment: Dialog for viewing and editing existing T&M reports.
        
        Features:
        - View all T&M entries for an activity
        - Edit mode for PENDING status entries
        - Send for approval after editing
        
        Entry Types Displayed:
        - Time Effort: Task, duration, start/end times
        - Material: Item, quantity, date
        - Expense: Type, external/internal amounts
        - Mileage: Route, distance, travel duration
        
        Model: dialog
    -->
    <Dialog 
        title="T&amp;M Reports - {dialog>/activityCode}"
        contentWidth="90%"
        contentHeight="80%"
        draggable="true"
        resizable="true"
    >
        <customHeader>
            <OverflowToolbar>
                <Title text="T&amp;M Reports - {dialog>/activityCode}" level="H4"/>
                <ToolbarSpacer/>
                <ObjectStatus text="{dialog>/activityStatus}" state="{dialog>/activityStatusState}" class="sapUiSmallMarginEnd"/>
                <ObjectStatus text="{dialog>/activityExecutionStage}" state="{dialog>/activityStageState}"/>
            </OverflowToolbar>
        </customHeader>
        <subHeader>
            <Toolbar design="Info">
                <Title text="{dialog>/activitySubject}" level="H6" wrapping="true"/>
                <ToolbarSpacer/>
                <Label text="ID: {dialog>/activityExternalId}"/>
            </Toolbar>
        </subHeader>
        <content>
            <VBox class="sapUiMediumMargin">
                
                <!-- ========== ACTIVITY DETAILS SECTION ========== -->
                <!-- Activity Details Grid -->
                <VBox class="activityQuickInfo sapUiSmallMarginBottom">
                    <l:Grid defaultSpan="XL4 L4 M12 S12" hSpacing="2" vSpacing="1" containerQuery="true">
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Service Product:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/serviceProduct}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Planned Start:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/formattedStartDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Quantity:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/quantity}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Duration:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/formattedDuration}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Planned End:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/formattedEndDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Unit of Measure:" design="Bold" class="infoLabel"/>
                            <Text text="{dialog>/quantityUoM}" class="infoValue detailFieldValue"/>
                        </VBox>
                    </l:Grid>
                </VBox>
                
                <Text text="Total Reports: {dialog>/reportCount}" class="sapUiSmallMarginBottom"/>
                
                <!-- ========== REPORTS LIST ========== -->
                <List items="{path: 'dialog>/reports', templateShareable: false}" mode="None" showSeparators="None">
                    <CustomListItem type="Inactive">
                        <Panel headerText="{dialog>entryHeaderText}" expandable="true" expanded="true" class="tmEntryPanel">
                            
                            <!-- Panel Header Toolbar -->
                            <headerToolbar>
                                <OverflowToolbar design="Info">
                                    <core:Icon src="{= ${dialog>type} === 'Time Effort' ? 'sap-icon://time-entry-request' : ${dialog>type} === 'Material' ? 'sap-icon://product' : ${dialog>type} === 'Expense' ? 'sap-icon://money-bills' : 'sap-icon://car-rental'}" class="sapUiSmallMarginEnd"/>
                                    <Title text="{dialog>entryHeaderText}" level="H5"/>
                                    <ToolbarSpacer/>
                                    <Button text="{= ${dialog>editMode} ? 'Update' : 'Edit T&amp;M Entry'}" type="Emphasized" icon="{= ${dialog>editMode} ? 'sap-icon://save' : 'sap-icon://edit'}" press=".onToggleEditMode" visible="{= ${dialog>decisionStatus} === 'PENDING'}" class="sapUiTinyMarginEnd"/>
                                    <ObjectStatus text="{dialog>decisionStatusText}" state="{dialog>decisionStatusState}" class="decisionStatusValue sapUiSmallMarginEnd"/>
                                    <Label text="ID: {dialog>id}"/>
                                </OverflowToolbar>
                            </headerToolbar>
                            
                            <content>
                                <!-- ===== TIME EFFORT LAYOUT ===== -->
                                <HBox visible="{= ${dialog>type} === 'Time Effort'}" class="tmEntryContent">
                                    
                                    <!-- Col 1: Task, Technician -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>taskDisplayText}" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>createPersonDisplayText}" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: Duration, Start, End -->
                                    <VBox class="tmColumn">
                                        <!-- Duration: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>durationText}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Duration: Edit -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{dialog>editDurationMinutes}" min="0" step="5" width="120px" description="minutes" change=".onEditDurationChange" class="tmFieldInput"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{path: 'dialog>startDateTime', formatter: '.formatter.formatDateTime'}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- End: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{path: 'dialog>endDateTime', formatter: '.formatter.formatDateTime'}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- End: Edit (calculated) -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{path: 'dialog>editEndDateTime', formatter: '.formatter.formatDateTime'}" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 3: Charge, Remarks -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Charge Option:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>chargeOption}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Remarks: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>remarksText}" class="tmFieldValue" wrapping="true"/>
                                        </HBox>
                                        <!-- Remarks: Edit -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{dialog>editRemarks}" rows="2" width="200px" placeholder="Remarks..." class="tmFieldInput"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== MATERIAL LAYOUT ===== -->
                                <HBox visible="{= ${dialog>type} === 'Material'}" class="tmEntryContent">
                                    
                                    <!-- Col 1: Item, Technician -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Item:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>itemDisplayText}" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>createPersonDisplayText}" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: Date, Quantity -->
                                    <VBox class="tmColumn">
                                        <!-- Date: View (read-only) -->
                                        <HBox class="tmFieldRow">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>dateText}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Quantity: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="Quantity:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>quantityText}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Quantity: Edit -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="Quantity:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{dialog>editQuantity}" min="0" step="1" description="Pcs." width="120px" class="tmFieldInput" valueState="{= parseFloat(${dialog>editQuantity}) > parseFloat(${dialog>/quantity}) ? 'Warning' : 'None'}" valueStateText="Quantity exceeds Activity quantity"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 3: Charge, Remarks -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Charge Option:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>chargeOption}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Remarks: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>remarksText}" class="tmFieldValue" wrapping="true"/>
                                        </HBox>
                                        <!-- Remarks: Edit -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{dialog>editRemarks}" rows="2" width="200px" placeholder="Remarks..." class="tmFieldInput"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== EXPENSE LAYOUT ===== -->
                                <HBox visible="{= ${dialog>type} === 'Expense'}" class="tmEntryContent">
                                    
                                    <!-- Col 1: Type, Technician, Date -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Expense Type:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>expenseTypeDisplayText}" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>createPersonDisplayText}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Date: View (read-only) -->
                                        <HBox class="tmFieldRow">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>dateText}" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: External Amount, Internal Amount -->
                                    <VBox class="tmColumn">
                                        <!-- External: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="External Amount:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>externalAmountText}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- External: Edit -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="External Amt:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{dialog>editExternalAmount}" min="0" step="1" description="EUR" width="120px" class="tmFieldInput"/>
                                        </HBox>
                                        <!-- Internal: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="Internal Amount:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>internalAmountText}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Internal: Edit -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="Internal Amt:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{dialog>editInternalAmount}" min="0" step="1" description="EUR" width="120px" class="tmFieldInput"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 3: Charge, Remarks -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Charge Option:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>chargeOption}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Remarks: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>remarksText}" class="tmFieldValue" wrapping="true"/>
                                        </HBox>
                                        <!-- Remarks: Edit -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{dialog>editRemarks}" rows="2" width="200px" placeholder="Remarks..." class="tmFieldInput"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== MILEAGE LAYOUT ===== -->
                                <HBox visible="{= ${dialog>type} === 'Mileage'}" class="tmEntryContent">
                                    
                                    <!-- Col 1: Type, Technician, Route/Distance -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Mileage Type:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>mileageTypeDisplayText}" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>createPersonDisplayText}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Distance: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="Distance:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>distanceText}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Distance: Edit -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="Distance:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{dialog>editDistance}" min="0" step="1" description="KM" width="120px" class="tmFieldInput" valueState="{= parseFloat(${dialog>editDistance}) > parseFloat(${dialog>/quantity}) ? 'Warning' : 'None'}" valueStateText="Distance exceeds Activity quantity"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: Duration, Travel Times -->
                                    <VBox class="tmColumn">
                                        <!-- Duration: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>travelDurationText}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Duration: Edit -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{dialog>editTravelDuration}" min="0" step="5" description="min" width="120px" change=".onEditMileageDurationChange" class="tmFieldInput"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Travel Start:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{path: 'dialog>travelStartDateTime', formatter: '.formatter.formatDateTime'}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Travel End: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="Travel End:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{path: 'dialog>travelEndDateTime', formatter: '.formatter.formatDateTime'}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Travel End: Edit (calculated) -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="Travel End:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{path: 'dialog>editTravelEnd', formatter: '.formatter.formatDateTime'}" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 3: Charge, Remarks -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Charge Option:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>chargeOption}" class="tmFieldValue"/>
                                        </HBox>
                                        <!-- Remarks: View -->
                                        <HBox class="tmFieldRow" visible="{= !${dialog>editMode}}">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="{dialog>remarksText}" class="tmFieldValue" wrapping="true"/>
                                        </HBox>
                                        <!-- Remarks: Edit -->
                                        <HBox class="tmFieldRow" visible="{= ${dialog>editMode}}">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{dialog>editRemarks}" rows="2" width="200px" placeholder="Remarks..." class="tmFieldInput"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </content>
                        </Panel>
                    </CustomListItem>
                </List>
                
            </VBox>
        </content>
        
        <!-- ========== DIALOG BUTTONS ========== -->
        <buttons>
            <Button text="Close" press=".onCloseTMReportsDialog"/>
            <Button 
                text="Add New T&amp;M" 
                type="Emphasized" 
                press=".onAddTMReport"
                visible="{= ${dialog>/activityStatus} !== 'CLOSED' &amp;&amp; ${dialog>/activityExecutionStage} !== 'CLOSED' &amp;&amp; ${dialog>/activityExecutionStage} !== 'CANCELLED' }"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>