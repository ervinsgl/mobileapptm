<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <VBox id="productGroupsMainContainer" class="sapUiResponsiveMargin">
        
        <VBox id="productGroupsContainer">
            <List
                id="productGroupsList"
                items="{view>/productGroups}"
                mode="None"
                showSeparators="None"
            >
                <CustomListItem type="Inactive">
                    
                    <Panel
                        headerText="Product: {view>productDescription}"
                        expandable="true"
                        expanded="{view>expanded}"
                        expand="onProductPanelExpand"
                        class="sapUiSmallMarginBottom productGroupPanel"
                        width="auto"
                    >
                        <headerToolbar>
                            <OverflowToolbar 
                                design="Solid"
                                class="productGroupHeader">
                                <Title 
                                    text="Product: {view>productDescription}" 
                                    level="H4" 
                                    titleStyle="H4"
                                    class="sapUiTinyMarginBegin productGroupHeaderTitle"
                                    wrapping="true"
                                />
                                <ToolbarSpacer />
                                <Label 
                                    text="SO Item: {view>soItemId}" 
                                    design="Bold"
                                    class="sapUiTinyMarginEnd productGroupHeaderLabel"
                                />
                            </OverflowToolbar>
                        </headerToolbar>
                        
                        <content>
                            <Table 
                                id="activitiesTable"
                                items="{
                                    path: 'view>activities',
                                    templateShareable: false
                                }"
                                growing="true"
                                growingThreshold="10"
                                growingScrollToLoad="true"
                                class="sapUiSmallMarginTop activitiesTable"
                                sticky="ColumnHeaders"
                            >
                                <headerToolbar>
                                    <OverflowToolbar class="activitiesTableToolbar">
                                        <Title 
                                            text="{view>activityCount} Activities" 
                                            level="H5"
                                        />
                                    </OverflowToolbar>
                                </headerToolbar>
                                
                                <columns>
                                    <Column width="8%" minScreenWidth="Tablet" demandPopin="true">
                                        <Text text="Code"/>
                                    </Column>
                                    <Column width="10%" minScreenWidth="Tablet" demandPopin="true">
                                        <Text text="External ID"/>
                                    </Column>
                                    <Column width="18%" minScreenWidth="Desktop" demandPopin="true">
                                        <Text text="Subject"/>
                                    </Column>
                                    <Column width="8%" minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
                                        <Text text="Status"/>
                                    </Column>
                                    <Column width="8%" minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
                                        <Text text="Stage"/>
                                    </Column>
                                    <Column width="10%" minScreenWidth="Desktop" demandPopin="true">
                                        <Text text="Planned Start"/>
                                    </Column>
                                    <Column width="10%" minScreenWidth="Desktop" demandPopin="true">
                                        <Text text="Planned End"/>
                                    </Column>
                                    <Column width="6%" minScreenWidth="Tablet" demandPopin="true">
                                        <Text text="Duration"/>
                                    </Column>
                                    <Column width="10%" minScreenWidth="Desktop" demandPopin="true">
                                        <Text text="Org Level"/>
                                    </Column>
                                    <Column width="12%" minScreenWidth="Desktop" demandPopin="true">
                                        <Text text="Address"/>
                                    </Column>
                                </columns>
                                
                                <items>
                                    <ColumnListItem type="Inactive">
                                        <cells>
                                            <Text 
                                                text="{view>code}" 
                                                class="{view>textClass}"
                                            />
                                            
                                            <Text 
                                                text="{view>externalId}" 
                                                class="{view>textClass}"
                                            />
                                            
                                            <Text 
                                                text="{view>subject}" 
                                                wrapping="true"
                                                class="{view>textClass}"
                                            />
                                            
                                            <ObjectStatus 
                                                text="{view>status}" 
                                                state="{view>statusState}"
                                            />
                                            
                                            <ObjectStatus 
                                                text="{view>executionStage}" 
                                                state="{view>stageState}"
                                            />
                                            
                                            <Text 
                                                text="{view>formattedStartDate}"
                                                class="{view>textClass}"
                                            />
                                            
                                            <Text 
                                                text="{view>formattedEndDate}"
                                                class="{view>textClass}"
                                            />
                                            
                                            <Text 
                                                text="{view>formattedDuration}"
                                                class="{view>textClass}"
                                            />
                                            
                                            <Text 
                                                text="{view>orgLevelId}"
                                                class="{view>textClass}"
                                            />
                                            
                                            <Text 
                                                text="{view>addressFull}"
                                                class="{view>textClass}"
                                                wrapping="true"
                                            />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </content>
                    </Panel>
                    
                </CustomListItem>
            </List>
        </VBox>
        
    </VBox>
</core:FragmentDefinition>