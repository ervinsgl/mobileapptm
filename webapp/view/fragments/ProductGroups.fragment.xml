<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <VBox class="sapUiResponsiveMargin">
        <List
            items="{view>/productGroups}"
            mode="None"
        >
            <CustomListItem>
                <Panel
                    headerText="Product: {view>productDescription}"
                    expandable="true"
                    expanded="{view>expanded}"
                    expand="onProductPanelExpand"
                    class="productGroupPanel"
                >
                    <headerToolbar>
                        <OverflowToolbar class="productGroupHeader">
                            <Title 
                                text="Product: {view>productDescription}" 
                                wrapping="true"
                                class="productGroupHeaderTitle"
                            />
                            <ToolbarSpacer />
                            <Label 
                                text="SO Item: {view>soItemId}" 
                                class="productGroupHeaderLabel"
                            />
                        </OverflowToolbar>
                    </headerToolbar>
                    
                    <content>
                        <Toolbar class="activitiesTableToolbar">
                            <Title text="{view>activityCount} Activities"/>
                        </Toolbar>
                        
                        <!-- Activities List -->
                        <List
                            items="{
                                path: 'view>activities',
                                templateShareable: false
                            }"
                            growing="true"
                            growingThreshold="20"
                        >
                            <CustomListItem type="Active" press=".onToggleTMReports">
                                <VBox width="100%">
                                    
                                    <!-- Activity Card -->
                                    <ObjectListItem
                                        type="Inactive"
                                        title="{view>code} - {view>subject}"
                                        intro="ID: {view>externalId}"
                                        number="{view>status}"
                                        numberState="{view>statusState}"
                                    >
                                        <attributes>
                                            <ObjectAttribute title="Stage" text="{view>executionStage}"/>
                                            <ObjectAttribute title="Start" text="{view>formattedStartDate}"/>
                                            <ObjectAttribute title="End" text="{view>formattedEndDate}"/>
                                            <ObjectAttribute title="Duration" text="{view>formattedDuration}"/>
                                            <ObjectAttribute title="Org Level" text="{view>orgLevelId}"/>
                                            <ObjectAttribute title="Address" text="{view>addressFull}"/>
                                        </attributes>
                                        
                                        <firstStatus>
                                            <ObjectStatus 
                                                text="{view>executionStage}" 
                                                state="{view>stageState}"
                                            />
                                        </firstStatus>
                                    </ObjectListItem>
                                    
                                    <!-- T&M Reports (Expandable) -->
                                    <VBox visible="{view>tmReportsExpanded}" class="tmReportsPanel">
                                        <Panel 
                                            headerText="T&amp;M Reports ({view>tmReportsCount})" 
                                            class="tmReportsInnerPanel"
                                        >
                                            <!-- Loading -->
                                            <VBox 
                                                visible="{view>tmReportsLoading}" 
                                                alignItems="Center" 
                                                class="sapUiSmallMargin"
                                            >
                                                <BusyIndicator size="1.5rem"/>
                                                <Text text="Loading..." class="sapUiTinyMarginTop"/>
                                            </VBox>
                                            
                                            <!-- Empty State -->
                                            <MessageStrip 
                                                visible="{= !${view>tmReportsLoading} &amp;&amp; ${view>tmReportsCount} === 0}"
                                                text="No T&amp;M reports yet."
                                                type="Information"
                                                showIcon="true"
                                                class="sapUiSmallMargin"
                                            />
                                            
                                            <!-- Reports List -->
                                            <List
                                                visible="{= !${view>tmReportsLoading} &amp;&amp; ${view>tmReportsCount} > 0}"
                                                items="{
                                                    path: 'view>tmReports',
                                                    templateShareable: false
                                                }"
                                            >
                                                <StandardListItem
                                                    title="{view>type}"
                                                    description="{path: 'view>createDateTime', formatter: '.formatter.formatDateTime'}"
                                                    info="{view>id}"
                                                    type="Inactive"
                                                />
                                            </List>
                                        </Panel>
                                    </VBox>
                                    
                                </VBox>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>
            </CustomListItem>
        </List>
    </VBox>
</core:FragmentDefinition>