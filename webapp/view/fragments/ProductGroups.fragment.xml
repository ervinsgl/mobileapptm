<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <VBox id="productGroupsMainContainer" class="sapUiResponsiveMargin">
        
        <!-- Header -->
        <Title 
            id="productGroupsTitle"
            text="Activities - {view>/selectedOrganizationLevel/text} ({view>/productGroups/length})" 
            level="H3"
            class="sapUiSmallMarginBottom"
        />
        
        <!-- List of Product Groups -->
        <VBox id="productGroupsContainer">
            <List
                id="productGroupsList"
                items="{view>/productGroups}"
                mode="None"
                showSeparators="None"
            >
                <CustomListItem type="Inactive">
                    
                    <!-- Product Panel (Level 1) -->
                    <Panel
                        headerText="Product: {view>productDescription}"
                        expandable="true"
                        expanded="{view>expanded}"
                        expand="onProductPanelExpand"
                        class="sapUiSmallMarginBottom"
                        width="100%"
                    >
                        <headerToolbar>
                            <Toolbar>
                                <Title text="Product: {view>productDescription}" level="H4" />
                                <ToolbarSpacer />
                                <Label 
                                    text="SO Item ID: {view>soItemId}" 
                                    design="Bold"
                                />
                            </Toolbar>
                        </headerToolbar>
                        
                        <content>
                            <VBox class="sapUiSmallMargin">
                                
                                <!-- Activities Count Info -->
                                <HBox class="sapUiTinyMarginBottom">
                                    <Label 
                                        text="{view>activities/length} activities" 
                                    />
                                </HBox>
                                
                                <!-- List of Activities (Level 2) -->
                                <VBox>
                                    <List
                                        items="{view>activities}"
                                        mode="None"
                                        showSeparators="Inner"
                                    >
                                        <CustomListItem type="Active" press="onActivityPress">
                                            
                                            <!-- Activity Panel -->
                                            <Panel
                                                expandable="true"
                                                expanded="{view>activityExpanded}"
                                                class="sapUiTinyMarginBottom"
                                                width="100%"
                                                backgroundDesign="Translucent"
                                            >
                                                <headerToolbar>
                                                    <Toolbar>
                                                        <Title 
                                                            text="{view>code} - {view>subject}" 
                                                            level="H5"
                                                        />
                                                    </Toolbar>
                                                </headerToolbar>
                                                
                                                <content>
                                                    <VBox class="sapUiSmallMargin">
                                                        
                                                        <!-- Activity Details in 3 columns -->
                                                        <HBox justifyContent="SpaceBetween">
                                                            
                                                            <!-- Column 1 -->
                                                            <VBox width="32%">
                                                                <Label text="External ID" design="Bold" />
                                                                <Text text="{view>fullActivity/externalId}" class="sapUiTinyMarginBottom" />
                                                                
                                                                <Label text="Status" design="Bold" class="sapUiTinyMarginTop" />
                                                                <Text text="{view>status}" class="sapUiTinyMarginBottom" />
                                                                
                                                                <Label text="Type" design="Bold" class="sapUiTinyMarginTop" />
                                                                <Text text="{view>type}" class="sapUiTinyMarginBottom" />
                                                                
                                                                <Label text="Stage" design="Bold" class="sapUiTinyMarginTop" />
                                                                <Text text="{view>executionStage}" class="sapUiTinyMarginBottom" />
                                                            </VBox>
                                                            
                                                            <!-- Column 2 -->
                                                            <VBox width="32%">
                                                                <Label text="Activity ID" design="Bold" />
                                                                <Text text="{view>id}" class="sapUiTinyMarginBottom" />
                                                                
                                                                <Label text="Planned Duration (min)" design="Bold" class="sapUiTinyMarginTop" />
                                                                <Text text="{view>fullActivity/plannedDurationInMinutes}" class="sapUiTinyMarginBottom" />
                                                                
                                                                <Label text="Planned Start" design="Bold" class="sapUiTinyMarginTop" />
                                                                <Text 
                                                                    text="{
                                                                        path: 'view>plannedStartDate',
                                                                        formatter: '.formatter.formatDateTime'
                                                                    }" 
                                                                    class="sapUiTinyMarginBottom"
                                                                />
                                                                
                                                                <Label text="Planned End" design="Bold" class="sapUiTinyMarginTop" />
                                                                <Text 
                                                                    text="{
                                                                        path: 'view>plannedEndDate',
                                                                        formatter: '.formatter.formatDateTime'
                                                                    }" 
                                                                />
                                                            </VBox>
                                                            
                                                            <!-- Column 3 -->
                                                            <VBox width="32%">
                                                                <Label text="Organization Level ID" design="Bold" />
                                                                <Text text="{view>fullActivity/orgLevelIds/0}" class="sapUiTinyMarginBottom" />
                                                                
                                                                <Label text="Address" design="Bold" class="sapUiTinyMarginTop" />
                                                                <Text text="{view>fullActivity/address/street} {view>fullActivity/address/streetNumber}" class="sapUiTinyMarginBottom" />
                                                                <Text text="{view>fullActivity/address/city}" class="sapUiTinyMarginBottom" />
                                                                
                                                                <Label text="Service Product" design="Bold" class="sapUiTinyMarginTop" />
                                                                <Text text="{view>fullActivity/serviceProduct/externalId}" class="sapUiTinyMarginBottom" />
                                                                
                                                                <Label text="Responsible" design="Bold" class="sapUiTinyMarginTop" />
                                                                <Text text="{view>fullActivity/responsibles/0/externalId}" />
                                                            </VBox>
                                                        </HBox>
                                                        
                                                        <!-- Action Button -->
                                                        <HBox justifyContent="End" class="sapUiSmallMarginTop">
                                                            <Button
                                                                text="Select Activity"
                                                                type="Emphasized"
                                                                press="onSelectActivityPress"
                                                                icon="sap-icon://action"
                                                            />
                                                        </HBox>
                                                        
                                                    </VBox>
                                                </content>
                                            </Panel>
                                            
                                        </CustomListItem>
                                    </List>
                                </VBox>
                                
                            </VBox>
                        </content>
                    </Panel>
                    
                </CustomListItem>
            </List>
        </VBox>
        
    </VBox>
</core:FragmentDefinition>