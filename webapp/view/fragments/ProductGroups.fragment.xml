<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <VBox class="sapUiResponsiveMargin">
        <List
            items="{view>/productGroups}"
            mode="None"
            showSeparators="None"
        >
            <CustomListItem type="Inactive">
                <Panel
                    headerText="Product: {view>productDescription}"
                    expandable="true"
                    expanded="{view>expanded}"
                    expand="onProductPanelExpand"
                    class="productGroupPanel"
                >
                    <headerToolbar>
                        <OverflowToolbar design="Info">
                            <core:Icon src="sap-icon://product" class="sapUiSmallMarginEnd"/>
                            <Title 
                                text="Product: {view>productDescription}"
                                wrapping="true"
                            />
                            <ToolbarSpacer />
                            <Title text="SO Item: {view>soItemId}" level="H5"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    
                    <content>
                        <Toolbar design="Transparent" height="2rem">
                            <Label text="{view>activityCount} Activities" design="Bold"/>
                        </Toolbar>
                        
                        <!-- ACTIVITIES LIST -->
                        <List
                            items="{path: 'view>activities', templateShareable: false}"
                            mode="None"
                            showSeparators="None"
                            growing="true"
                            growingThreshold="20"
                        >
                            <CustomListItem type="Inactive" class="activityListItem">
                                <VBox class="activityCard">
                                    
                                    <!-- Header: Code + Status -->
                                    <HBox justifyContent="SpaceBetween" alignItems="Start" class="sapUiTinyMarginBottom">
                                        <ObjectIdentifier
                                            title="{view>code}"
                                            text="ID: {view>externalId}"
                                            titleActive="false"
                                        />
                                        <VBox alignItems="End" class="activityStatusBox">
                                            <ObjectStatus text="{view>status}" state="{view>statusState}"/>
                                            <ObjectStatus text="{view>executionStage}" state="{view>stageState}"/>
                                        </VBox>
                                    </HBox>
                                    
                                    <!-- Subject -->
                                    <Text text="{view>subject}" wrapping="true" class="sapUiTinyMarginBottom"/>
                                    
                                    <!-- Quick Info: Address, Responsible, Org Level, Service Product -->
									<VBox class="activityQuickInfo">
                                        <l:Grid defaultSpan="XL6 L6 M12 S12" hSpacing="2" vSpacing="1" containerQuery="true">
                                            <!-- Left Column -->
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Address:" design="Bold" class="infoLabel"/>
                                                <Text text="{view>addressFull}" wrapping="true" class="infoValue detailFieldValue"/>
                                            </VBox>
                                            
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Responsible:" design="Bold" class="infoLabel"/>
                                                <Text text="{view>responsibleId}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                            
                                            <!-- Right Column -->
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Organization Level:" design="Bold" class="infoLabel"/>
                                                <Text text="{view>orgLevelId}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                            
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Service Product:" design="Bold" class="infoLabel"/>
                                                <Text text="{view>serviceProductDisplayText}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                        </l:Grid>
                                    </VBox>

                                    <!-- More Details Link -->
                                    <HBox class="activityActions">
                                        <Link
                                            text="{= ${view>detailsExpanded} ? 'Hide Details' : 'More Details...'}"
                                            press=".onToggleDetails"
                                            class="detailsToggleLink"
                                        />
                                    </HBox>

                                    <!-- Extended Details (Hidden) - Simplified for now -->
                                    <VBox visible="{view>detailsExpanded}" class="activityExtendedDetails">
                                        <Text text="No more details yet" class="infoValue"/>
                                    </VBox>

                                    <!-- T&M Summary Box -->
                                    <Panel backgroundDesign="Transparent" class="tmSummaryPanel">
                                        <headerToolbar>
                                            <Toolbar design="Transparent" height="2.5rem" class="tmSummaryToolbar">
                                                <core:Icon src="sap-icon://timesheet" class="sapUiTinyMarginEnd"/>
                                                <Label text="T&amp;M Reports:" design="Bold"/>
                                                <ObjectNumber number="{view>tmReportsCount}" unit="items" state="{= ${view>tmReportsCount} > 0 ? 'Success' : 'None'}"/>
                                                <ToolbarSpacer/>
                                            </Toolbar>
                                        </headerToolbar>
                                        <content>
                                            <HBox visible="{view>tmReportsLoaded}" class="sapUiTinyMargin">
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="Time Effort" class="sapUiTinyMarginBottom"/>
                                                    <ObjectNumber number="{view>tmTimeEffortCount}" state="Information"/>
                                                </VBox>
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="Material" class="sapUiTinyMarginBottom"/>
                                                    <ObjectNumber number="{view>tmMaterialCount}" state="Information"/>
                                                </VBox>
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="Expense" class="sapUiTinyMarginBottom"/>
                                                    <ObjectNumber number="{view>tmExpenseCount}" state="Information"/>
                                                </VBox>
                                                <VBox>
                                                    <Label text="Mileage" class="sapUiTinyMarginBottom"/>
                                                    <ObjectNumber number="{view>tmMileageCount}" state="Information"/>
                                                </VBox>
                                            </HBox>
                                        </content>
                                    </Panel>
                                    
                                    <!-- Action Buttons -->
                                    <HBox class="activityActions">
                                        <Button
                                            text="View T&amp;M"
                                            icon="sap-icon://detail-view"
                                            type="Emphasized"
                                            press=".onViewTMReports"
                                            class="tmActionButton"
                                        />
                                        <Button
                                            text="Add T&amp;M"
                                            icon="sap-icon://add"
                                            type="Accept"
                                            press=".onAddTMReport"
                                            class="tmActionButton"
                                        />
                                    </HBox>
                                    
                                </VBox>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>
            </CustomListItem>
        </List>
    </VBox>
</core:FragmentDefinition>