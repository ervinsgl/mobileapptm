<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <VBox class="sapUiResponsiveMargin">
    
        <!-- Empty State - No Activities for User's Org Level -->
        <IllustratedMessage
            illustrationType="sapIllus-NoEntries"
            title="{= ${view>/noActivitiesMessage/show} ? ${view>/noActivitiesMessage/title} : 'No Activities Found'}"
            description="{= ${view>/noActivitiesMessage/show} ? ${view>/noActivitiesMessage/description} : 'There are no activities assigned to your organization level.'}"
            visible="{= ${view>/productGroups}.length === 0 }"
        >
            <additionalContent>
                <Button text="Refresh" type="Emphasized" icon="sap-icon://refresh" press=".onRefresh"/>
            </additionalContent>
        </IllustratedMessage>
        
        <!-- Product Groups List -->
        <List items="{view>/productGroups}" mode="None" showSeparators="None" visible="{= ${view>/productGroups}.length > 0 }">
            <CustomListItem type="Inactive">
                <Panel expandable="true" expanded="{view>expanded}" expand="onProductPanelExpand" class="productGroupPanel">
                    <headerToolbar>
                        <OverflowToolbar design="Info">
                            <core:Icon src="sap-icon://product" class="sapUiSmallMarginEnd"/>
                            <Title text="Product: {view>productDescription}" wrapping="true"/>
                            <ToolbarSpacer/>
                            <Text text="ID: {view>soItemId}" class="sapUiTinyMarginEnd"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <Toolbar design="Transparent" height="2rem">
                            <Label text="{view>activityCount} Activities" design="Bold"/>
                            <ToolbarSpacer/>
                            <ObjectNumber number="{view>tmTotalCount}" unit="T&amp;M Entries" state="Information"/>
                        </Toolbar>
                        
                        <List items="{path: 'view>activities', templateShareable: false}" mode="None" showSeparators="None" growing="true" growingThreshold="20">
                            <CustomListItem type="Inactive" class="activityListItem">
                                <Panel expandable="true" expanded="{view>detailsExpanded}" class="activityEntryPanel">
                                    <customData>
                                        <core:CustomData key="highlighted" value="{view>entryActivityFlag}" writeToDom="true"/>
                                        <core:CustomData key="activitystatus" value="{view>status}" writeToDom="true"/>
                                    </customData>
                                    <headerToolbar>
                                        <OverflowToolbar design="Info" class="activityHeaderToolbar">
                                            <core:Icon src="sap-icon://activity-individual" class="sapUiSmallMarginEnd"/>
                                            <Title text="ID: {view>externalId}" level="H5" class="sapUiSmallMarginEnd activityHeaderId"/>
                                            <Title text="{view>subject}" level="H5" wrapping="true" class="activityHeaderSubject"/>
                                        </OverflowToolbar>
                                    </headerToolbar>
                                    <content>
                                        <Toolbar design="Info" class="activitySubjectBar sapUiTinyMarginBottom">
                                            <Title text="{view>code}" level="H6"/>
                                            <ToolbarSpacer/>
                                            <ObjectStatus text="{view>status}" state="{view>statusState}" class="sapUiTinyMarginEnd"/>
                                            <ObjectStatus text="{view>executionStage}" state="{view>stageState}"/>
                                        </Toolbar>
                                        
                                        <HBox class="activityEntryContent">
                                            <VBox class="activityColumn">
                                                <HBox class="activityFieldRow">
                                                    <Label text="Service Product:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>serviceProductDisplayText}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="Responsible:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>responsibleDisplayText}" class="activityFieldValue"/>
                                                </HBox>
                                            </VBox>
                                            <VBox class="activityColumn">
                                                <HBox class="activityFieldRow">
                                                    <Label text="Address:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>addressFull}" class="activityFieldValue" wrapping="true"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="Org Level:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>orgLevelDisplayText}" class="activityFieldValue"/>
                                                </HBox>
                                            </VBox>
                                            <VBox class="activityColumn">
                                                <HBox class="activityFieldRow">
                                                    <Label text="Planned Start:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>formattedStartDate}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="Planned End:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>formattedEndDate}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="Duration:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>formattedDuration}" class="activityFieldValue"/>
                                                </HBox>
                                            </VBox>
                                        </HBox>
                                        
                                        <!-- T&M REPORTS SECTION -->
                                        <VBox class="tmTablesSection sapUiSmallMarginTop">
                                            <HBox alignItems="Center" class="sapUiTinyMarginBottom sapUiSmallMarginBegin">
                                                <core:Icon src="sap-icon://timesheet" class="sapUiTinyMarginEnd"/>
                                                <Label text="T&amp;M Reports:" design="Bold"/>
                                                <ObjectNumber number="{view>tmReportsCount}" unit="items" state="{= ${view>tmReportsCount} > 0 ? 'Success' : 'None'}" class="sapUiTinyMarginBegin"/>
                                            </HBox>
                                            
                                            <!-- T&M Summary Stats - Only show for Time & Material activities (not expense/mileage) -->
                                            <HBox visible="{= ${view>tmReportsLoaded} &amp;&amp; ${view>isTimeMaterialType} }" class="sapUiTinyMarginBottom sapUiSmallMarginBegin" wrap="Wrap">
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="Quantity"/>
                                                    <HBox alignItems="Center">
                                                        <ObjectNumber number="{view>tmMaterialQtyReported}" state="{= ${view>tmMaterialQtyReported} > 0 ? 'Information' : 'None'}"/>
                                                        <Text text=" of " class="sapUiTinyMarginBeginEnd"/>
                                                        <Text text="{view>quantity}"/>
                                                    </HBox>
                                                </VBox>
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="Arbeitszeit"/>
                                                    <ObjectNumber number="{view>tmAzHoursReported}" unit="hrs" state="{= ${view>tmAzHoursReported} > 0 ? 'Information' : 'None'}"/>
                                                </VBox>
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="Fahrzeit"/>
                                                    <ObjectNumber number="{view>tmFzHoursReported}" unit="hrs" state="{= ${view>tmFzHoursReported} > 0 ? 'Information' : 'None'}"/>
                                                </VBox>
                                                <VBox>
                                                    <Label text="Wartezeit"/>
                                                    <ObjectNumber number="{view>tmWzHoursReported}" unit="hrs" state="{= ${view>tmWzHoursReported} > 0 ? 'Information' : 'None'}"/>
                                                </VBox>
                                            </HBox>
                                            
                                            <!-- TIME & MATERIAL TABLE -->
                                            <Panel expandable="true" expanded="true" visible="{= (${view>tmTimeEffortCount} + ${view>tmMaterialCount}) > 0 }" class="tmTypePanel">
                                                <headerToolbar>
                                                    <OverflowToolbar design="Info">
                                                        <core:Icon src="sap-icon://time-entry-request" class="sapUiTinyMarginEnd"/>
                                                        <Title text="Time Effort &amp; Material" level="H5"/>
                                                        <ToolbarSpacer/>
                                                        <SegmentedButton selectedKey="ALL" selectionChange=".onTMTypeFilterChange">
                                                            <items>
                                                                <SegmentedButtonItem key="ALL" text="All"/>
                                                                <SegmentedButtonItem key="Time Effort" icon="sap-icon://time-entry-request" tooltip="Time Effort"/>
                                                                <SegmentedButtonItem key="Material" icon="sap-icon://product" tooltip="Material"/>
                                                            </items>
                                                        </SegmentedButton>
                                                        <Select selectedKey="startDateTime-desc" change=".onTMSortChange" class="sapUiTinyMarginBegin" tooltip="Sort by">
                                                            <core:Item key="startDateTime-desc" text="Date ↓"/>
                                                            <core:Item key="startDateTime-asc" text="Date ↑"/>
                                                            <core:Item key="type-asc" text="Type A-Z"/>
                                                            <core:Item key="type-desc" text="Type Z-A"/>
                                                            <core:Item key="taskDisplayText-asc" text="Description A-Z"/>
                                                            <core:Item key="taskDisplayText-desc" text="Description Z-A"/>
                                                            <core:Item key="createPersonDisplayText-asc" text="Technician A-Z"/>
                                                            <core:Item key="createPersonDisplayText-desc" text="Technician Z-A"/>
                                                            <core:Item key="durationHrs-desc" text="Time ↓"/>
                                                            <core:Item key="durationHrs-asc" text="Time ↑"/>
                                                            <core:Item key="quantity-desc" text="Qty ↓"/>
                                                            <core:Item key="quantity-asc" text="Qty ↑"/>
                                                            <core:Item key="decisionStatus-asc" text="Status A-Z"/>
                                                            <core:Item key="decisionStatus-desc" text="Status Z-A"/>
                                                        </Select>
                                                        <Button text="Edit Selected" icon="sap-icon://edit" press=".onEditSelectedTM" visible="{= ${view>tmEditMode} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="Save All" icon="sap-icon://save" type="Emphasized" press=".onSaveAllTM" visible="{= ${view>tmEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="End Edit" icon="sap-icon://sys-cancel" press=".onEndEditTM" visible="{= ${view>tmEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="Add Entry" icon="sap-icon://add" type="Emphasized" press=".onAddNewTMEntry" visible="{= ${view>status} !== 'CLOSED' &amp;&amp; ${view>status} !== 'CANCELLED'}" class="sapUiTinyMarginBegin"/>
                                                        <ObjectNumber number="{= ${view>tmTimeEffortCount} + ${view>tmMaterialCount} }" unit="entries" class="sapUiSmallMarginBegin"/>
                                                    </OverflowToolbar>
                                                </headerToolbar>
                                                <content>
                                                    <ScrollContainer horizontal="true" vertical="false" width="100%">
                                                        <Table
                                                            items="{path: 'view>tmReports', templateShareable: false, filters: [{ path: 'type', operator: 'NE', value1: 'Expense' }, { path: 'type', operator: 'NE', value1: 'Mileage' }], sorter: { path: 'startDateTime', descending: true }}"
                                                            class="tmMTable"
                                                            width="auto"
                                                        >
                                                            <columns>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column hAlign="Begin"><Text text="Description"/></Column>
                                                                <Column width="10rem" hAlign="Begin"><Text text="Technician"/></Column>
                                                                <Column width="7rem" hAlign="Begin"><Text text="Time"/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="5rem" hAlign="Begin"><Text text="Qty"/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="8rem" hAlign="Begin"><Text text="Date"/></Column>
                                                                <Column hAlign="Begin"><Text text="Remarks"/></Column>
                                                                <Column width="6rem" hAlign="Center"><Text text="Status"/></Column>
                                                            </columns>
                                                            <items>
                                                                <ColumnListItem type="Inactive" highlight="{= ${view>decisionStatus} === 'APPROVED' ? 'Success' : (${view>decisionStatus} === 'DECLINED' || ${view>decisionStatus} === 'CANCELLED' || ${view>decisionStatus} === 'DECLINED_CLOSED') ? 'Error' : ${view>editMode} ? 'Information' : 'None'}">
                                                                    <cells>
                                                                        <CheckBox selected="{view>selected}" visible="{= ${view>decisionStatus} === 'PENDING' || ${view>decisionStatus} === 'REVIEW'}"/>
                                                                        <core:Icon src="{= ${view>type} === 'Time Effort' ? 'sap-icon://time-entry-request' : 'sap-icon://product'}" color="{= ${view>type} === 'Time Effort' ? '#0854A0' : '#107E3E'}" tooltip="{view>type}"/>
                                                                        <Text text="{= ${view>type} === 'Time Effort' ? ${view>taskDisplayText} : ${view>itemDisplayText}}"/>
                                                                        <Text text="{view>createPersonDisplayText}"/>
                                                                        <!-- Time: show StepInput for Time Effort (in hours), N/A for Material -->
                                                                        <HBox alignItems="Center">
                                                                            <StepInput value="{view>durationHrs}" min="0" step="0.25" displayValuePrecision="2" width="5rem" editable="{view>editMode}" visible="{= ${view>type} === 'Time Effort'}"/>
                                                                            <Text text="N/A" visible="{= ${view>type} !== 'Time Effort'}"/>
                                                                        </HBox>
                                                                        <Text text="{= ${view>type} === 'Time Effort' ? 'hrs' : ''}" class="sapUiTinyMarginBegin"/>
                                                                        <!-- Qty: show Input for Material, N/A for Time Effort -->
                                                                        <HBox>
                                                                            <Input value="{view>quantity}" type="Number" width="4rem" editable="{view>editMode}" visible="{= ${view>type} === 'Material'}"/>
                                                                            <Text text="N/A" visible="{= ${view>type} !== 'Material'}"/>
                                                                        </HBox>
                                                                        <Text text="{= ${view>type} === 'Material' ? 'pcs' : ''}" class="sapUiTinyMarginBegin"/>
                                                                        <!-- Date: editable DatePicker in edit mode -->
                                                                        <DatePicker value="{view>entryDateFormatted}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="100%" editable="{view>editMode}"/>
                                                                        <Input value="{view>remarksText}" width="100%" editable="{view>editMode}"/>
                                                                        <ObjectStatus text="{= ${view>decisionStatus} === 'DECLINED_CLOSED' ? 'DECLINED' : ${view>decisionStatus}}" state="{view>decisionStatusState}" icon="{= ${view>decisionStatus} === 'APPROVED' ? 'sap-icon://accept' : (${view>decisionStatus} === 'DECLINED' || ${view>decisionStatus} === 'CANCELLED' || ${view>decisionStatus} === 'DECLINED_CLOSED') ? 'sap-icon://decline' : ''}"/>
                                                                    </cells>
                                                                </ColumnListItem>
                                                            </items>
                                                        </Table>
                                                    </ScrollContainer>
                                                </content>
                                            </Panel>
                                            
                                            <!-- EXPENSES TABLE -->
                                            <Panel expandable="true" expanded="true" visible="{= ${view>tmExpenseCount} > 0 }" class="tmTypePanel">
                                                <headerToolbar>
                                                    <OverflowToolbar design="Info">
                                                        <core:Icon src="sap-icon://money-bills" class="sapUiTinyMarginEnd" color="#E9730C"/>
                                                        <Title text="Expenses" level="H5"/>
                                                        <ToolbarSpacer/>
                                                        <Select selectedKey="createDateTime-desc" change=".onTMSortChange" class="sapUiTinyMarginBegin" tooltip="Sort by">
                                                            <core:Item key="createDateTime-desc" text="Date ↓"/>
                                                            <core:Item key="createDateTime-asc" text="Date ↑"/>
                                                            <core:Item key="expenseTypeDisplayText-asc" text="Type A-Z"/>
                                                            <core:Item key="expenseTypeDisplayText-desc" text="Type Z-A"/>
                                                            <core:Item key="createPersonDisplayText-asc" text="Technician A-Z"/>
                                                            <core:Item key="createPersonDisplayText-desc" text="Technician Z-A"/>
                                                            <core:Item key="externalAmountValue-desc" text="Amount ↓"/>
                                                            <core:Item key="externalAmountValue-asc" text="Amount ↑"/>
                                                            <core:Item key="decisionStatus-asc" text="Status A-Z"/>
                                                        </Select>
                                                        <Button text="Edit Selected" icon="sap-icon://edit" press=".onEditSelectedTM" visible="{= ${view>expenseEditMode} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="Save All" icon="sap-icon://save" type="Emphasized" press=".onSaveAllTM" visible="{= ${view>expenseEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="End Edit" icon="sap-icon://sys-cancel" press=".onEndEditTM" visible="{= ${view>expenseEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="Add Entry" icon="sap-icon://add" type="Emphasized" press=".onAddNewTMEntry" visible="{= ${view>status} !== 'CLOSED' &amp;&amp; ${view>status} !== 'CANCELLED'}" class="sapUiTinyMarginBegin"/>
                                                        <ObjectNumber number="{view>tmExpenseCount}" unit="entries" class="sapUiSmallMarginBegin"/>
                                                    </OverflowToolbar>
                                                </headerToolbar>
                                                <content>
                                                    <ScrollContainer horizontal="true" vertical="false" width="100%">
                                                        <Table
                                                            items="{path: 'view>tmReports', templateShareable: false, filters: [{ path: 'type', operator: 'EQ', value1: 'Expense' }], sorter: { path: 'createDateTime', descending: true }}"
                                                            class="tmMTable"
                                                            width="auto"
                                                        >
                                                            <columns>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column hAlign="Begin"><Text text="Expense Type"/></Column>
                                                                <Column width="10rem" hAlign="Begin"><Text text="Technician"/></Column>
                                                                <Column width="5rem" hAlign="Begin"><Text text="Ext. Amt"/></Column>
                                                                <Column width="5rem" hAlign="Begin"><Text text="Int. Amt"/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="8rem" hAlign="Begin"><Text text="Date"/></Column>
                                                                <Column hAlign="Begin"><Text text="Remarks"/></Column>
                                                                <Column width="6rem" hAlign="Center"><Text text="Status"/></Column>
                                                            </columns>
                                                            <items>
                                                                <ColumnListItem type="Inactive" highlight="{= ${view>decisionStatus} === 'APPROVED' ? 'Success' : (${view>decisionStatus} === 'DECLINED' || ${view>decisionStatus} === 'CANCELLED' || ${view>decisionStatus} === 'DECLINED_CLOSED') ? 'Error' : ${view>editMode} ? 'Information' : 'None'}">
                                                                    <cells>
                                                                        <CheckBox selected="{view>selected}" visible="{= ${view>decisionStatus} === 'PENDING' || ${view>decisionStatus} === 'REVIEW'}"/>
                                                                        <Text text="{view>expenseTypeDisplayText}"/>
                                                                        <Text text="{view>createPersonDisplayText}"/>
                                                                        <Input value="{view>externalAmountValue}" type="Number" width="100%" editable="{view>editMode}"/>
                                                                        <Input value="{view>internalAmountValue}" type="Number" width="100%" editable="{view>editMode}"/>
                                                                        <Text text="EUR"/>
                                                                        <DatePicker value="{view>entryDateFormatted}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="100%" editable="{view>editMode}"/>
                                                                        <Input value="{view>remarksText}" width="100%" editable="{view>editMode}"/>
                                                                        <ObjectStatus text="{= ${view>decisionStatus} === 'DECLINED_CLOSED' ? 'DECLINED' : ${view>decisionStatus}}" state="{view>decisionStatusState}" icon="{= ${view>decisionStatus} === 'APPROVED' ? 'sap-icon://accept' : (${view>decisionStatus} === 'DECLINED' || ${view>decisionStatus} === 'CANCELLED' || ${view>decisionStatus} === 'DECLINED_CLOSED') ? 'sap-icon://decline' : ''}"/>
                                                                    </cells>
                                                                </ColumnListItem>
                                                            </items>
                                                        </Table>
                                                    </ScrollContainer>
                                                </content>
                                            </Panel>
                                            
                                            <!-- MILEAGE TABLE -->
                                            <Panel expandable="true" expanded="true" visible="{= ${view>tmMileageCount} > 0 }" class="tmTypePanel">
                                                <headerToolbar>
                                                    <OverflowToolbar design="Info">
                                                        <core:Icon src="sap-icon://car-rental" class="sapUiTinyMarginEnd" color="#6C32A9"/>
                                                        <Title text="Mileage" level="H5"/>
                                                        <ToolbarSpacer/>
                                                        <Select selectedKey="createDateTime-desc" change=".onTMSortChange" class="sapUiTinyMarginBegin" tooltip="Sort by">
                                                            <core:Item key="createDateTime-desc" text="Date ↓"/>
                                                            <core:Item key="createDateTime-asc" text="Date ↑"/>
                                                            <core:Item key="mileageTypeDisplayText-asc" text="Type A-Z"/>
                                                            <core:Item key="mileageTypeDisplayText-desc" text="Type Z-A"/>
                                                            <core:Item key="createPersonDisplayText-asc" text="Technician A-Z"/>
                                                            <core:Item key="createPersonDisplayText-desc" text="Technician Z-A"/>
                                                            <core:Item key="distanceValue-desc" text="Distance ↓"/>
                                                            <core:Item key="distanceValue-asc" text="Distance ↑"/>
                                                            <core:Item key="decisionStatus-asc" text="Status A-Z"/>
                                                        </Select>
                                                        <Button text="Edit Selected" icon="sap-icon://edit" press=".onEditSelectedTM" visible="{= ${view>mileageEditMode} !== true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="Save All" icon="sap-icon://save" type="Emphasized" press=".onSaveAllTM" visible="{= ${view>mileageEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="End Edit" icon="sap-icon://sys-cancel" press=".onEndEditTM" visible="{= ${view>mileageEditMode} === true}" class="sapUiTinyMarginBegin"/>
                                                        <Button text="Add Entry" icon="sap-icon://add" type="Emphasized" press=".onAddNewTMEntry" visible="{= ${view>status} !== 'CLOSED' &amp;&amp; ${view>status} !== 'CANCELLED'}" class="sapUiTinyMarginBegin"/>
                                                        <ObjectNumber number="{view>tmMileageCount}" unit="entries" class="sapUiSmallMarginBegin"/>
                                                    </OverflowToolbar>
                                                </headerToolbar>
                                                <content>
                                                    <ScrollContainer horizontal="true" vertical="false" width="100%">
                                                        <Table
                                                            items="{path: 'view>tmReports', templateShareable: false, filters: [{ path: 'type', operator: 'EQ', value1: 'Mileage' }], sorter: { path: 'createDateTime', descending: true }}"
                                                            class="tmMTable"
                                                            width="auto"
                                                        >
                                                            <columns>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column hAlign="Begin"><Text text="Mileage Type"/></Column>
                                                                <Column width="10rem" hAlign="Begin"><Text text="Technician"/></Column>
                                                                <Column width="5rem" hAlign="Begin"><Text text="Dist."/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="5rem" hAlign="Begin"><Text text="Dur."/></Column>
                                                                <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                                                <Column width="8rem" hAlign="Begin"><Text text="Date"/></Column>
                                                                <Column hAlign="Begin"><Text text="Remarks"/></Column>
                                                                <Column width="6rem" hAlign="Center"><Text text="Status"/></Column>
                                                            </columns>
                                                            <items>
                                                                <ColumnListItem type="Inactive" highlight="{= ${view>decisionStatus} === 'APPROVED' ? 'Success' : (${view>decisionStatus} === 'DECLINED' || ${view>decisionStatus} === 'CANCELLED' || ${view>decisionStatus} === 'DECLINED_CLOSED') ? 'Error' : ${view>editMode} ? 'Information' : 'None'}">
                                                                    <cells>
                                                                        <CheckBox selected="{view>selected}" visible="{= ${view>decisionStatus} === 'PENDING' || ${view>decisionStatus} === 'REVIEW'}"/>
                                                                        <Text text="{view>mileageTypeDisplayText}"/>
                                                                        <Text text="{view>createPersonDisplayText}"/>
                                                                        <Input value="{view>distanceValue}" type="Number" width="100%" editable="{view>editMode}"/>
                                                                        <Text text="KM"/>
                                                                        <Input value="{view>travelDurationMinutes}" type="Number" width="100%" editable="{view>editMode}"/>
                                                                        <Text text="min"/>
                                                                        <DatePicker value="{view>entryDateFormatted}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="100%" editable="{view>editMode}"/>
                                                                        <Input value="{view>remarksText}" width="100%" editable="{view>editMode}"/>
                                                                        <ObjectStatus text="{= ${view>decisionStatus} === 'DECLINED_CLOSED' ? 'DECLINED' : ${view>decisionStatus}}" state="{view>decisionStatusState}" icon="{= ${view>decisionStatus} === 'APPROVED' ? 'sap-icon://accept' : (${view>decisionStatus} === 'DECLINED' || ${view>decisionStatus} === 'CANCELLED' || ${view>decisionStatus} === 'DECLINED_CLOSED') ? 'sap-icon://decline' : ''}"/>
                                                                    </cells>
                                                                </ColumnListItem>
                                                            </items>
                                                        </Table>
                                                    </ScrollContainer>
                                                </content>
                                            </Panel>
                                            
                                            <!-- Empty State -->
                                            <VBox visible="{= ${view>tmReportsCount} === 0 }" alignItems="Center" class="sapUiMediumMarginTopBottom">
                                                <core:Icon src="sap-icon://document" size="2rem" color="#888"/>
                                                <Text text="No T&amp;M entries yet" class="sapUiTinyMarginTop"/>
                                                <Button text="Add Entry" icon="sap-icon://add" type="Emphasized" press=".onAddNewTMEntry" visible="{= ${view>status} !== 'CLOSED' &amp;&amp; ${view>status} !== 'CANCELLED'}" class="sapUiSmallMarginTop"/>
                                            </VBox>
                                        </VBox>
                                    </content>
                                </Panel>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>
            </CustomListItem>
        </List>
    </VBox>
</core:FragmentDefinition>