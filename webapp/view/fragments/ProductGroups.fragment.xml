<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <VBox id="productGroupsMainContainer" class="sapUiResponsiveMargin">
        
        <VBox id="productGroupsContainer">
            <List
                id="productGroupsList"
                items="{view>/productGroups}"
                mode="None"
                showSeparators="None"
            >
                <CustomListItem type="Inactive">
                    
                    <Panel
                        headerText="Product: {view>productDescription}"
                        expandable="true"
                        expanded="{view>expanded}"
                        expand="onProductPanelExpand"
                        class="sapUiSmallMarginBottom productGroupPanel"
                        width="auto"
                    >
                        <headerToolbar>
                            <OverflowToolbar 
                                design="Solid"
                                class="productGroupHeader">
                                <Title 
                                    text="Product: {view>productDescription}" 
                                    level="H4" 
                                    titleStyle="H4"
                                    class="sapUiTinyMarginBegin productGroupHeaderTitle"
                                    wrapping="true"
                                />
                                <ToolbarSpacer />
                                <Label 
                                    text="SO Item: {view>soItemId}" 
                                    design="Bold"
                                    class="sapUiTinyMarginEnd productGroupHeaderLabel"
                                />
                            </OverflowToolbar>
                        </headerToolbar>
                        
                        <content>
                            <!-- Activity Count -->
                            <Toolbar class="activitiesTableToolbar">
                                <Title 
                                    text="{view>activityCount} Activities" 
                                    level="H5"
                                />
                            </Toolbar>
                            
                            <!-- Column Headers -->
                            <HBox class="activityTableHeader" width="100%">
                                <Text text="" class="activityHeaderText">
                                    <layoutData>
                                        <FlexItemData growFactor="0" shrinkFactor="0" baseSize="3%"/>
                                    </layoutData>
                                </Text>
                                <Text text="Code" class="activityHeaderText">
                                    <layoutData>
                                        <FlexItemData growFactor="0" shrinkFactor="0" baseSize="8%"/>
                                    </layoutData>
                                </Text>
                                <Text text="External ID" class="activityHeaderText">
                                    <layoutData>
                                        <FlexItemData growFactor="0" shrinkFactor="0" baseSize="10%"/>
                                    </layoutData>
                                </Text>
                                <Text text="Subject" class="activityHeaderText">
                                    <layoutData>
                                        <FlexItemData growFactor="1" shrinkFactor="1" baseSize="17%"/>
                                    </layoutData>
                                </Text>
                                <HBox justifyContent="Center">
                                    <layoutData>
                                        <FlexItemData growFactor="0" shrinkFactor="0" baseSize="7%"/>
                                    </layoutData>
                                    <Text text="Status" class="activityHeaderText"/>
                                </HBox>
                                <HBox justifyContent="Center">
                                    <layoutData>
                                        <FlexItemData growFactor="0" shrinkFactor="0" baseSize="7%"/>
                                    </layoutData>
                                    <Text text="Stage" class="activityHeaderText"/>
                                </HBox>
                                <Text text="Planned Start" class="activityHeaderText">
                                    <layoutData>
                                        <FlexItemData growFactor="0" shrinkFactor="0" baseSize="10%"/>
                                    </layoutData>
                                </Text>
                                <Text text="Planned End" class="activityHeaderText">
                                    <layoutData>
                                        <FlexItemData growFactor="0" shrinkFactor="0" baseSize="10%"/>
                                    </layoutData>
                                </Text>
                                <Text text="Duration" class="activityHeaderText">
                                    <layoutData>
                                        <FlexItemData growFactor="0" shrinkFactor="0" baseSize="6%"/>
                                    </layoutData>
                                </Text>
                                <Text text="Org Level" class="activityHeaderText">
                                    <layoutData>
                                        <FlexItemData growFactor="0" shrinkFactor="0" baseSize="10%"/>
                                    </layoutData>
                                </Text>
                                <Text text="Address" class="activityHeaderText">
                                    <layoutData>
                                        <FlexItemData growFactor="1" shrinkFactor="1" baseSize="12%"/>
                                    </layoutData>
                                </Text>
                            </HBox>
                            
                            <!-- Activities List -->
                            <List
                                id="activitiesList"
                                items="{view>activities}"
                                mode="None"
                                showSeparators="All"
                                growing="true"
                                growingThreshold="10"
                            >
                                <CustomListItem type="Inactive">
                                    <VBox width="100%">
                                        <!-- Main Activity Row -->
                                        <HBox class="activityRow" alignItems="Center" width="100%">
                                            <HBox alignItems="Center" justifyContent="Center">
                                                <layoutData>
                                                    <FlexItemData growFactor="0" shrinkFactor="0" baseSize="3%"/>
                                                </layoutData>
                                                <core:Icon 
                                                    src="sap-icon://navigation-right-arrow"
                                                    class="{view>tmIconClass}"
                                                    press=".onToggleTMReports"
                                                />
                                            </HBox>
                                            
                                            <Text 
                                                text="{view>code}" 
                                                class="{view>textClass}"
                                            >
                                                <layoutData>
                                                    <FlexItemData growFactor="0" shrinkFactor="0" baseSize="8%"/>
                                                </layoutData>
                                            </Text>
                                            
                                            <Text 
                                                text="{view>externalId}" 
                                                class="{view>textClass}"
                                            >
                                                <layoutData>
                                                    <FlexItemData growFactor="0" shrinkFactor="0" baseSize="10%"/>
                                                </layoutData>
                                            </Text>
                                            
                                            <Text 
                                                text="{view>subject}" 
                                                wrapping="true"
                                                class="{view>textClass}"
                                            >
                                                <layoutData>
                                                    <FlexItemData growFactor="1" shrinkFactor="1" baseSize="17%"/>
                                                </layoutData>
                                            </Text>
                                            
                                            <HBox justifyContent="Center">
                                                <layoutData>
                                                    <FlexItemData growFactor="0" shrinkFactor="0" baseSize="7%"/>
                                                </layoutData>
                                                <ObjectStatus 
                                                    text="{view>status}" 
                                                    state="{view>statusState}"
                                                />
                                            </HBox>
                                            
                                            <HBox justifyContent="Center">
                                                <layoutData>
                                                    <FlexItemData growFactor="0" shrinkFactor="0" baseSize="7%"/>
                                                </layoutData>
                                                <ObjectStatus 
                                                    text="{view>executionStage}" 
                                                    state="{view>stageState}"
                                                />
                                            </HBox>
                                            
                                            <Text 
                                                text="{view>formattedStartDate}"
                                                class="{view>textClass}"
                                            >
                                                <layoutData>
                                                    <FlexItemData growFactor="0" shrinkFactor="0" baseSize="10%"/>
                                                </layoutData>
                                            </Text>
                                            
                                            <Text 
                                                text="{view>formattedEndDate}"
                                                class="{view>textClass}"
                                            >
                                                <layoutData>
                                                    <FlexItemData growFactor="0" shrinkFactor="0" baseSize="10%"/>
                                                </layoutData>
                                            </Text>
                                            
                                            <Text 
                                                text="{view>formattedDuration}"
                                                class="{view>textClass}"
                                            >
                                                <layoutData>
                                                    <FlexItemData growFactor="0" shrinkFactor="0" baseSize="6%"/>
                                                </layoutData>
                                            </Text>
                                            
                                            <Text 
                                                text="{view>orgLevelId}"
                                                class="{view>textClass}"
                                            >
                                                <layoutData>
                                                    <FlexItemData growFactor="0" shrinkFactor="0" baseSize="10%"/>
                                                </layoutData>
                                            </Text>
                                            
                                            <Text 
                                                text="{view>addressFull}"
                                                class="{view>textClass}"
                                                wrapping="true"
                                            >
                                                <layoutData>
                                                    <FlexItemData growFactor="1" shrinkFactor="1" baseSize="12%"/>
                                                </layoutData>
                                            </Text>
                                        </HBox>
                                        
                                        <!-- T&M Reports Expandable Section -->
                                        <VBox visible="{view>tmReportsExpanded}" class="tmReportsPanel">
                                            <Panel
                                                headerText="T&amp;M Reports"
                                                class="tmReportsInnerPanel"
                                            >
                                                <!-- Loading State -->
                                                <VBox 
                                                    visible="{view>tmReportsLoading}"
                                                    alignItems="Center"
                                                    class="sapUiSmallMargin"
                                                >
                                                    <BusyIndicator size="2rem"/>
                                                    <Text text="Loading reports..." class="sapUiTinyMarginTop"/>
                                                </VBox>
                                                
                                                <!-- Empty State -->
                                                <VBox 
                                                    visible="{= !${view>tmReportsLoading} &amp;&amp; ${view>tmReportsCount} === 0}"
                                                    class="sapUiSmallMargin"
                                                >
                                                    <MessageStrip
                                                        text="No reports have been made."
                                                        type="Information"
                                                        showIcon="true"
                                                    />
                                                </VBox>
                                                
                                                <!-- Reports Table -->
                                                <Table
                                                    visible="{= !${view>tmReportsLoading} &amp;&amp; ${view>tmReportsCount} > 0}"
                                                    items="{view>tmReports}"
                                                    class="tmReportsTable"
                                                >
                                                    <columns>
                                                        <Column width="15%">
                                                            <Text text="Type"/>
                                                        </Column>
                                                        <Column width="40%">
                                                            <Text text="ID"/>
                                                        </Column>
                                                        <Column width="45%">
                                                            <Text text="Created Date"/>
                                                        </Column>
                                                    </columns>
                                                    <items>
                                                        <ColumnListItem>
                                                            <cells>
                                                                <Text text="{view>type}"/>
                                                                <Text text="{view>id}"/>
                                                                <Text text="{
                                                                    path: 'view>createDateTime',
                                                                    formatter: '.formatter.formatDateTime'
                                                                }"/>
                                                            </cells>
                                                        </ColumnListItem>
                                                    </items>
                                                </Table>
                                            </Panel>
                                        </VBox>
                                    </VBox>
                                </CustomListItem>
                            </List>
                        </content>
                    </Panel>
                    
                </CustomListItem>
            </List>
        </VBox>
        
    </VBox>
</core:FragmentDefinition>