<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <VBox class="sapUiResponsiveMargin">
        <List
            items="{view>/productGroups}"
            mode="None"
            showSeparators="None"
        >
            <CustomListItem type="Inactive">
                <Panel
                    headerText="Product: {view>productDescription}"
                    expandable="true"
                    expanded="{view>expanded}"
                    expand="onProductPanelExpand"
                    class="productGroupPanel"
                >
                    <headerToolbar>
                        <OverflowToolbar class="productGroupHeader">
                            <Title 
                                text="Product: {view>productDescription}"
                                wrapping="true"
                                class="productGroupHeaderTitle"
                            />
                            <ToolbarSpacer />
                            <Label 
                                text="SO Item: {view>soItemId}" 
                                class="productGroupHeaderLabel"
                            />
                        </OverflowToolbar>
                    </headerToolbar>
                    
                    <content>
                        <Toolbar class="activitiesTableToolbar">
                            <Title text="{view>activityCount} Activities"/>
                        </Toolbar>
                        
                        <!-- SIMPLIFIED ACTIVITIES LIST -->
                        <List
                            items="{path: 'view>activities', templateShareable: false}"
                            mode="None"
                            growing="true"
                            growingThreshold="20"
                        >
                            <CustomListItem type="Inactive" class="activityCardContainer">
                                <VBox width="100%" class="activityCard">
                                    
                                    <!-- Header: Code + External ID + Status -->
                                    <HBox justifyContent="SpaceBetween" alignItems="Center" class="activityHeader">
                                        <VBox>
                                            <Text text="{view>code}" class="activityCode"/>
                                            <Text text="ID: {view>externalId}" class="activityExternalId"/>
                                        </VBox>
                                        <HBox>
                                            <ObjectStatus text="{view>status}" state="{view>statusState}"/>
                                            <ObjectStatus text="{view>executionStage}" state="{view>stageState}" class="sapUiTinyMarginBegin"/>
                                        </HBox>
                                    </HBox>
                                    
                                    <!-- Subject -->
                                    <Text text="{view>subject}" wrapping="true" class="activitySubject"/>
                                    
                                    <!-- Quick Info: Address + Time -->
									<VBox class="activityQuickInfo">
                                        <l:Grid defaultSpan="XL6 L6 M12 S12" hSpacing="2" vSpacing="1" containerQuery="true">
                                            <!-- Left Column -->
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Address:" design="Bold" class="infoLabel"/>
                                                <Text text="{view>addressFull}" wrapping="true" class="infoValue detailFieldValue"/>
                                            </VBox>
                                            
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Responsible:" design="Bold" class="infoLabel"/>
                                                <Text text="{view>responsibleId}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                            
                                            <!-- Right Column -->
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Planned Start:" design="Bold" class="infoLabel"/>
                                                <Text text="{view>formattedStartDate}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                            
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Planned End:" design="Bold" class="infoLabel"/>
                                                <Text text="{view>formattedEndDate}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                        </l:Grid>
                                    </VBox>

                                    <!-- More Details Link -->
                                    <HBox class="activityActions">
                                        <Link
                                            text="{= ${view>detailsExpanded} ? 'Hide Details' : 'More Details...'}"
                                            press=".onToggleDetails"
                                            class="detailsToggleLink"
                                        />
                                    </HBox>

                                    <!-- Extended Details (Hidden) -->
                                    <VBox visible="{view>detailsExpanded}" class="activityExtendedDetails">
                                        <l:Grid defaultSpan="XL6 L6 M12 S12" hSpacing="2" vSpacing="1" containerQuery="true">
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Duration" design="Bold" class="infoLabel"/>
                                                <Text text="{view>formattedDuration}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                            
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Organization Level" design="Bold" class="infoLabel"/>
                                                <Text text="{view>orgLevelId}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                            
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Service Product" design="Bold" class="infoLabel"/>
                                                <Text text="{view>serviceProductId}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                            
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Quantity" design="Bold" class="infoLabel"/>
                                                <Text text="{view>quantity}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                            
                                            <VBox class="detailField">
                                                <layoutData>
                                                    <l:GridData span="XL6 L6 M12 S12"/>
                                                </layoutData>
                                                <Label text="Unit of Measure" design="Bold" class="infoLabel"/>
                                                <Text text="{view>quantityUoM}" class="infoValue detailFieldValue"/>
                                            </VBox>
                                        </l:Grid>
                                    </VBox>

                                    <!-- T&M Summary Box -->
                                    <VBox class="tmSummaryBox">
                                        <HBox justifyContent="SpaceBetween" alignItems="Center">
                                            <Text text="T&amp;M Reports: {view>tmReportsCount} items" class="tmSummaryTitle"/>
                                            <core:Icon src="sap-icon://chart-table-view" size="1.25rem" color="#0854a0"/>
                                        </HBox>
                                        
                                        <!-- T&M Type Breakdown (show when loaded) -->
                                        <VBox visible="{view>tmReportsLoaded}" class="sapUiTinyMarginTop">
                                            <Text text="• Time Effort: {view>tmTimeEffortCount}" class="tmSummaryItem"/>
                                            <Text text="• Material: {view>tmMaterialCount}" class="tmSummaryItem"/>
                                            <Text text="• Expense: {view>tmExpenseCount}" class="tmSummaryItem"/>
                                            <Text text="• Mileage: {view>tmMileageCount}" class="tmSummaryItem"/>
                                        </VBox>
                                    </VBox>
                                    
                                    <!-- Action Buttons -->
                                    <HBox class="activityActions">
                                        <Button
                                            text="View T&amp;M"
                                            icon="sap-icon://detail-view"
                                            type="Emphasized"
                                            press=".onViewTMReports"
                                            class="tmActionButton"
                                        />
                                        <Button
                                            text="Add T&amp;M"
                                            icon="sap-icon://add"
                                            type="Accept"
                                            press=".onAddTMReport"
                                            class="tmActionButton"
                                        />
                                    </HBox>
                                    
                                </VBox>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>
            </CustomListItem>
        </List>
    </VBox>
</core:FragmentDefinition>