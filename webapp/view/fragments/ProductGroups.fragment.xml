<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <VBox class="sapUiResponsiveMargin">
        <List
            items="{view>/productGroups}"
            mode="None"
            showSeparators="None"
        >
            <CustomListItem type="Inactive">
                <Panel
                    headerText="Product: {view>productDescription}"
                    expandable="true"
                    expanded="{view>expanded}"
                    expand="onProductPanelExpand"
                    class="productGroupPanel"
                >
                    <headerToolbar>
                        <OverflowToolbar design="Info">
                            <core:Icon src="sap-icon://product" class="sapUiSmallMarginEnd"/>
                            <Title 
                                text="Product: {view>productDescription}"
                                wrapping="true"
                            />
                            <ToolbarSpacer />
                            <Title text="ID: {view>soItemId}" level="H5"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    
                    <content>
                        <Toolbar design="Transparent" height="2rem">
                            <Label text="{view>activityCount} Activities" design="Bold"/>
                        </Toolbar>
                        
                        <!-- ACTIVITIES LIST -->
                        <List
                            items="{path: 'view>activities', templateShareable: false}"
                            mode="None"
                            showSeparators="None"
                            growing="true"
                            growingThreshold="20"
                        >
                            <CustomListItem type="Inactive" class="activityListItem">
                                <Panel
                                    expandable="true"
                                    expanded="{view>detailsExpanded}"
                                    class="activityEntryPanel"
                                >
                                    <headerToolbar>
                                        <OverflowToolbar design="Info">
                                            <core:Icon src="sap-icon://activity-individual" class="sapUiSmallMarginEnd"/>
                                            <Title 
                                                text="{view>code}  {view>subject}" 
                                                level="H5"
                                            />
                                            <ToolbarSpacer />
                                            <ObjectStatus text="{view>status}" state="{view>statusState}" class="sapUiTinyMarginEnd"/>
                                            <ObjectStatus text="{view>executionStage}" state="{view>stageState}" class="sapUiTinyMarginEnd"/>
                                            <Label text="ID: {view>externalId}"/>
                                        </OverflowToolbar>
                                    </headerToolbar>
                                    
                                    <content>
                                        <!-- Activity Details - Compact 3-Column Layout -->
                                        <HBox class="activityEntryContent">
                                            <!-- Column 1: Service Product, Responsible -->
                                            <VBox class="activityColumn">
                                                <HBox class="activityFieldRow">
                                                    <Label text="Service Product:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>serviceProductDisplayText}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="Responsible:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>responsibleId}" class="activityFieldValue"/>
                                                </HBox>
                                            </VBox>
                                            
                                            <!-- Column 2: Address, Organization Level -->
                                            <VBox class="activityColumn">
                                                <HBox class="activityFieldRow">
                                                    <Label text="Address:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>addressFull}" class="activityFieldValue" wrapping="true"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="Org Level:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>orgLevelId}" class="activityFieldValue"/>
                                                </HBox>
                                            </VBox>
                                            
                                            <!-- Column 3: Planned Start/End, Duration -->
                                            <VBox class="activityColumn">
                                                <HBox class="activityFieldRow">
                                                    <Label text="Planned Start:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>formattedStartDate}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="Planned End:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>formattedEndDate}" class="activityFieldValue"/>
                                                </HBox>
                                                <HBox class="activityFieldRow">
                                                    <Label text="Duration:" design="Bold" class="activityFieldLabel"/>
                                                    <Text text="{view>formattedDuration}" class="activityFieldValue"/>
                                                </HBox>
                                            </VBox>
                                        </HBox>
                                        
                                        <!-- T&M Summary Section -->
                                        <VBox class="tmSummarySection">
                                            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                                <core:Icon src="sap-icon://timesheet" class="sapUiTinyMarginEnd"/>
                                                <Label text="T&amp;M Reports:" design="Bold"/>
                                                <ObjectNumber number="{view>tmReportsCount}" unit="items" state="{= ${view>tmReportsCount} > 0 ? 'Success' : 'None'}" class="sapUiTinyMarginBegin"/>
                                            </HBox>
                                            <HBox visible="{view>tmReportsLoaded}" class="sapUiTinyMarginBottom">
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="Time Effort"/>
                                                    <ObjectNumber number="{view>tmTimeEffortCount}" state="Information"/>
                                                </VBox>
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="Material"/>
                                                    <ObjectNumber number="{view>tmMaterialCount}" state="Information"/>
                                                </VBox>
                                                <VBox class="sapUiSmallMarginEnd">
                                                    <Label text="Expense"/>
                                                    <ObjectNumber number="{view>tmExpenseCount}" state="Information"/>
                                                </VBox>
                                                <VBox>
                                                    <Label text="Mileage"/>
                                                    <ObjectNumber number="{view>tmMileageCount}" state="Information"/>
                                                </VBox>
                                            </HBox>
                                            
                                            <!-- Action Buttons -->
                                            <HBox class="activityActions">
                                                <Button
                                                    text="View T&amp;M"
                                                    icon="sap-icon://detail-view"
                                                    type="Emphasized"
                                                    press=".onViewTMReports"
                                                    class="tmActionButton"
                                                />
                                                <Button
                                                    text="Add T&amp;M"
                                                    icon="sap-icon://add"
                                                    type="Accept"
                                                    press=".onAddTMReport"
                                                    class="tmActionButton"
                                                />
                                            </HBox>
                                        </VBox>
                                    </content>
                                </Panel>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>
            </CustomListItem>
        </List>
    </VBox>
</core:FragmentDefinition>