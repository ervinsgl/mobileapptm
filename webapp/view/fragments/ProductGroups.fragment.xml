<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <VBox id="productGroupsMainContainer" class="sapUiResponsiveMargin">
        
        <VBox id="productGroupsContainer">
            <List
                id="productGroupsList"
                items="{view>/productGroups}"
                mode="None"
                showSeparators="None"
            >
                <CustomListItem type="Inactive">
                    
                    <Panel
                        headerText="Product: {view>productDescription}"
                        expandable="true"
                        expanded="{view>expanded}"
                        expand="onProductPanelExpand"
                        class="sapUiSmallMarginBottom productGroupPanel"
                        width="auto"
                    >
                        <headerToolbar>
                            <OverflowToolbar 
                                design="Solid"
                                class="productGroupHeader">
                                <Title 
                                    text="Product: {view>productDescription}" 
                                    level="H4" 
                                    titleStyle="H4"
                                    class="sapUiTinyMarginBegin productGroupHeaderTitle"
                                    wrapping="true"
                                />
                                <ToolbarSpacer />
                                <Label 
                                    text="SO Item: {view>soItemId}" 
                                    design="Bold"
                                    class="sapUiTinyMarginEnd productGroupHeaderLabel"
                                />
                            </OverflowToolbar>
                        </headerToolbar>
                        
                        <content>
                            <Table 
                                id="activitiesTable"
                                items="{view>activities}"
                                mode="MultiSelect"
                                selectionChange="onActivitySelectionChange"
                                class="sapUiSmallMarginTop activitiesTable"
                                alternateRowColors="true"
                                sticky="ColumnHeaders"
                            >
                                <headerToolbar>
                                    <OverflowToolbar class="activitiesTableToolbar">
                                        <Title 
                                            text="{= ${view>activities}.length + ' Activities'}" 
                                            level="H5"
                                        />
                                    </OverflowToolbar>
                                </headerToolbar>
                                
                                <columns>
                                    <Column width="12%" minScreenWidth="Tablet" demandPopin="true">
                                        <Text text="Activity Code" class="sapUiSmallMarginBegin"/>
                                    </Column>
                                    <Column width="28%" minScreenWidth="Desktop" demandPopin="true" popinDisplay="Inline">
                                        <Text text="Subject"/>
                                    </Column>
                                    <Column width="12%" minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
                                        <Text text="Status"/>
                                    </Column>
                                    <Column width="15%" minScreenWidth="Desktop" demandPopin="true">
                                        <Text text="Planned Start"/>
                                    </Column>
                                    <Column width="15%" minScreenWidth="Desktop" demandPopin="true">
                                        <Text text="Planned End"/>
                                    </Column>
                                    <Column width="10%" minScreenWidth="Tablet" demandPopin="true" hAlign="Center">
                                        <Text text="Duration"/>
                                    </Column>
                                    <Column width="8%" minScreenWidth="Desktop" demandPopin="true" hAlign="Center">
                                        <Text text="Details"/>
                                    </Column>
                                </columns>
                                
                                <items>
                                    <ColumnListItem 
                                        type="Active"
                                        press="onActivityPress"
                                    >
                                        <cells>
                                            <ObjectIdentifier 
                                                title="{view>code}"
                                                text="{view>fullActivity/externalId}"
                                            />
                                            
                                            <Text 
                                                text="{view>subject}" 
                                                class="sapUiSmallMarginBegin"
                                                wrapping="true"
                                            />
                                            
                                            <ObjectStatus 
                                                text="{view>status}" 
                                                state="{= ${view>status} === 'OPEN' ? 'Warning' : ${view>status} === 'COMPLETED' ? 'Success' : 'None'}"
                                            />
                                            
                                            <Text 
                                                text="{
                                                    path: 'view>plannedStartDate',
                                                    formatter: '.formatter.formatDateTime'
                                                }"
                                            />
                                            
                                            <Text 
                                                text="{
                                                    path: 'view>plannedEndDate',
                                                    formatter: '.formatter.formatDateTime'
                                                }"
                                            />
                                            
                                            <Text 
                                                text="{view>fullActivity/plannedDurationInMinutes} min"
                                            />
                                            
                                            <Link 
                                                text="View" 
                                                press="onViewActivityDetails"
                                            />
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </content>
                    </Panel>
                    
                </CustomListItem>
            </List>
        </VBox>
        
    </VBox>
</core:FragmentDefinition>