<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Panel
        id="activityDetailsPanel"
        headerText="Activity Details"
        expandable="true"
        expanded="true"
        class="sapUiResponsiveMargin"
        visible="{= !!${view>/selectedActivity/id} }"
    >
        <VBox id="activityDetailsBox" class="sapUiSmallMargin">
            <!-- Subject -->
            <Label id="activitySubjectLabel" text="Subject" design="Bold" />
            <Text 
                id="activitySubjectText"
                text="{view>/selectedActivity/subject}" 
            />
            
            <!-- ID -->
            <Label 
                id="activityIdLabel"
                text="ID" 
                design="Bold" 
                class="sapUiTinyMarginTop" 
            />
            <Text 
                id="activityIdText"
                text="{view>/selectedActivity/id}" 
            />
            
            <!-- Code -->
            <Label 
                id="activityCodeLabel"
                text="Code" 
                design="Bold" 
                class="sapUiTinyMarginTop" 
            />
            <Text 
                id="activityCodeText"
                text="{view>/selectedActivity/code}" 
            />
            
            <!-- Created By -->
            <Label 
                id="activityCreatePersonLabel"
                text="Created By" 
                design="Bold" 
                class="sapUiTinyMarginTop" 
            />
            <Text 
                id="activityCreatePersonText"
                text="{view>/selectedActivity/createPerson}" 
            />
            
            <!-- Type -->
            <Label 
                id="activityTypeLabel"
                text="Type" 
                design="Bold" 
                class="sapUiTinyMarginTop" 
            />
            <Text 
                id="activityTypeText"
                text="{view>/selectedActivity/type}" 
            />
            
            <!-- Status -->
            <Label 
                id="activityStatusLabel"
                text="Status" 
                design="Bold" 
                class="sapUiTinyMarginTop" 
            />
            <Text 
                id="activityStatusText"
                text="{view>/selectedActivity/status}" 
            />
            
            <!-- Start Date -->
            <Label 
                id="activityStartDateLabel"
                text="Start Date" 
                design="Bold" 
                class="sapUiTinyMarginTop" 
            />
            <Text 
                id="activityStartDateText"
                text="{
                    path: 'view>/selectedActivity/startDateTime',
                    formatter: '.formatter.formatDateTime'
                }" 
            />
            
            <!-- End Date -->
            <Label 
                id="activityEndDateLabel"
                text="End Date" 
                design="Bold" 
                class="sapUiTinyMarginTop" 
            />
            <Text 
                id="activityEndDateText"
                text="{
                    path: 'view>/selectedActivity/endDateTime',
                    formatter: '.formatter.formatDateTime'
                }" 
            />
        </VBox>
    </Panel>
</core:FragmentDefinition>