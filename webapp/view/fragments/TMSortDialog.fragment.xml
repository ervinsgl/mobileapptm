<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <!-- 
    ViewSettingsDialog for T&M Table Sort & Filter
    - Sort: Various fields depending on table type (populated dynamically)
    - Filter > Status: Static list of all possible approval statuses
    - Filter > Technician: Populated dynamically from current table data
    -->
    <ViewSettingsDialog
        id="tmSortDialog"
        confirm=".onTMSortDialogConfirm"
        cancel=".onTMSortDialogCancel"
        resetFilters=".onTMSortDialogReset"
        title="{i18n>sortFilterDialogTitle}">
        <filterItems>
            <ViewSettingsFilterItem key="status" text="{i18n>filterByStatus}" multiSelect="true">
                <items>
                    <ViewSettingsItem key="PENDING"       text="{i18n>filterStatusPending}"/>
                    <ViewSettingsItem key="REVIEW"        text="{i18n>filterStatusReview}"/>
                    <ViewSettingsItem key="APPROVED"      text="{i18n>filterStatusApproved}"/>
                    <ViewSettingsItem key="DECLINED"      text="{i18n>filterStatusDeclined}"/>
                    <ViewSettingsItem key="DECLINED_CLOSED" text="{i18n>filterStatusRejected}"/>
                    <ViewSettingsItem key="CANCELLED"     text="{i18n>filterStatusCancelled}"/>
                </items>
            </ViewSettingsFilterItem>
            <!-- Technician group is added/updated dynamically in onOpenSortDialog -->
        </filterItems>
    </ViewSettingsDialog>
    
</core:FragmentDefinition>