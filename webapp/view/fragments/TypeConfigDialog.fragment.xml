<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <!--
        TypeConfigDialog Fragment: Configure Expense and Mileage Service Product types.
        Model: typeConfig
    -->
    <Dialog
        id="typeConfigDialog"
        title="Configure Entry Types"
        contentWidth="500px"
        draggable="true"
        resizable="true"
    >
        <customHeader>
            <OverflowToolbar>
                <core:Icon src="sap-icon://action-settings"/>
                <ToolbarSpacer width="0.5rem"/>
                <Title text="Configure Entry Types" level="H4"/>
                <ToolbarSpacer/>
                <Button icon="sap-icon://reset" tooltip="Reset to Defaults" press=".onResetTypeConfig" type="Transparent"/>
            </OverflowToolbar>
        </customHeader>
        
        <content>
            <VBox class="sapUiSmallMargin">
                <VBox class="sapUiSmallMarginBottom">
                    <MessageStrip
                        text="Service Products assigned here determine which T&amp;M creation form is shown. IDs not listed are treated as Time &amp; Material."
                        type="Information"
                        showIcon="true"
                    />
                </VBox>
                
                <!-- Expense Types Section -->
                <Panel expandable="false" class="sapUiTinyMarginBottom">
                    <headerToolbar>
                        <OverflowToolbar design="Info">
                            <core:Icon src="sap-icon://money-bills" color="#E9730C"/>
                            <ToolbarSpacer width="0.5rem"/>
                            <Title text="Expense Types" level="H5"/>
                            <ToolbarSpacer/>
                            <ObjectNumber number="{= ${typeConfig>/expenseTypes}.length }" unit="IDs"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <Input
                                id="newExpenseTypeInput"
                                placeholder="Enter Service Product ID (e.g., Z40000001)"
                                width="100%"
                                submit=".onAddExpenseType"
                            />
                            <ToolbarSpacer width="0.5rem"/>
                            <Button icon="sap-icon://add" type="Emphasized" press=".onAddExpenseType" tooltip="Add"/>
                        </HBox>
                        <List
                            items="{typeConfig>/expenseTypes}"
                            noDataText="No expense types configured"
                            mode="None"
                        >
                            <CustomListItem>
                                <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
                                    <HBox alignItems="Center">
                                        <core:Icon src="sap-icon://money-bills" color="#E9730C"/>
                                        <ToolbarSpacer width="0.5rem"/>
                                        <Text text="{typeConfig>}"/>
                                    </HBox>
                                    <Button icon="sap-icon://delete" type="Transparent" press=".onRemoveExpenseType" tooltip="Remove"/>
                                </HBox>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>
                
                <!-- Mileage Types Section -->
                <Panel expandable="false">
                    <headerToolbar>
                        <OverflowToolbar design="Info">
                            <core:Icon src="sap-icon://car-rental" color="#6C32A9"/>
                            <ToolbarSpacer width="0.5rem"/>
                            <Title text="Mileage Types" level="H5"/>
                            <ToolbarSpacer/>
                            <ObjectNumber number="{= ${typeConfig>/mileageTypes}.length }" unit="IDs"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <Input
                                id="newMileageTypeInput"
                                placeholder="Enter Service Product ID (e.g., Z40000038)"
                                width="100%"
                                submit=".onAddMileageType"
                            />
                            <ToolbarSpacer width="0.5rem"/>
                            <Button icon="sap-icon://add" type="Emphasized" press=".onAddMileageType" tooltip="Add"/>
                        </HBox>
                        <List
                            items="{typeConfig>/mileageTypes}"
                            noDataText="No mileage types configured"
                            mode="None"
                        >
                            <CustomListItem>
                                <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
                                    <HBox alignItems="Center">
                                        <core:Icon src="sap-icon://car-rental" color="#6C32A9"/>
                                        <ToolbarSpacer width="0.5rem"/>
                                        <Text text="{typeConfig>}"/>
                                    </HBox>
                                    <Button icon="sap-icon://delete" type="Transparent" press=".onRemoveMileageType" tooltip="Remove"/>
                                </HBox>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>
            </VBox>
        </content>
        
        <beginButton>
            <Button text="Close" press=".onCloseTypeConfig"/>
        </beginButton>
    </Dialog>
</core:FragmentDefinition>