<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <!--
        TypeConfigDialog Fragment: Configure Expense and Mileage Service Product types.
        Model: typeConfig
    -->
    <Dialog
        id="typeConfigDialog"
        title="{i18n>typeConfigTitle}"
        contentWidth="500px"
        draggable="true"
        resizable="true"
    >
        <customHeader>
            <OverflowToolbar>
                <core:Icon src="sap-icon://action-settings"/>
                <ToolbarSpacer width="0.5rem"/>
                <Title text="{i18n>typeConfigTitle}" level="H4"/>
                <ToolbarSpacer/>
                <Button icon="sap-icon://reset" tooltip="{i18n>typeConfigResetTooltip}" press=".onResetTypeConfig" type="Transparent"/>
            </OverflowToolbar>
        </customHeader>
        
        <content>
            <VBox class="sapUiSmallMargin">
                <VBox class="sapUiSmallMarginBottom">
                    <MessageStrip
                        text="{i18n>typeConfigInfoMessage}"
                        type="Information"
                        showIcon="true"
                    />
                </VBox>
                
                <!-- Expense Types Section -->
                <Panel expandable="false" class="sapUiTinyMarginBottom">
                    <headerToolbar>
                        <OverflowToolbar design="Info">
                            <core:Icon src="sap-icon://money-bills" color="#E9730C"/>
                            <ToolbarSpacer width="0.5rem"/>
                            <Title text="{i18n>typeConfigExpenseTypes}" level="H5"/>
                            <ToolbarSpacer/>
                            <ObjectNumber number="{= ${typeConfig>/expenseTypes}.length }" unit="{i18n>typeConfigIdsUnit}"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <Input
                                id="newExpenseTypeInput"
                                placeholder="{i18n>typeConfigExpensePlaceholder}"
                                width="100%"
                                submit=".onAddExpenseType"
                            />
                            <ToolbarSpacer width="0.5rem"/>
                            <Button icon="sap-icon://add" type="Emphasized" press=".onAddExpenseType" tooltip="{i18n>typeConfigAddTooltip}"/>
                        </HBox>
                        <List
                            items="{typeConfig>/expenseTypes}"
                            noDataText="{i18n>typeConfigNoExpenseTypes}"
                            mode="None"
                        >
                            <CustomListItem>
                                <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
                                    <HBox alignItems="Center">
                                        <core:Icon src="sap-icon://money-bills" color="#E9730C"/>
                                        <ToolbarSpacer width="0.5rem"/>
                                        <Text text="{typeConfig>}"/>
                                    </HBox>
                                    <Button icon="sap-icon://delete" type="Transparent" press=".onRemoveExpenseType" tooltip="{i18n>typeConfigRemoveTooltip}"/>
                                </HBox>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>
                
                <!-- Mileage Types Section -->
                <Panel expandable="false">
                    <headerToolbar>
                        <OverflowToolbar design="Info">
                            <core:Icon src="sap-icon://car-rental" color="#6C32A9"/>
                            <ToolbarSpacer width="0.5rem"/>
                            <Title text="{i18n>typeConfigMileageTypes}" level="H5"/>
                            <ToolbarSpacer/>
                            <ObjectNumber number="{= ${typeConfig>/mileageTypes}.length }" unit="{i18n>typeConfigIdsUnit}"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                            <Input
                                id="newMileageTypeInput"
                                placeholder="{i18n>typeConfigMileagePlaceholder}"
                                width="100%"
                                submit=".onAddMileageType"
                            />
                            <ToolbarSpacer width="0.5rem"/>
                            <Button icon="sap-icon://add" type="Emphasized" press=".onAddMileageType" tooltip="{i18n>typeConfigAddTooltip}"/>
                        </HBox>
                        <List
                            items="{typeConfig>/mileageTypes}"
                            noDataText="{i18n>typeConfigNoMileageTypes}"
                            mode="None"
                        >
                            <CustomListItem>
                                <HBox alignItems="Center" justifyContent="SpaceBetween" width="100%">
                                    <HBox alignItems="Center">
                                        <core:Icon src="sap-icon://car-rental" color="#6C32A9"/>
                                        <ToolbarSpacer width="0.5rem"/>
                                        <Text text="{typeConfig>}"/>
                                    </HBox>
                                    <Button icon="sap-icon://delete" type="Transparent" press=".onRemoveMileageType" tooltip="{i18n>typeConfigRemoveTooltip}"/>
                                </HBox>
                            </CustomListItem>
                        </List>
                    </content>
                </Panel>
            </VBox>
        </content>
        
        <beginButton>
            <Button text="{i18n>typeConfigClose}" press=".onCloseTypeConfig"/>
        </beginButton>
    </Dialog>
</core:FragmentDefinition>