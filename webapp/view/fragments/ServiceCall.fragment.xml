<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Panel
        id="serviceCallPanel"
        headerText="Service Order"
        expandable="true"
        expanded="false"
        class="sapUiResponsiveMargin sapUiSmallMarginBottom serviceOrderPanel"
        width="auto"
    >
        <headerToolbar>
            <OverflowToolbar design="Info">
                <core:Icon src="sap-icon://sales-order" class="sapUiSmallMarginEnd"/>
                <Title 
                    text="Service Order" 
                    level="H4" 
                    titleStyle="H4"
                />
                <ToolbarSpacer />
                <Title text="ID: {view>/serviceCall/externalId}" level="H5"/>
            </OverflowToolbar>
        </headerToolbar>
        
        <content>
            <!-- Service Order Details - Compact 3-Column Layout -->
            <HBox class="serviceOrderContent">
                <!-- Column 1: ID, Subject -->
                <VBox class="serviceOrderColumn">
                    <HBox class="serviceOrderFieldRow">
                        <Label text="ID:" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{view>/serviceCall/id}" class="serviceOrderFieldValue"/>
                    </HBox>
                    <HBox class="serviceOrderFieldRow">
                        <Label text="Subject:" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{view>/serviceCall/subject}" class="serviceOrderFieldValue" wrapping="true"/>
                    </HBox>
                </VBox>
                
                <!-- Column 2: Business Partner, Responsible -->
                <VBox class="serviceOrderColumn">
                    <HBox class="serviceOrderFieldRow">
                        <Label text="Business Partner:" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{view>/serviceCall/businessPartnerExternalId}" class="serviceOrderFieldValue"/>
                    </HBox>
                    <HBox class="serviceOrderFieldRow">
                        <Label text="Responsible:" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{view>/serviceCall/responsibleExternalId}" class="serviceOrderFieldValue"/>
                    </HBox>
                </VBox>
                
                <!-- Column 3: Earliest Start, Due Date -->
                <VBox class="serviceOrderColumn">
                    <HBox class="serviceOrderFieldRow">
                        <Label text="Earliest Start:" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{path: 'view>/serviceCall/earliestStartDateTime', formatter: '.formatter.formatDateTime'}" class="serviceOrderFieldValue"/>
                    </HBox>
                    <HBox class="serviceOrderFieldRow">
                        <Label text="Due Date:" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{path: 'view>/serviceCall/dueDateTime', formatter: '.formatter.formatDateTime'}" class="serviceOrderFieldValue"/>
                    </HBox>
                </VBox>
            </HBox>
        </content>
    </Panel>
</core:FragmentDefinition>