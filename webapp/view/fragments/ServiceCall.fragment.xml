<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Panel
        id="serviceCallPanel"
        headerText="Service Order"
        expandable="true"
        expanded="false"
        class="sapUiResponsiveMargin sapUiSmallMarginBottom serviceOrderPanel"
        width="auto"
    >
        <headerToolbar>
            <OverflowToolbar design="Info">
                <core:Icon src="sap-icon://sales-order" class="sapUiSmallMarginEnd"/>
                <Title 
                    text="Service Order" 
                    level="H4" 
                    titleStyle="H4"
                />
            </OverflowToolbar>
        </headerToolbar>
        
        <l:Grid
            id="serviceCallGrid"
            defaultSpan="L6 M6 S12"
            class="sapUiSmallMargin"
        >
            <VBox>
                <Label text="ID" design="Bold" />
                <Text 
                    text="{view>/serviceCall/id}" 
                />
            </VBox>
            
            <VBox>
                <Label 
                    text="External ID" 
                    design="Bold"
                />
                <Text 
                    text="{view>/serviceCall/externalId}" 
                />
            </VBox>
            
            <VBox class="sapUiTinyMarginTop">
                <layoutData>
                    <l:GridData id="serviceCallSubjectGridData" span="L12 M12 S12" />
                </layoutData>
                <Label 
                    text="Subject" 
                    design="Bold"
                />
                <Text 
                    text="{view>/serviceCall/subject}" 
                />
            </VBox>
            
            <VBox class="sapUiTinyMarginTop">
                <Label 
                    text="Business Partner" 
                    design="Bold"
                />
                <Text 
                    text="{view>/serviceCall/businessPartnerExternalId}" 
                />
            </VBox>
            
            <VBox class="sapUiTinyMarginTop">
                <Label 
                    text="Responsible" 
                    design="Bold"
                />
                <Text 
                    text="{view>/serviceCall/responsibleExternalId}" 
                />
            </VBox>
            
            <VBox class="sapUiTinyMarginTop">
                <Label 
                    text="Earliest Start" 
                    design="Bold"
                />
                <Text 
                    text="{
                        path: 'view>/serviceCall/earliestStartDateTime',
                        formatter: '.formatter.formatDateTime'
                    }" 
                />
            </VBox>
            
            <VBox class="sapUiTinyMarginTop">
                <Label 
                    text="Due Date" 
                    design="Bold"
                />
                <Text 
                    text="{
                        path: 'view>/serviceCall/dueDateTime',
                        formatter: '.formatter.formatDateTime'
                    }" 
                />
            </VBox>
            
        </l:Grid>
    </Panel>
</core:FragmentDefinition>