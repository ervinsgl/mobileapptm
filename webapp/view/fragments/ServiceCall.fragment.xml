<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <!-- 
        ServiceCall Fragment: Displays service order header information.
        
        Shows: Subject, Business Partner, Responsible, Dates
        
        Model: view>/serviceCall
    -->
    <Panel
        id="serviceCallPanel"
        headerText="{i18n>serviceOrderTitle}"
        expandable="true"
        expanded="false"
        class="sapUiResponsiveMargin sapUiSmallMarginBottom serviceOrderPanel"
        width="auto"
    >
        <headerToolbar>
            <OverflowToolbar design="Info">
                <core:Icon src="sap-icon://sales-order" class="sapUiSmallMarginEnd"/>
                <Title text="{i18n>serviceOrderTitle}" level="H4" titleStyle="H4"/>
                <ToolbarSpacer/>
                <Title text="{i18n>serviceOrderId} {view>/serviceCall/externalId}" level="H5"/>
            </OverflowToolbar>
        </headerToolbar>
        
        <content>
            <!-- Service Order Details: 3-Column Layout -->
            <HBox class="serviceOrderContent">
            
                <!-- Col 1: Subject -->
                <VBox class="serviceOrderColumn">
                    <HBox class="serviceOrderFieldRow">
                        <Label text="{i18n>serviceOrderSubject}" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{view>/serviceCall/subject}" class="serviceOrderFieldValue" wrapping="true"/>
                    </HBox>
                </VBox>
                
                <!-- Col 2: Business Partner, Responsible -->
                <VBox class="serviceOrderColumn">
                    <HBox class="serviceOrderFieldRow">
                        <Label text="{i18n>serviceOrderBusinessPartner}" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{view>/serviceCall/businessPartnerDisplayText}" class="serviceOrderFieldValue"/>
                    </HBox>
                    <HBox class="serviceOrderFieldRow">
                        <Label text="{i18n>serviceOrderResponsible}" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{view>/serviceCall/responsibleDisplayText}" class="serviceOrderFieldValue"/>
                    </HBox>
                </VBox>
                
                <!-- Col 3: Dates -->
                <VBox class="serviceOrderColumn">
                    <HBox class="serviceOrderFieldRow">
                        <Label text="{i18n>serviceOrderEarliestStart}" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{path: 'view>/serviceCall/earliestStartDateTime', formatter: '.formatter.formatDateTime'}" class="serviceOrderFieldValue"/>
                    </HBox>
                    <HBox class="serviceOrderFieldRow">
                        <Label text="{i18n>serviceOrderDueDate}" design="Bold" class="serviceOrderFieldLabel"/>
                        <Text text="{path: 'view>/serviceCall/dueDateTime', formatter: '.formatter.formatDateTime'}" class="serviceOrderFieldValue"/>
                    </HBox>
                </VBox>
            </HBox>
        </content>
    </Panel>
</core:FragmentDefinition>