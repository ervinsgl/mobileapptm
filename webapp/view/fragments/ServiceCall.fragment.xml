<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Panel
        id="serviceCallPanel"
        headerText="Service Order"
        expandable="true"
        expanded="true"
        class="sapUiResponsiveMargin"
        width="auto"
    >
        <l:Grid
            id="serviceCallGrid"
            defaultSpan="L6 M6 S12"
            class="sapUiSmallMargin"
        >
            <!-- ID -->
            <VBox>
                <Label text="ID" design="Bold" />
                <Text 
                    text="{view>/serviceCall/id}" 
                />
            </VBox>
            
            <!-- External ID -->
            <VBox>
                <Label 
                    text="External ID" 
                    design="Bold"
                />
                <Text 
                    text="{view>/serviceCall/externalId}" 
                />
            </VBox>
            
            <!-- Subject (spans full width) -->
            <VBox class="sapUiTinyMarginTop">
                <layoutData>
                    <l:GridData id="serviceCallSubjectGridData" span="L12 M12 S12" />
                </layoutData>
                <Label 
                    text="Subject" 
                    design="Bold"
                />
                <Text 
                    text="{view>/serviceCall/subject}" 
                />
            </VBox>
            
            <!-- Business Partner External ID -->
            <VBox class="sapUiTinyMarginTop">
                <Label 
                    text="Business Partner" 
                    design="Bold"
                />
                <Text 
                    text="{view>/serviceCall/businessPartnerExternalId}" 
                />
            </VBox>
            
            <!-- Responsible External ID -->
            <VBox class="sapUiTinyMarginTop">
                <Label 
                    text="Responsible" 
                    design="Bold"
                />
                <Text 
                    text="{view>/serviceCall/responsibleExternalId}" 
                />
            </VBox>
            
            <!-- Earliest Start Date Time -->
            <VBox class="sapUiTinyMarginTop">
                <Label 
                    text="Earliest Start" 
                    design="Bold"
                />
                <Text 
                    text="{
                        path: 'view>/serviceCall/earliestStartDateTime',
                        formatter: '.formatter.formatDateTime'
                    }" 
                />
            </VBox>
            
            <!-- Due Date Time -->
            <VBox class="sapUiTinyMarginTop">
                <Label 
                    text="Due Date" 
                    design="Bold"
                />
                <Text 
                    text="{
                        path: 'view>/serviceCall/dueDateTime',
                        formatter: '.formatter.formatDateTime'
                    }" 
                />
            </VBox>
            
        </l:Grid>
    </Panel>
</core:FragmentDefinition>