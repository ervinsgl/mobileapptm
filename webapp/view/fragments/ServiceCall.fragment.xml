<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout"
>
    <Panel
        id="serviceCallPanel"
        headerText="Service Order"
        expandable="false"
        expanded="true"
        class="sapUiResponsiveMargin"
        width="auto"
    >
        <l:Grid
            id="serviceCallGrid"
            defaultSpan="L6 M6 S12"
            class="sapUiSmallMargin"
        >
            <!-- ID -->
            <VBox id="serviceCallIdBox">
                <Label id="serviceCallIdLabel" text="ID" design="Bold" />
                <Text 
                    id="serviceCallIdText"
                    text="{view>/serviceCall/id}" 
                />
            </VBox>
            
            <!-- External ID -->
            <VBox id="serviceCallExternalIdBox">
                <Label 
                    id="serviceCallExternalIdLabel"
                    text="External ID" 
                    design="Bold"
                />
                <Text 
                    id="serviceCallExternalIdText"
                    text="{view>/serviceCall/externalId}" 
                />
            </VBox>
            
            <!-- Subject (spans full width) -->
            <VBox id="serviceCallSubjectBox" class="sapUiTinyMarginTop">
                <layoutData>
                    <l:GridData id="serviceCallSubjectGridData" span="L12 M12 S12" />
                </layoutData>
                <Label 
                    id="serviceCallSubjectLabel"
                    text="Subject" 
                    design="Bold"
                />
                <Text 
                    id="serviceCallSubjectText"
                    text="{view>/serviceCall/subject}" 
                />
            </VBox>
            
            <!-- Business Partner External ID -->
            <VBox id="serviceCallBusinessPartnerBox" class="sapUiTinyMarginTop">
                <Label 
                    id="serviceCallBusinessPartnerLabel"
                    text="Business Partner" 
                    design="Bold"
                />
                <Text 
                    id="serviceCallBusinessPartnerText"
                    text="{view>/serviceCall/businessPartnerExternalId}" 
                />
            </VBox>
            
            <!-- Responsible External ID -->
            <VBox id="serviceCallResponsibleBox" class="sapUiTinyMarginTop">
                <Label 
                    id="serviceCallResponsibleLabel"
                    text="Responsible" 
                    design="Bold"
                />
                <Text 
                    id="serviceCallResponsibleText"
                    text="{view>/serviceCall/responsibleExternalId}" 
                />
            </VBox>
            
            <!-- Earliest Start Date Time -->
            <VBox id="serviceCallEarliestStartBox" class="sapUiTinyMarginTop">
                <Label 
                    id="serviceCallEarliestStartLabel"
                    text="Earliest Start" 
                    design="Bold"
                />
                <Text 
                    id="serviceCallEarliestStartText"
                    text="{
                        path: 'view>/serviceCall/earliestStartDateTime',
                        formatter: '.formatter.formatDateTime'
                    }" 
                />
            </VBox>
            
            <!-- Due Date Time -->
            <VBox id="serviceCallDueBox" class="sapUiTinyMarginTop">
                <Label 
                    id="serviceCallDueLabel"
                    text="Due Date" 
                    design="Bold"
                />
                <Text 
                    id="serviceCallDueText"
                    text="{
                        path: 'view>/serviceCall/dueDateTime',
                        formatter: '.formatter.formatDateTime'
                    }" 
                />
            </VBox>
            
        </l:Grid>
    </Panel>
</core:FragmentDefinition>