<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Panel
        id="activitiesPanel"
        headerText="Activities"
        expandable="false"
        expanded="true"
        class="sapUiResponsiveMargin"
    >
        <VBox id="activitiesInfoBox" class="sapUiSmallMargin">
            <HBox 
                id="activitySelectionBox"
                justifyContent="SpaceBetween" 
                alignItems="Center"
            >
                <VBox 
                    id="selectedActivityBox"
                    visible="{= ${view>/selectedActivity/code} !== undefined }"
                >
                    <Text 
                        id="selectedActivityText"
                        text="{view>/selectedActivity/code} - {view>/selectedActivity/subject}" 
                    />
                </VBox>
                <Button
                    id="selectActivityButton"
                    text="Select Activity"
                    type="Emphasized"
                    press=".onSelectActivity"
                    visible="{= !${view>/selectedActivity/id} }"
                />
                <Button
                    id="changeActivityButton"
                    icon="sap-icon://edit"
                    type="Transparent"
                    press=".onSelectActivity"
                    visible="{= !!${view>/selectedActivity/id} }"
                />
            </HBox>
        </VBox>
    </Panel>
</core:FragmentDefinition>