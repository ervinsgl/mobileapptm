<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <Panel
        id="activitiesListPanel"
        headerText="Activities - {view>/selectedOrganizationLevel/text} ({= ${view>/serviceCallActivities}.length })"
        expandable="false"
        expanded="true"
        class="sapUiResponsiveMargin"
        visible="{= ${view>/serviceCallActivities}.length > 0 }"
    >
        <VBox id="activitiesListBox" class="sapUiSmallMargin">
            <Label 
                id="activitiesListLabel" 
                text="Select Activity:" 
                design="Bold" 
            />
            
            <ComboBox
                id="activitiesComboBox"
                selectionChange=".onActivitySelectionChange"
                placeholder="Choose activity..."
                width="100%"
                class="sapUiTinyMarginTop"
            >
            </ComboBox>
            
            <MessageStrip
                id="activitiesMessageStrip"
                text="Please select an activity to view details"
                type="Information"
                class="sapUiTinyMarginTop"
                visible="{= !${view>/activitySelected} }"
            />
        </VBox>
    </Panel>
</core:FragmentDefinition>