<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">
    <!-- 
        TMCreateDialog Fragment: Dialog for creating T&M (Time & Materials) entries.
        
        Entry Types Supported:
        - Time Effort: Duration-based time entries with task selection
        - Material: Item-based entries with quantity
        - Expense: Cost entries with external/internal amounts
        - Mileage: Distance-based travel entries
        - Time & Material: Combined entry (1 Material + up to 3 Time Efforts)
        
        Model: createTM
    -->
    <Dialog 
        title="Create T&amp;M Report - {createTM>/activityCode}"
        contentWidth="90%"
        contentHeight="80%"
        draggable="true"
        resizable="true"
    >
        <customHeader>
            <OverflowToolbar>
                <Title text="Create T&amp;M Report - {createTM>/activityCode}" level="H4"/>
                <ToolbarSpacer/>
            </OverflowToolbar>
        </customHeader>
        <subHeader>
            <Toolbar design="Info">
                <Title text="{createTM>/activitySubject}" level="H6" wrapping="true"/>
                <ToolbarSpacer/>
                <Label text="ID: {createTM>/activityExternalId}"/>
            </Toolbar>
        </subHeader>
        <content>
            <VBox class="sapUiMediumMargin">
                
                <!-- ========== ACTIVITY DETAILS SECTION ========== -->
                <!-- Activity Details Grid -->
                <VBox class="activityQuickInfo sapUiSmallMarginBottom">
                    <l:Grid defaultSpan="XL4 L4 M12 S12" hSpacing="2" vSpacing="1" containerQuery="true">
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Service Product:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/serviceProduct}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Planned Start:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedStartDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Quantity:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/quantity}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Duration:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedDuration}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Planned End:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedEndDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Unit of Measure:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/quantityUoM}" class="infoValue detailFieldValue"/>
                        </VBox>
                    </l:Grid>
                </VBox>
                
                <!-- ========== ENTRY TYPE BUTTONS ========== -->
                <!-- 
                    Button visibility based on Activity Service Product:
                    - Mileage Report: Z40000038, Z40000008
                    - Expense Report: Z40000001, Z40000007, Z50000000
                    - Time & Material Report: All other Service Products
                -->
                <HBox class="sapUiSmallMarginBottom" width="100%" wrap="Wrap">
                    <!-- Expense Report: Only for Service Products Z40000001, Z40000007, Z50000000 -->
                    <Button 
                        text="Expense Report" 
                        icon="sap-icon://money-bills" 
                        press=".onAddExpenseEntry" 
                        class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                        type="Emphasized"
                        visible="{= ${createTM>/serviceProductExternalId} === 'Z40000001' || ${createTM>/serviceProductExternalId} === 'Z40000007' || ${createTM>/serviceProductExternalId} === 'Z50000000' }"/>
                    
                    <!-- Mileage Report: Only for Service Products Z40000038, Z40000008 -->
                    <Button 
                        text="Mileage Report" 
                        icon="sap-icon://car-rental" 
                        press=".onAddMileageEntry" 
                        class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                        type="Emphasized"
                        visible="{= ${createTM>/serviceProductExternalId} === 'Z40000038' || ${createTM>/serviceProductExternalId} === 'Z40000008' }"/>
                    
                    <!-- Time & Material Report: All other Service Products -->
                    <Button 
                        text="Time &amp; Material Report" 
                        icon="sap-icon://checklist-item-2" 
                        press=".onAddTimeAndMaterialEntry" 
                        class="sapUiTinyMarginBottom" 
                        type="Emphasized"
                        visible="{= ${createTM>/serviceProductExternalId} !== 'Z40000001' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z40000007' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z50000000' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z40000038' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z40000008' }"/>
                </HBox>
                
                <!-- ========== ENTRY PANELS LIST ========== -->
                <List items="{path: 'createTM>/entries', templateShareable: false}" mode="None" showSeparators="None">
                    <CustomListItem type="Inactive">
                        <Panel headerText="{createTM>type}" expandable="true" expanded="{createTM>expanded}" class="tmEntryPanel">
                            
                            <!-- Panel Header Toolbar -->
                            <headerToolbar>
                                <OverflowToolbar design="Info">
                                    <core:Icon src="{createTM>icon}" class="sapUiSmallMarginEnd"/>
                                    <Title text="{createTM>type}" level="H5"/>
                                    <ToolbarSpacer/>
                                    <Button text="Close Entry" icon="sap-icon://decline" type="Reject" press=".onCloseEntry" class="sapUiTinyMarginEnd"/>
                                    <Button text="{createTM>saveButtonText}" icon="{createTM>saveButtonIcon}" type="{createTM>saveButtonType}" press=".onSaveEntry" enabled="{createTM>saveButtonEnabled}"/>
                                </OverflowToolbar>
                            </headerToolbar>
                            
                            <content>
                                <!-- ===== TIME EFFORT LAYOUT (2-Column) ===== -->
                                <HBox class="tmEntryContent" visible="{= ${createTM>type} === 'Time Effort'}" width="100%">
                                    
                                    <!-- Col 1: Task, Duration -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Select selectedKey="{createTM>taskCode}" items="{path: 'createTM>/taskSuggestions', templateShareable: false}" change=".onTaskSelect" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <StepInput value="{createTM>duration}" min="0" step="5" description="minutes" class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: Technician, Remarks -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>technicianId}" items="{path: 'createTM>/activityTechnicians', templateShareable: false}" change=".onTechnicianSelect" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== MATERIAL LAYOUT (2-Column) ===== -->
                                <HBox class="tmEntryContent" visible="{= ${createTM>type} === 'Material'}" width="100%">
                                    
                                    <!-- Col 1: Technician, Item -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>technicianId}" items="{path: 'createTM>/activityTechnicians', templateShareable: false}" change=".onTechnicianSelect" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Item:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>itemDisplay}" editable="false" class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: Quantity, Remarks -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Quantity:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>quantity}" min="0" step="1" displayValuePrecision="2" description="Pcs." class="tmFieldInputNarrow" valueState="{= parseFloat(${createTM>quantity}) > parseFloat(${createTM>/quantity}) ? 'Warning' : 'None'}" valueStateText="Quantity exceeds Activity quantity"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== EXPENSE LAYOUT (2-Column) ===== -->
                                <HBox class="tmEntryContent" visible="{= ${createTM>type} === 'Expense' || ${createTM>type} === 'Expense Report'}" width="100%">
                                    
                                    <!-- Col 1: Type, Technician -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Type:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>expenseTypeDisplay}" editable="false" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>technicianId}" items="{path: 'createTM>/activityTechnicians', templateShareable: false}" change=".onTechnicianSelect" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                            </Select>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: External, Internal, Remarks -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="External:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>externalAmountValue}" min="0" step="1" description="EUR" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Internal:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>internalAmountValue}" min="0" step="1" description="EUR" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== MILEAGE LAYOUT (2-Column) ===== -->
                                <HBox class="tmEntryContent" visible="{= ${createTM>type} === 'Mileage' || ${createTM>type} === 'Mileage Report'}" width="100%">
                                    
                                    <!-- Col 1: Type, Technician -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Type:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>itemDisplay}" editable="false" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>technicianId}" items="{path: 'createTM>/activityTechnicians', templateShareable: false}" change=".onTechnicianSelect" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                            </Select>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: Distance, Duration, Remarks -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Distance:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>distance}" min="0" step="1" description="KM" class="tmFieldInputNarrow" valueState="{= parseFloat(${createTM>distance}) > parseFloat(${createTM>/quantity}) ? 'Warning' : 'None'}" valueStateText="Distance exceeds Activity quantity"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>travelDuration}" min="0" step="5" description="min" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== TIME & MATERIAL LAYOUT ===== -->
                                <VBox visible="{= ${createTM>type} === 'Time &amp; Material'}" width="100%" class="sapUiSmallMarginTop">
                                    
                                    <!-- Material Section (2-column) -->
                                    <Title text="Material" level="H6" class="tmColumnHeader sapUiTinyMarginBottom"/>
                                    <HBox width="100%" class="tmEntryContent sapUiSmallMarginBottom">
                                        <!-- Col 1: Technician, Item -->
                                        <VBox class="tmColumn">
                                            <HBox class="tmFieldRow" width="100%">
                                                <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                                <Select selectedKey="{createTM>technicianId}" items="{path: 'createTM>/activityTechnicians', templateShareable: false}" change=".onTechnicianSelect" forceSelection="false" class="tmFieldSelectNarrow">
                                                    <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                                </Select>
                                            </HBox>
                                            <HBox class="tmFieldRow" width="100%">
                                                <Label text="Item:" design="Bold" class="tmFieldLabel"/>
                                                <Input value="{createTM>itemDisplay}" editable="false" class="tmFieldInputNarrow"/>
                                            </HBox>
                                        </VBox>
                                        <!-- Col 2: Quantity, Remarks -->
                                        <VBox class="tmColumn">
                                            <HBox class="tmFieldRow" width="100%">
                                                <Label text="Quantity:" design="Bold" class="tmFieldLabel"/>
                                                <StepInput value="{createTM>quantity}" min="0" step="1" displayValuePrecision="2" description="Pcs." class="tmFieldInputNarrow" valueState="{= parseFloat(${createTM>quantity}) > parseFloat(${createTM>/quantity}) ? 'Warning' : 'None'}" valueStateText="Quantity exceeds Activity quantity"/>
                                            </HBox>
                                            <HBox class="tmFieldRow" width="100%">
                                                <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                                <TextArea value="{createTM>remarksMaterial}" rows="2" placeholder="Remarks..." class="tmFieldInputNarrow"/>
                                            </HBox>
                                        </VBox>
                                    </HBox>
                                    
                                    <!-- Time Entries - 3 Panels (responsive: 3→2→1 columns) -->
                                    <HBox width="100%" class="tmTimeColumns">
                                        
                                        <!-- Panel: Time - Arbeitszeit (FIRST) -->
                                        <VBox class="tmColumn tmTimePanel">
                                            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                                <Title text="Time - Arbeitszeit" level="H6" class="tmColumnHeader"/>
                                                <ToolbarSpacer/>
                                                <Button icon="sap-icon://add" type="Transparent" tooltip="Add Arbeitszeit" press=".onAddTimeEffortAZ"/>
                                            </HBox>
                                            <List items="{path: 'createTM>timeEffortsAZ', templateShareable: false}" noDataText="Tap + to add" showSeparators="None" class="tmTimeEntryList">
                                                <CustomListItem class="tmTimeEntryItem">
                                                    <HBox class="tmTimeEntryContent" width="100%">
                                                        <VBox class="sapUiTinyMarginEnd" width="100%">
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Technician:" design="Bold" class="tmFieldLabelNarrow"/>
                                                                <Input 
                                                                    value="{createTM>technicianDisplay}" 
                                                                    showSuggestion="true" 
                                                                    suggestionItems="{path: 'createTM>technicianSuggestions', templateShareable: false}"
                                                                    liveChange=".onTimeEntryTechnicianLiveChange"
                                                                    suggestionItemSelected=".onTimeEntryTechnicianSuggestionSelect"
                                                                    placeholder="Search technician..."
                                                                    class="tmTimeEntrySelect"
                                                                    maxSuggestionWidth="400px"
                                                                    startSuggestion="2"
                                                                    showTableSuggestionValueHelp="false">
                                                                    <suggestionItems>
                                                                        <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                                                    </suggestionItems>
                                                                </Input>
                                                            </HBox>
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Task:" design="Bold" class="tmFieldLabelNarrow tmFieldLabelRequired"/>
                                                                <Select selectedKey="{createTM>taskCode}" items="{path: 'createTM>/taskSuggestionsAZ', templateShareable: false}" forceSelection="false" class="tmTimeEntrySelect" valueState="{= ${createTM>taskCode} ? 'None' : 'Error'}" valueStateText="Task is required">
                                                                    <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                                                </Select>
                                                            </HBox>
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Duration:" design="Bold" class="tmFieldLabelNarrow"/>
                                                                <StepInput value="{createTM>duration}" min="0" step="5" description="min" class="tmTimeEntryInput"/>
                                                            </HBox>
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Remarks:" design="Bold" class="tmFieldLabelNarrow"/>
                                                                <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmTimeEntryInput"/>
                                                            </HBox>
                                                        </VBox>
                                                        <Button icon="sap-icon://decline" type="Transparent" tooltip="Remove" press=".onRemoveTimeEffortAZ"/>
                                                    </HBox>
                                                </CustomListItem>
                                            </List>
                                        </VBox>
                                        
                                        <!-- Panel: Time - Fahrzeit -->
                                        <VBox class="tmColumn tmTimePanel">
                                            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                                <Title text="Time - Fahrzeit" level="H6" class="tmColumnHeader"/>
                                                <ToolbarSpacer/>
                                                <Button icon="sap-icon://add" type="Transparent" tooltip="Add Fahrzeit" press=".onAddTimeEffortFZ"/>
                                            </HBox>
                                            <List items="{path: 'createTM>timeEffortsFZ', templateShareable: false}" noDataText="Tap + to add" showSeparators="None" class="tmTimeEntryList">
                                                <CustomListItem class="tmTimeEntryItem">
                                                    <HBox class="tmTimeEntryContent" width="100%">
                                                        <VBox class="sapUiTinyMarginEnd" width="100%">
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Technician:" design="Bold" class="tmFieldLabelNarrow"/>
                                                                <Input 
                                                                    value="{createTM>technicianDisplay}" 
                                                                    showSuggestion="true" 
                                                                    suggestionItems="{path: 'createTM>technicianSuggestions', templateShareable: false}"
                                                                    liveChange=".onTimeEntryTechnicianLiveChange"
                                                                    suggestionItemSelected=".onTimeEntryTechnicianSuggestionSelect"
                                                                    placeholder="Search technician..."
                                                                    class="tmTimeEntrySelect"
                                                                    maxSuggestionWidth="400px"
                                                                    startSuggestion="2"
                                                                    showTableSuggestionValueHelp="false">
                                                                    <suggestionItems>
                                                                        <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                                                    </suggestionItems>
                                                                </Input>
                                                            </HBox>
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Task:" design="Bold" class="tmFieldLabelNarrow tmFieldLabelRequired"/>
                                                                <Select selectedKey="{createTM>taskCode}" items="{path: 'createTM>/taskSuggestionsFZ', templateShareable: false}" forceSelection="false" class="tmTimeEntrySelect" valueState="{= ${createTM>taskCode} ? 'None' : 'Error'}" valueStateText="Task is required">
                                                                    <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                                                </Select>
                                                            </HBox>
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Duration:" design="Bold" class="tmFieldLabelNarrow"/>
                                                                <StepInput value="{createTM>duration}" min="0" step="5" description="min" class="tmTimeEntryInput"/>
                                                            </HBox>
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Remarks:" design="Bold" class="tmFieldLabelNarrow"/>
                                                                <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmTimeEntryInput"/>
                                                            </HBox>
                                                        </VBox>
                                                        <Button icon="sap-icon://decline" type="Transparent" tooltip="Remove" press=".onRemoveTimeEffortFZ"/>
                                                    </HBox>
                                                </CustomListItem>
                                            </List>
                                        </VBox>
                                        
                                        <!-- Panel: Time - Wartezeit -->
                                        <VBox class="tmColumn tmTimePanel">
                                            <HBox alignItems="Center" class="sapUiTinyMarginBottom">
                                                <Title text="Time - Wartezeit" level="H6" class="tmColumnHeader"/>
                                                <ToolbarSpacer/>
                                                <Button icon="sap-icon://add" type="Transparent" tooltip="Add Wartezeit" press=".onAddTimeEffortWZ"/>
                                            </HBox>
                                            <List items="{path: 'createTM>timeEffortsWZ', templateShareable: false}" noDataText="Tap + to add" showSeparators="None" class="tmTimeEntryList">
                                                <CustomListItem class="tmTimeEntryItem">
                                                    <HBox class="tmTimeEntryContent" width="100%">
                                                        <VBox class="sapUiTinyMarginEnd" width="100%">
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Technician:" design="Bold" class="tmFieldLabelNarrow"/>
                                                                <Input 
                                                                    value="{createTM>technicianDisplay}" 
                                                                    showSuggestion="true" 
                                                                    suggestionItems="{path: 'createTM>technicianSuggestions', templateShareable: false}"
                                                                    liveChange=".onTimeEntryTechnicianLiveChange"
                                                                    suggestionItemSelected=".onTimeEntryTechnicianSuggestionSelect"
                                                                    placeholder="Search technician..."
                                                                    class="tmTimeEntrySelect"
                                                                    maxSuggestionWidth="400px"
                                                                    startSuggestion="2"
                                                                    showTableSuggestionValueHelp="false">
                                                                    <suggestionItems>
                                                                        <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                                                    </suggestionItems>
                                                                </Input>
                                                            </HBox>
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Task:" design="Bold" class="tmFieldLabelNarrow tmFieldLabelRequired"/>
                                                                <Select selectedKey="{createTM>taskCode}" items="{path: 'createTM>/taskSuggestionsWZ', templateShareable: false}" forceSelection="false" class="tmTimeEntrySelect" valueState="{= ${createTM>taskCode} ? 'None' : 'Error'}" valueStateText="Task is required">
                                                                    <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                                                </Select>
                                                            </HBox>
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Duration:" design="Bold" class="tmFieldLabelNarrow"/>
                                                                <StepInput value="{createTM>duration}" min="0" step="5" description="min" class="tmTimeEntryInput"/>
                                                            </HBox>
                                                            <HBox class="tmFieldRow" width="100%">
                                                                <Label text="Remarks:" design="Bold" class="tmFieldLabelNarrow"/>
                                                                <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmTimeEntryInput"/>
                                                            </HBox>
                                                        </VBox>
                                                        <Button icon="sap-icon://decline" type="Transparent" tooltip="Remove" press=".onRemoveTimeEffortWZ"/>
                                                    </HBox>
                                                </CustomListItem>
                                            </List>
                                        </VBox>
                                        
                                    </HBox>
                                </VBox>
                            </content>
                        </Panel>
                    </CustomListItem>
                </List>
                
            </VBox>
        </content>
        
        <!-- ========== DIALOG BUTTONS ========== -->
        <buttons>
            <Button text="Close" press=".onCancelCreateTM"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>