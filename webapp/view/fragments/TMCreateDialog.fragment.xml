<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">
    <!-- 
        TMCreateDialog Fragment: Dialog for creating T&M (Time & Materials) entries.
        
        Entry Types Supported:
        - Time Effort: Duration-based time entries with task selection
        - Material: Item-based entries with quantity
        - Expense: Cost entries with external/internal amounts
        - Mileage: Distance-based travel entries
        - Time & Material: Combined entry (1 Material + up to 3 Time Efforts)
        
        Model: createTM
    -->
    <Dialog 
        title="Create T&amp;M Report - {createTM>/activityCode}"
        contentWidth="90%"
        contentHeight="80%"
        draggable="true"
        resizable="true"
    >
        <customHeader>
            <OverflowToolbar>
                <Title text="Create T&amp;M Report - {createTM>/activityCode}" level="H4"/>
                <ToolbarSpacer/>
            </OverflowToolbar>
        </customHeader>
        <subHeader>
            <Toolbar design="Info">
                <Title text="{createTM>/activitySubject}" level="H6" wrapping="true"/>
                <ToolbarSpacer/>
                <Label text="ID: {createTM>/activityExternalId}"/>
            </Toolbar>
        </subHeader>
        <content>
            <VBox class="sapUiMediumMargin">
                
                <!-- ========== ACTIVITY DETAILS SECTION ========== -->
                <!-- Activity Details Grid -->
                <VBox class="activityQuickInfo sapUiSmallMarginBottom">
                    <l:Grid defaultSpan="XL4 L4 M12 S12" hSpacing="2" vSpacing="1" containerQuery="true">
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Service Product:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/serviceProduct}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Planned Start:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedStartDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Quantity:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/quantity}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Duration:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedDuration}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Planned End:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedEndDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M12 S12"/></layoutData>
                            <Label text="Unit of Measure:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/quantityUoM}" class="infoValue detailFieldValue"/>
                        </VBox>
                    </l:Grid>
                </VBox>
                
                <!-- ========== ENTRY TYPE BUTTONS ========== -->
                <HBox class="sapUiSmallMarginBottom" width="100%" wrap="Wrap">
                    <Button text="Time Effort" icon="sap-icon://time-entry-request" press=".onAddTimeEffortEntry" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                    <Button text="Material" icon="sap-icon://product" press=".onAddMaterialEntry" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                    <Button text="Expense" icon="sap-icon://money-bills" press=".onAddExpenseEntry" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                    <Button text="Mileage" icon="sap-icon://car-rental" press=".onAddMileageEntry" class="sapUiTinyMarginEnd sapUiTinyMarginBottom"/>
                    <Button text="Time &amp; Material Report" icon="sap-icon://checklist-item-2" press=".onAddTimeAndMaterialEntry" class="sapUiTinyMarginBottom" type="Emphasized"/>
                </HBox>
                
                <!-- ========== ENTRY PANELS LIST ========== -->
                <List items="{path: 'createTM>/entries', templateShareable: false}" mode="None" showSeparators="None">
                    <CustomListItem type="Inactive">
                        <Panel headerText="{createTM>type}" expandable="true" expanded="{createTM>expanded}" class="tmEntryPanel">
                            
                            <!-- Panel Header Toolbar -->
                            <headerToolbar>
                                <OverflowToolbar design="Info">
                                    <core:Icon src="{createTM>icon}" class="sapUiSmallMarginEnd"/>
                                    <Title text="{createTM>type}" level="H5"/>
                                    <ToolbarSpacer/>
                                    <Button text="Close Entry" icon="sap-icon://decline" type="Reject" press=".onCloseEntry" class="sapUiTinyMarginEnd"/>
                                    <Button text="{createTM>saveButtonText}" icon="{createTM>saveButtonIcon}" type="{createTM>saveButtonType}" press=".onSaveEntry" enabled="{createTM>saveButtonEnabled}"/>
                                </OverflowToolbar>
                            </headerToolbar>
                            
                            <content>
                                <!-- ===== TIME EFFORT LAYOUT (3-Column) ===== -->
                                <HBox class="tmEntryContent tmEntryContent3Col" visible="{= ${createTM>type} === 'Time Effort'}" width="100%">
                                    
                                    <!-- Col 1: Task, Technician -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Select selectedKey="{createTM>taskCode}" items="{path: 'createTM>/taskSuggestions', templateShareable: false}" change=".onTaskSelect" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>technicianDisplay}" showSuggestion="true" suggestionItems="{path: 'createTM>/technicianSuggestions', templateShareable: false}" liveChange=".onTechnicianLiveChange" suggestionItemSelected=".onTechnicianSuggestionSelect" placeholder="Search..." class="tmFieldInput tmFieldInputNarrow">
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                    
                                    <!-- Col 2: Duration, Start, End -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <StepInput value="{createTM>duration}" min="0" step="5" description="minutes" change=".onDurationChange" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <DateTimePicker value="{createTM>startDateTime}" valueFormat="yyyy-MM-dd'T'HH:mm:ss'Z'" displayFormat="dd.MM.yyyy HH:mm" change=".onStartDateTimeChange" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <DateTimePicker value="{createTM>endDateTime}" valueFormat="yyyy-MM-dd'T'HH:mm:ss'Z'" displayFormat="dd.MM.yyyy HH:mm" class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 3: Charge, Remarks -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Charge:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>chargeOption}" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="" text=""/>
                                                <core:Item key="CHARGEABLE" text="Chargeable"/>
                                                <core:Item key="NONCHARGEABLE" text="Non-Chargeable"/>
                                                <core:Item key="UNKNOWN" text="Unknown"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== MATERIAL LAYOUT (3-Column) ===== -->
                                <HBox class="tmEntryContent tmEntryContent3Col" visible="{= ${createTM>type} === 'Material'}" width="100%">
                                    
                                    <!-- Col 1: Item, Technician -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Item:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Input value="{createTM>itemDisplay}" showSuggestion="true" suggestionItems="{path: 'createTM>/itemSuggestions', templateShareable: false}" liveChange=".onItemLiveChange" suggestionItemSelected=".onItemSuggestionSelect" placeholder="Search item..." class="tmFieldInput tmFieldInputNarrow">
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>technicianDisplay}" showSuggestion="true" suggestionItems="{path: 'createTM>/technicianSuggestions', templateShareable: false}" liveChange=".onTechnicianLiveChange" suggestionItemSelected=".onTechnicianSuggestionSelect" placeholder="Search..." class="tmFieldInput tmFieldInputNarrow">
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                    
                                    <!-- Col 2: Date, Quantity -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <DatePicker value="{createTM>date}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Quantity:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <StepInput value="{createTM>quantity}" min="0" step="1" displayValuePrecision="2" valueState="{= ${createTM>quantity} > ${createTM>/maxQuantity} ? 'Warning' : 'None'}" valueStateText="{= ${createTM>quantity} > ${createTM>/maxQuantity} ? 'Exceeds activity quantity (' + ${createTM>/maxQuantity} + ')' : ''}" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                    
                                    <!-- Col 3: Charge, Remarks -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Charge:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>chargeOption}" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="" text=""/>
                                                <core:Item key="CHARGEABLE" text="Chargeable"/>
                                                <core:Item key="NONCHARGEABLE" text="Non-Chargeable"/>
                                                <core:Item key="UNKNOWN" text="Unknown"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== EXPENSE LAYOUT (3-Column) ===== -->
                                <HBox class="tmEntryContent tmEntryContent3Col" visible="{= ${createTM>type} === 'Expense'}" width="100%">
                                    
                                    <!-- Col 1: Type, Technician, Date -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Type:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Select selectedKey="{createTM>expenseTypeId}" items="{path: 'createTM>/expenseTypeSuggestions', templateShareable: false}" change=".onExpenseTypeChange" class="tmFieldSelectNarrow">
                                                <core:Item key="{createTM>key}" text="{createTM>text}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>technicianDisplay}" showSuggestion="true" suggestionItems="{path: 'createTM>/technicianSuggestions', templateShareable: false}" liveChange=".onTechnicianLiveChange" suggestionItemSelected=".onTechnicianSuggestionSelect" placeholder="Search..." class="tmFieldInput tmFieldInputNarrow">
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <DatePicker value="{createTM>date}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: External Amount, Internal Amount -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="External:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>externalAmountValue}" min="0" step="1" description="EUR" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Internal:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>internalAmountValue}" min="0" step="1" description="EUR" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                    
                                    <!-- Col 3: Charge, Remarks -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Charge:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>chargeOption}" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="" text=""/>
                                                <core:Item key="CHARGEABLE" text="Chargeable"/>
                                                <core:Item key="NONCHARGEABLE" text="Non-Chargeable"/>
                                                <core:Item key="UNKNOWN" text="Unknown"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== MILEAGE LAYOUT (3-Column) ===== -->
                                <HBox class="tmEntryContent tmEntryContent3Col" visible="{= ${createTM>type} === 'Mileage'}" width="100%">
                                    
                                    <!-- Col 1: Source, Destination, Technician, Distance -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Source:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>source}" placeholder="Start location..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Destination:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>destination}" placeholder="End location..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>technicianDisplay}" showSuggestion="true" suggestionItems="{path: 'createTM>/technicianSuggestions', templateShareable: false}" liveChange=".onTechnicianLiveChange" suggestionItemSelected=".onTechnicianSuggestionSelect" placeholder="Search..." class="tmFieldInput tmFieldInputNarrow">
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Distance:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <StepInput value="{createTM>distance}" min="0" step="1" description="KM" class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: Duration, Travel Start, Travel End -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>travelDuration}" min="0" step="5" description="minutes" change=".onTravelDurationChange" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <DateTimePicker value="{createTM>travelStartDateTime}" valueFormat="yyyy-MM-dd'T'HH:mm:ss'Z'" displayFormat="dd.MM.yyyy HH:mm" change=".onTravelStartDateTimeChange" class="tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <DateTimePicker value="{createTM>travelEndDateTime}" valueFormat="yyyy-MM-dd'T'HH:mm:ss'Z'" displayFormat="dd.MM.yyyy HH:mm" class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 3: Driver, Private Car, Charge, Remarks -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Driver:" design="Bold" class="tmFieldLabel"/>
                                            <CheckBox selected="{createTM>driver}" text="I am the driver"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Private Car:" design="Bold" class="tmFieldLabel"/>
                                            <CheckBox selected="{createTM>privateCar}" text="Private car used"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Charge:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>chargeOption}" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="" text=""/>
                                                <core:Item key="CHARGEABLE" text="Chargeable"/>
                                                <core:Item key="NONCHARGEABLE" text="Non-Chargeable"/>
                                                <core:Item key="UNKNOWN" text="Unknown"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{createTM>remarks}" rows="2" placeholder="Remarks..." class="tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- ===== TIME & MATERIAL LAYOUT (3-Column) ===== -->
                                <HBox class="tmEntryContent tmEntryContent3Col" visible="{= ${createTM>type} === 'Time &amp; Material'}" width="100%">
                                    
                                    <!-- Col 1: Material + Options -->
                                    <VBox class="tmColumn">
                                        <Title text="Material" level="H6" class="tmColumnHeader sapUiTinyMarginBottom"/>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>technicianDisplay}" showSuggestion="true" suggestionItems="{path: 'createTM>/technicianSuggestions', templateShareable: false}" liveChange=".onTechnicianLiveChange" suggestionItemSelected=".onTechnicianSuggestionSelect" placeholder="Search..." class="tmFieldInput">
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <DatePicker value="{createTM>date}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" class="tmFieldInput"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Item:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Input value="{createTM>itemDisplay}" showSuggestion="true" suggestionItems="{path: 'createTM>/itemSuggestions', templateShareable: false}" liveChange=".onItemLiveChange" suggestionItemSelected=".onItemSuggestionSelect" placeholder="Search..." class="tmFieldInput">
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Quantity:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <StepInput value="{createTM>quantity}" min="0" step="1" displayValuePrecision="2" valueState="{= ${createTM>quantity} > ${createTM>/maxQuantity} ? 'Warning' : 'None'}" valueStateText="{= ${createTM>quantity} > ${createTM>/maxQuantity} ? 'Exceeds activity quantity (' + ${createTM>/maxQuantity} + ')' : ''}" class="tmFieldInput"/>
                                        </HBox>
                                        
                                        <!-- Options Section -->
                                        <Title text="Options" level="H6" class="tmColumnHeader sapUiTinyMarginBottom sapUiSmallMarginTop"/>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Charge:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>chargeOption}" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="" text=""/>
                                                <core:Item key="CHARGEABLE" text="Chargeable"/>
                                                <core:Item key="NONCHARGEABLE" text="Non-Chargeable"/>
                                                <core:Item key="UNKNOWN" text="Unknown"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Rem. Time:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{createTM>remarksTime}" rows="2" placeholder="Remarks..." class="tmFieldInput"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Rem. Mat:" design="Bold" class="tmFieldLabel"/>
                                            <TextArea value="{createTM>remarksMaterial}" rows="2" placeholder="Remarks..." class="tmFieldInput"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 2: Time - Arbeitszeit + Time - Wartezeit -->
                                    <VBox class="tmColumn">
                                        <Title text="Time - Arbeitszeit" level="H6" class="tmColumnHeader sapUiTinyMarginBottom"/>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>task1Code}" items="{path: 'createTM>/taskSuggestionsAZ', templateShareable: false}" change=".onTaskSelect" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>duration1}" min="0" step="5" description="min" change=".onDuration1Change" class="tmFieldInput"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <DateTimePicker value="{createTM>startDateTime1}" valueFormat="yyyy-MM-dd'T'HH:mm:ss'Z'" displayFormat="dd.MM.yyyy HH:mm" change=".onStartDateTime1Change" class="tmFieldInput"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <DateTimePicker value="{createTM>endDateTime1}" valueFormat="yyyy-MM-dd'T'HH:mm:ss'Z'" displayFormat="dd.MM.yyyy HH:mm" class="tmFieldInput"/>
                                        </HBox>
                                        
                                        <!-- Time - Wartezeit Section -->
                                        <Title text="Time - Wartezeit" level="H6" class="tmColumnHeader sapUiTinyMarginBottom sapUiSmallMarginTop"/>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>task3Code}" items="{path: 'createTM>/taskSuggestionsWZ', templateShareable: false}" change=".onTaskSelect" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>duration3}" min="0" step="5" description="min" change=".onDuration3Change" class="tmFieldInput"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <DateTimePicker value="{createTM>startDateTime3}" valueFormat="yyyy-MM-dd'T'HH:mm:ss'Z'" displayFormat="dd.MM.yyyy HH:mm" change=".onStartDateTime3Change" class="tmFieldInput"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <DateTimePicker value="{createTM>endDateTime3}" valueFormat="yyyy-MM-dd'T'HH:mm:ss'Z'" displayFormat="dd.MM.yyyy HH:mm" class="tmFieldInput"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Col 3: Time - Fahrzeit -->
                                    <VBox class="tmColumn">
                                        <Title text="Time - Fahrzeit" level="H6" class="tmColumnHeader sapUiTinyMarginBottom"/>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel"/>
                                            <Select selectedKey="{createTM>task2Code}" items="{path: 'createTM>/taskSuggestionsFZ', templateShareable: false}" change=".onTaskSelect" forceSelection="false" class="tmFieldSelectNarrow">
                                                <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <StepInput value="{createTM>duration2}" min="0" step="5" description="min" change=".onDuration2Change" class="tmFieldInput"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <DateTimePicker value="{createTM>startDateTime2}" valueFormat="yyyy-MM-dd'T'HH:mm:ss'Z'" displayFormat="dd.MM.yyyy HH:mm" change=".onStartDateTime2Change" class="tmFieldInput"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <DateTimePicker value="{createTM>endDateTime2}" valueFormat="yyyy-MM-dd'T'HH:mm:ss'Z'" displayFormat="dd.MM.yyyy HH:mm" class="tmFieldInput"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </content>
                        </Panel>
                    </CustomListItem>
                </List>
                
            </VBox>
        </content>
        
        <!-- ========== DIALOG BUTTONS ========== -->
        <buttons>
            <Button text="Close" press=".onCancelCreateTM"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>