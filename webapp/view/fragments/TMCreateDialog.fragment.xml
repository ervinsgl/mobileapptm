<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">
    <Dialog 
        title="Create T&amp;M Report - {createTM>/activityCode}"
        contentWidth="90%"
        contentHeight="80%"
        draggable="true"
        resizable="true"
    >
        <content>
            <VBox class="sapUiMediumMargin">
                
                <!-- Header Info -->
                <VBox class="sapUiSmallMarginBottom">
                    <Title text="Activity: {createTM>/activityCode}" level="H4" class="sapUiTinyMarginBottom"/>
                    <Title text="{createTM>/activitySubject}" level="H5" class="sapUiSmallMarginBottom"/>
                </VBox>
                
                <!-- Activity Details Grid (3-column structure) -->
                <VBox class="activityQuickInfo sapUiSmallMarginBottom">
                    <l:Grid defaultSpan="XL4 L4 M12 S12" hSpacing="2" vSpacing="1" containerQuery="true">
                        
                        <!-- Row 1 -->
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Service Product:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/serviceProduct}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Planned Start:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedStartDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Quantity:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/quantity}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <!-- Row 2 -->
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Duration:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedDuration}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Planned End:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedEndDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Unit of Measure:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/quantityUoM}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                    </l:Grid>
                </VBox>
                
                <!-- T&M Type Selection Buttons -->
                <HBox class="sapUiSmallMarginBottom" width="100%" wrap="Wrap">
                    <Button 
                        text="Time Effort" 
                        icon="sap-icon://time-entry-request" 
                        press=".onAddTimeEffortEntry"
                        class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                    />
                    <Button 
                        text="Material" 
                        icon="sap-icon://product" 
                        press=".onAddMaterialEntry"
                        class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                    />
                    <Button 
                        text="Expense" 
                        icon="sap-icon://money-bills" 
                        press=".onAddExpenseEntry"
                        class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                    />
                    <Button 
                        text="Mileage" 
                        icon="sap-icon://car-rental" 
                        press=".onAddMileageEntry"
                        class="sapUiTinyMarginEnd sapUiTinyMarginBottom"
                    />
                    <Button 
                        text="Time &amp; Material Report" 
                        icon="sap-icon://checklist-item-2" 
                        press=".onAddTimeAndMaterialEntry"
                        class="sapUiTinyMarginBottom"
                        type="Emphasized"
                    />
                </HBox>
                
                <!-- T&M Entry Panels - Dynamic List -->
                <List
                    items="{
                        path: 'createTM>/entries',
                        templateShareable: false
                    }"
                    mode="None"
                    showSeparators="None"
                >
                    <CustomListItem type="Inactive">
                        <Panel
                            headerText="T&amp;M Entry - {createTM>type}"
                            expandable="true"
                            expanded="{createTM>expanded}"
                            class="tmEntryPanel"
                        >
                            <headerToolbar>
                                <OverflowToolbar design="Info">
                                    <core:Icon src="{createTM>icon}" class="sapUiSmallMarginEnd"/>
                                    <Title text="T&amp;M Entry - {createTM>type}" level="H5"/>
                                    <ToolbarSpacer />
                                    <!-- Close Entry Button -->
                                    <Button
                                        text="Close Entry"
                                        icon="sap-icon://decline"
                                        type="Reject"
                                        press=".onCloseEntry"
                                        class="sapUiTinyMarginEnd"
                                    />
                                    <!-- Progressive Save Button -->
                                    <Button
                                        text="{createTM>saveButtonText}"
                                        icon="{createTM>saveButtonIcon}"
                                        type="{createTM>saveButtonType}"
                                        press=".onSaveEntry"
                                        enabled="{createTM>saveButtonEnabled}"
                                    />
                                </OverflowToolbar>
                            </headerToolbar>
                            
                            <content>
                                <!-- TIME EFFORT LAYOUT (3-Column, 3 rows each) -->
                                <HBox class="tmEntryContent tmEntryContent3Col" visible="{= ${createTM>type} === 'Time Effort'}" width="100%">
                                    <!-- Column 1: Task, Technician -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Select
                                                selectedKey="{createTM>taskCode}"
                                                items="{
                                                    path: 'createTM>/taskSuggestions',
                                                    templateShareable: false
                                                }"
                                                change=".onTaskSelect"
                                                forceSelection="false"
                                                class="tmFieldSelectNarrow"
                                            >
                                                <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Input
                                                value="{createTM>technicianDisplay}"
                                                showSuggestion="true"
                                                suggestionItems="{
                                                    path: 'createTM>/technicianSuggestions',
                                                    templateShareable: false
                                                }"
                                                liveChange=".onTechnicianLiveChange"
                                                suggestionItemSelected=".onTechnicianSuggestionSelect"
                                                placeholder="Search..."
                                                class="tmFieldInput tmFieldInputNarrow"
                                            >
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                    
                                    <!-- Column 2: Duration, Start, End -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Input value="{createTM>duration}" placeholder="e.g. 30 min" class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>start}" placeholder="Start time..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>end}" placeholder="End time..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 3: Charge Option, Remarks -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Charge:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>chargeOption}" placeholder="Charge..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>remarks}" placeholder="Remarks..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                </HBox>
                                
                                <!-- MATERIAL LAYOUT (3-Column Narrow) -->
                                <HBox class="tmEntryContent tmEntryContent3Col" visible="{= ${createTM>type} === 'Material'}" width="100%">
                                    <!-- Column 1: Item & Technician -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Item:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Input
                                                value="{createTM>itemDisplay}"
                                                showSuggestion="true"
                                                suggestionItems="{
                                                    path: 'createTM>/itemSuggestions',
                                                    templateShareable: false
                                                }"
                                                liveChange=".onItemLiveChange"
                                                suggestionItemSelected=".onItemSuggestionSelect"
                                                placeholder="Search item..."
                                                class="tmFieldInput tmFieldInputNarrow"
                                            >
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Input
                                                value="{createTM>technicianDisplay}"
                                                showSuggestion="true"
                                                suggestionItems="{
                                                    path: 'createTM>/technicianSuggestions',
                                                    templateShareable: false
                                                }"
                                                liveChange=".onTechnicianLiveChange"
                                                suggestionItemSelected=".onTechnicianSuggestionSelect"
                                                placeholder="Search..."
                                                class="tmFieldInput tmFieldInputNarrow"
                                            >
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                    
                                    <!-- Column 2: Date, Quantity -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <DatePicker
                                                value="{createTM>date}"
                                                valueFormat="yyyy-MM-dd"
                                                displayFormat="dd.MM.yyyy"
                                                class="tmFieldInputNarrow"
                                            />
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Quantity:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Input value="{createTM>quantity}" placeholder="Qty..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                    
                                    <!-- Column 3: Charge Option, Remarks -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Charge:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>chargeOption}" placeholder="Charge..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>remarks}" placeholder="Remarks..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                </HBox>
                                
                                <!-- EXPENSE LAYOUT (3-Column Narrow) -->
                                <HBox class="tmEntryContent tmEntryContent3Col" visible="{= ${createTM>type} === 'Expense'}" width="100%">
                                    <!-- Column 1: Expense Type, Technician, Date -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Type:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Select
                                                selectedKey="{createTM>expenseTypeId}"
                                                items="{
                                                    path: 'createTM>/expenseTypeSuggestions',
                                                    templateShareable: false
                                                }"
                                                change=".onExpenseTypeChange"
                                                class="tmFieldSelectNarrow"
                                            >
                                                <core:Item key="{createTM>key}" text="{createTM>text}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Input
                                                value="{createTM>technicianDisplay}"
                                                showSuggestion="true"
                                                suggestionItems="{
                                                    path: 'createTM>/technicianSuggestions',
                                                    templateShareable: false
                                                }"
                                                liveChange=".onTechnicianLiveChange"
                                                suggestionItemSelected=".onTechnicianSuggestionSelect"
                                                placeholder="Search..."
                                                class="tmFieldInput tmFieldInputNarrow"
                                            >
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <DatePicker
                                                value="{createTM>date}"
                                                valueFormat="yyyy-MM-dd"
                                                displayFormat="dd.MM.yyyy"
                                                class="tmFieldInputNarrow"
                                            />
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 2: External Amount, Internal Amount -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="External:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>externalAmount}" placeholder="External..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Internal:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>internalAmount}" placeholder="Internal..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                    
                                    <!-- Column 3: Charge Option, Remarks -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Charge:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>chargeOption}" placeholder="Charge..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>remarks}" placeholder="Remarks..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                </HBox>
                                
                                <!-- MILEAGE LAYOUT (3-Column Narrow) -->
                                <HBox class="tmEntryContent tmEntryContent3Col" visible="{= ${createTM>type} === 'Mileage'}" width="100%">
                                    <!-- Column 1: Route, Technician, Distance -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Route:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>route}" placeholder="Route..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Input
                                                value="{createTM>technicianDisplay}"
                                                showSuggestion="true"
                                                suggestionItems="{
                                                    path: 'createTM>/technicianSuggestions',
                                                    templateShareable: false
                                                }"
                                                liveChange=".onTechnicianLiveChange"
                                                suggestionItemSelected=".onTechnicianSuggestionSelect"
                                                placeholder="Search..."
                                                class="tmFieldInput tmFieldInputNarrow"
                                            >
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Distance:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Input value="{createTM>distance}" placeholder="e.g. 50 km" class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                    
                                    <!-- Column 2: Date, Travel Start, Travel End -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <DatePicker
                                                value="{createTM>date}"
                                                valueFormat="yyyy-MM-dd"
                                                displayFormat="dd.MM.yyyy"
                                                class="tmFieldInputNarrow"
                                            />
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>travelStart}" placeholder="Start..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>travelEnd}" placeholder="End..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow tmFieldRowSpacer" width="100%" height="2rem"/>
                                    </VBox>
                                    
                                    <!-- Column 3: Driver, Private Car, Charge Option, Remarks -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Driver:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>driver}" placeholder="Driver..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Private:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>privateCar}" placeholder="Yes/No..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Charge:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>chargeOption}" placeholder="Charge..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>remarks}" placeholder="Remarks..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- TIME & MATERIAL LAYOUT (5-Column) -->
                                <HBox class="tmEntryContent tmEntryContent5Col" visible="{= ${createTM>type} === 'Time &amp; Material'}" width="100%">
                                    <!-- Column 1: Material Info -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <Title text="Material" level="H6" class="tmColumnHeader sapUiTinyMarginBottom"/>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Input
                                                value="{createTM>technicianDisplay}"
                                                showSuggestion="true"
                                                suggestionItems="{
                                                    path: 'createTM>/technicianSuggestions',
                                                    templateShareable: false
                                                }"
                                                liveChange=".onTechnicianLiveChange"
                                                suggestionItemSelected=".onTechnicianSuggestionSelect"
                                                placeholder="Search..."
                                                class="tmFieldInput tmFieldInputNarrow"
                                            >
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <DatePicker
                                                value="{createTM>date}"
                                                valueFormat="yyyy-MM-dd"
                                                displayFormat="dd.MM.yyyy"
                                                class="tmFieldInputNarrow"
                                            />
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Item:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Input
                                                value="{createTM>itemDisplay}"
                                                showSuggestion="true"
                                                suggestionItems="{
                                                    path: 'createTM>/itemSuggestions',
                                                    templateShareable: false
                                                }"
                                                liveChange=".onItemLiveChange"
                                                suggestionItemSelected=".onItemSuggestionSelect"
                                                placeholder="Search..."
                                                class="tmFieldInput tmFieldInputNarrow"
                                            >
                                                <suggestionItems>
                                                    <core:ListItem key="{createTM>id}" text="{createTM>displayText}" additionalText="{createTM>externalId}"/>
                                                </suggestionItems>
                                            </Input>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Quantity:" design="Bold" class="tmFieldLabel tmFieldLabelRequired"/>
                                            <Input value="{createTM>quantity}" placeholder="Qty..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 2: Time - Arbeitszeit -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <Title text="Time - Arbeitszeit" level="H6" class="tmColumnHeader sapUiTinyMarginBottom"/>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel"/>
                                            <Select
                                                selectedKey="{createTM>task1Code}"
                                                items="{
                                                    path: 'createTM>/taskSuggestionsAZ',
                                                    templateShareable: false
                                                }"
                                                change=".onTaskSelect"
                                                forceSelection="false"
                                                class="tmFieldSelectNarrow"
                                            >
                                                <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>duration1}" placeholder="Duration..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>start1}" placeholder="Start..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>end1}" placeholder="End..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 3: Time - Fahrzeit -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <Title text="Time - Fahrzeit" level="H6" class="tmColumnHeader sapUiTinyMarginBottom"/>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel"/>
                                            <Select
                                                selectedKey="{createTM>task2Code}"
                                                items="{
                                                    path: 'createTM>/taskSuggestionsFZ',
                                                    templateShareable: false
                                                }"
                                                change=".onTaskSelect"
                                                forceSelection="false"
                                                class="tmFieldSelectNarrow"
                                            >
                                                <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>duration2}" placeholder="Duration..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>start2}" placeholder="Start..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <Input value="{createTM>end2}" placeholder="End..." class="tmFieldInput tmFieldInputNarrow"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 4: Time - Wartezeit -->
                                    <VBox class="tmColumn tmColumnNarrow">
                                        <Title text="Time - Wartezeit" level="H6" class="tmColumnHeader sapUiTinyMarginBottom"/>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel"/>
                                            <Select
                                                selectedKey="{createTM>task3Code}"
                                                items="{
                                                    path: 'createTM>/taskSuggestionsWZ',
                                                    templateShareable: false
                                                }"
                                                change=".onTaskSelect"
                                                forceSelection="false"
                                                class="tmFieldSelectNarrow"
                                            >
                                                <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                            </Select>
                                        </HBox>
                                        <HBox class="tmFieldRow" width="100%">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
