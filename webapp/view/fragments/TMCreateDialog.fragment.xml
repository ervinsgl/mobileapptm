<core:FragmentDefinition xmlns="sap.m" xmlns:core="sap.ui.core" xmlns:l="sap.ui.layout">
    <Dialog 
        title="Create T&amp;M Report - {createTM>/activityCode}"
        contentWidth="90%"
        contentHeight="80%"
        draggable="true"
        resizable="true"
    >
        <content>
            <VBox class="sapUiMediumMargin">
                
                <!-- Header Info -->
                <VBox class="sapUiSmallMarginBottom">
                    <Title text="Activity: {createTM>/activityCode}" level="H4" class="sapUiTinyMarginBottom"/>
                    <Title text="{createTM>/activitySubject}" level="H5" class="sapUiSmallMarginBottom"/>
                </VBox>
                
                <!-- Activity Details Grid (3-column structure - MATCHING TMReportsDialog) -->
                <VBox class="activityQuickInfo sapUiSmallMarginBottom">
                    <l:Grid defaultSpan="XL4 L4 M12 S12" hSpacing="2" vSpacing="1" containerQuery="true">
                        
                        <!-- Column 1: Service Product, Duration -->
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Service Product:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/serviceProduct}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Planned Start:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedStartDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Quantity:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/quantity}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <!-- Row 2 -->
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Duration:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedDuration}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Planned End:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedEndDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                        <VBox class="detailField">
                            <layoutData>
                                <l:GridData span="XL4 L4 M12 S12"/>
                            </layoutData>
                            <Label text="Unit of Measure:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/quantityUoM}" class="infoValue detailFieldValue"/>
                        </VBox>
                        
                    </l:Grid>
                </VBox>
                
                <!-- T&M Type Selection Buttons -->
                <HBox class="sapUiSmallMarginBottom" width="100%">
                    <Button 
                        text="Time Effort" 
                        icon="sap-icon://time-entry-request" 
                        press=".onAddTimeEffortEntry"
                        class="sapUiTinyMarginEnd"
                    />
                    <Button 
                        text="Material" 
                        icon="sap-icon://product" 
                        press=".onAddMaterialEntry"
                        class="sapUiTinyMarginEnd"
                    />
                    <Button 
                        text="Expense" 
                        icon="sap-icon://money-bills" 
                        press=".onAddExpenseEntry"
                        class="sapUiTinyMarginEnd"
                    />
                    <Button 
                        text="Mileage" 
                        icon="sap-icon://car-rental" 
                        press=".onAddMileageEntry"
                    />
                </HBox>
                
                <!-- T&M Entry Panels - Dynamic List -->
                <List
                    items="{
                        path: 'createTM>/entries',
                        templateShareable: false
                    }"
                    mode="None"
                    showSeparators="None"
                >
                    <CustomListItem type="Inactive">
                        <Panel
                            headerText="T&amp;M Entry - {createTM>type}"
                            expandable="true"
                            expanded="{createTM>expanded}"
                            class="tmEntryPanel"
                        >
                            <headerToolbar>
                                <OverflowToolbar design="Info">
                                    <core:Icon src="{createTM>icon}" class="sapUiSmallMarginEnd"/>
                                    <Title text="T&amp;M Entry - {createTM>type}" level="H5"/>
                                </OverflowToolbar>
                            </headerToolbar>
                            
                            <content>
                                <!-- TIME EFFORT LAYOUT -->
                                <HBox class="tmEntryContent" visible="{= ${createTM>type} === 'Time Effort'}">
                                    <!-- Column 1 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Task:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 2 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Duration:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Start:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="End:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 3 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Charge Option:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- MATERIAL LAYOUT -->
                                <HBox class="tmEntryContent" visible="{= ${createTM>type} === 'Material'}">
                                    <!-- Column 1 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Item:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 2 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Quantity:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 3 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Charge Option:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- EXPENSE LAYOUT -->
                                <HBox class="tmEntryContent" visible="{= ${createTM>type} === 'Expense'}">
                                    <!-- Column 1 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Expense Type:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 2 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="External Amount:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Internal Amount:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 3 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Charge Option:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                                
                                <!-- MILEAGE LAYOUT -->
                                <HBox class="tmEntryContent" visible="{= ${createTM>type} === 'Mileage'}">
                                    <!-- Column 1 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Route:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Technician:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Distance:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 2 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Date:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Travel Start:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Travel End:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                    
                                    <!-- Column 3 -->
                                    <VBox class="tmColumn">
                                        <HBox class="tmFieldRow">
                                            <Label text="Driver:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Private Car:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Charge Option:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                        <HBox class="tmFieldRow">
                                            <Label text="Remarks:" design="Bold" class="tmFieldLabel"/>
                                            <Text text="" class="tmFieldValue"/>
                                        </HBox>
                                    </VBox>
                                </HBox>
                            </content>
                        </Panel>
                    </CustomListItem>
                </List>
                
            </VBox>
        </content>
        
        <buttons>
            <Button text="Close" press=".onCancelCreateTM"/>
            <Button text="Save All" type="Emphasized" press=".onSaveAllTMEntries"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>