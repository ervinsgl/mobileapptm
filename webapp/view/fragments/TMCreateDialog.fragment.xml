<core:FragmentDefinition 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core" 
    xmlns:l="sap.ui.layout"
>
    <!-- 
        TMCreateDialog Fragment: Dialog for creating T&M (Time & Materials) entries.
        
        Entry Types:
        - Expense Report: Table-based (Service Products Z40000001, Z40000007, Z50000000)
        - Mileage Report: Table-based (Service Products Z40000038, Z40000008)
        - Time & Material Report: Panel-based (All other Service Products)
        
        Model: createTM
    -->
    <Dialog 
        title="Create T&amp;M Report - {createTM>/activityCode}"
        contentWidth="95%"
        contentHeight="85%"
        draggable="true"
        resizable="true"
    >
        <customHeader>
            <OverflowToolbar>
                <Title text="Create T&amp;M Report - {createTM>/activityCode}" level="H4"/>
                <ToolbarSpacer/>
            </OverflowToolbar>
        </customHeader>
        <subHeader>
            <Toolbar design="Info">
                <Title text="{createTM>/activitySubject}" level="H6" wrapping="true"/>
                <ToolbarSpacer/>
                <Label text="ID: {createTM>/activityExternalId}"/>
            </Toolbar>
        </subHeader>
        <content>
            <VBox class="sapUiSmallMargin">
                
                <!-- ========== ACTIVITY DETAILS SECTION ========== -->
                <VBox class="activityQuickInfo sapUiSmallMarginBottom">
                    <l:Grid defaultSpan="XL4 L4 M6 S12" hSpacing="2" vSpacing="1" containerQuery="true">
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M6 S12"/></layoutData>
                            <Label text="Service Product:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/serviceProduct}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M6 S12"/></layoutData>
                            <Label text="Planned Start:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedStartDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M6 S12"/></layoutData>
                            <Label text="Quantity:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/quantity}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M6 S12"/></layoutData>
                            <Label text="Duration:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedDuration}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M6 S12"/></layoutData>
                            <Label text="Planned End:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/formattedEndDate}" class="infoValue detailFieldValue"/>
                        </VBox>
                        <VBox class="detailField">
                            <layoutData><l:GridData span="XL4 L4 M6 S12"/></layoutData>
                            <Label text="Unit of Measure:" design="Bold" class="infoLabel"/>
                            <Text text="{createTM>/quantityUoM}" class="infoValue detailFieldValue"/>
                        </VBox>
                    </l:Grid>
                </VBox>
                
                <!-- ========== EXPENSE REPORT TABLE ========== -->
                <!-- Visible only for Service Products: Z40000001, Z40000007, Z50000000 -->
                <Panel 
                    expandable="false" 
                    expanded="true" 
                    visible="{= ${createTM>/serviceProductExternalId} === 'Z40000001' || ${createTM>/serviceProductExternalId} === 'Z40000007' || ${createTM>/serviceProductExternalId} === 'Z50000000' }" 
                    class="tmTypePanel sapUiSmallMarginTop"
                >
                    <headerToolbar>
                        <OverflowToolbar design="Info">
                            <core:Icon src="sap-icon://money-bills" class="sapUiTinyMarginEnd" color="#E9730C"/>
                            <Title text="Expense Report" level="H5"/>
                            <ToolbarSpacer/>
                            <Button 
                                text="Add Entry" 
                                icon="sap-icon://add" 
                                type="Emphasized" 
                                press=".onAddCreateExpenseRow" 
                                class="sapUiTinyMarginBegin"
                            />
                            <ObjectNumber number="{= ${createTM>/expenseEntries}.length }" unit="entries" class="sapUiSmallMarginBegin"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <!-- Empty state when no entries -->
                        <VBox visible="{= ${createTM>/expenseEntries}.length === 0 }" alignItems="Center" class="sapUiMediumMarginTopBottom">
                            <core:Icon src="sap-icon://money-bills" size="2.5rem" color="#E9730C"/>
                            <Text text="No expense entries yet" class="sapUiSmallMarginTop"/>
                            <Text text="Click 'Add Entry' to create an expense report" class="sapUiTinyMarginTop sapMTextGrey"/>
                        </VBox>
                        
                        <!-- Expense Table -->
                        <ScrollContainer horizontal="true" vertical="false" width="100%">
                            <Table
                                items="{path: 'createTM>/expenseEntries', templateShareable: false}"
                                visible="{= ${createTM>/expenseEntries}.length > 0 }"
                                class="tmMTable"
                                width="auto"
                            >
                                <columns>
                                    <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                    <Column hAlign="Begin"><Text text="Expense Type"/></Column>
                                    <Column width="14rem" hAlign="Begin"><Text text="Technician"/></Column>
                                    <Column width="5rem" hAlign="Begin"><Text text="Ext. Amt"/></Column>
                                    <Column width="5rem" hAlign="Begin"><Text text="Int. Amt"/></Column>
                                    <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                    <Column width="9rem" hAlign="Begin"><Text text="Date"/></Column>
                                    <Column hAlign="Begin"><Text text="Remarks"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem type="Inactive" highlight="Information">
                                        <cells>
                                            <Button icon="sap-icon://decline" type="Transparent" tooltip="Remove" press=".onRemoveCreateExpenseRow"/>
                                            <Text text="{createTM>expenseTypeDisplay}"/>
                                            <Input 
                                                value="{createTM>technicianDisplay}" 
                                                showSuggestion="true" 
                                                suggestionItems="{path: 'createTM>/technicianSuggestions', templateShareable: false}"
                                                liveChange=".onCreateTechnicianLiveChange"
                                                suggestionItemSelected=".onCreateTechnicianSuggestionSelect"
                                                placeholder="Search technician..."
                                                width="100%"
                                                maxSuggestionWidth="400px"
                                                startSuggestion="2"
                                                showTableSuggestionValueHelp="false"
                                            >
                                                <suggestionItems>
                                                    <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                                </suggestionItems>
                                            </Input>
                                            <Input value="{createTM>externalAmountValue}" type="Number" width="100%"/>
                                            <Input value="{createTM>internalAmountValue}" type="Number" width="100%"/>
                                            <Text text="EUR"/>
                                            <DatePicker value="{createTM>entryDate}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="100%"/>
                                            <Input value="{createTM>remarks}" width="100%" placeholder="Enter remarks..."/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </ScrollContainer>
                        
                        <!-- Add button at bottom -->
                        <HBox justifyContent="Center" class="sapUiSmallMarginTop" visible="{= ${createTM>/expenseEntries}.length > 0 }">
                            <Button icon="sap-icon://add" type="Transparent" tooltip="Add Entry" press=".onAddCreateExpenseRow"/>
                        </HBox>
                    </content>
                </Panel>
                
                <!-- ========== MILEAGE REPORT TABLE ========== -->
                <!-- Visible only for Service Products: Z40000038, Z40000008 -->
                <Panel 
                    expandable="false" 
                    expanded="true" 
                    visible="{= ${createTM>/serviceProductExternalId} === 'Z40000038' || ${createTM>/serviceProductExternalId} === 'Z40000008' }" 
                    class="tmTypePanel sapUiSmallMarginTop"
                >
                    <headerToolbar>
                        <OverflowToolbar design="Info">
                            <core:Icon src="sap-icon://car-rental" class="sapUiTinyMarginEnd" color="#6C32A9"/>
                            <Title text="Mileage Report" level="H5"/>
                            <ToolbarSpacer/>
                            <Button 
                                text="Add Entry" 
                                icon="sap-icon://add" 
                                type="Emphasized" 
                                press=".onAddCreateMileageRow" 
                                class="sapUiTinyMarginBegin"
                            />
                            <ObjectNumber number="{= ${createTM>/mileageEntries}.length }" unit="entries" class="sapUiSmallMarginBegin"/>
                        </OverflowToolbar>
                    </headerToolbar>
                    <content>
                        <!-- Empty state when no entries -->
                        <VBox visible="{= ${createTM>/mileageEntries}.length === 0 }" alignItems="Center" class="sapUiMediumMarginTopBottom">
                            <core:Icon src="sap-icon://car-rental" size="2.5rem" color="#6C32A9"/>
                            <Text text="No mileage entries yet" class="sapUiSmallMarginTop"/>
                            <Text text="Click 'Add Entry' to create a mileage report" class="sapUiTinyMarginTop sapMTextGrey"/>
                        </VBox>
                        
                        <!-- Mileage Table -->
                        <ScrollContainer horizontal="true" vertical="false" width="100%">
                            <Table
                                items="{path: 'createTM>/mileageEntries', templateShareable: false}"
                                visible="{= ${createTM>/mileageEntries}.length > 0 }"
                                class="tmMTable"
                                width="auto"
                            >
                                <columns>
                                    <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                    <Column hAlign="Begin"><Text text="Mileage Type"/></Column>
                                    <Column width="14rem" hAlign="Begin"><Text text="Technician"/></Column>
                                    <Column width="5rem" hAlign="Begin"><Text text="Dist."/></Column>
                                    <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                    <Column width="5rem" hAlign="Begin"><Text text="Dur."/></Column>
                                    <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                    <Column width="9rem" hAlign="Begin"><Text text="Date"/></Column>
                                    <Column hAlign="Begin"><Text text="Remarks"/></Column>
                                </columns>
                                <items>
                                    <ColumnListItem type="Inactive" highlight="Information">
                                        <cells>
                                            <Button icon="sap-icon://decline" type="Transparent" tooltip="Remove" press=".onRemoveCreateMileageRow"/>
                                            <Text text="{createTM>mileageTypeDisplay}"/>
                                            <Input 
                                                value="{createTM>technicianDisplay}" 
                                                showSuggestion="true" 
                                                suggestionItems="{path: 'createTM>/technicianSuggestions', templateShareable: false}"
                                                liveChange=".onCreateTechnicianLiveChange"
                                                suggestionItemSelected=".onCreateTechnicianSuggestionSelect"
                                                placeholder="Search technician..."
                                                width="100%"
                                                maxSuggestionWidth="400px"
                                                startSuggestion="2"
                                                showTableSuggestionValueHelp="false"
                                            >
                                                <suggestionItems>
                                                    <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                                </suggestionItems>
                                            </Input>
                                            <Input value="{createTM>distance}" type="Number" width="100%"/>
                                            <Text text="KM"/>
                                            <Input value="{createTM>travelDuration}" type="Number" width="100%"/>
                                            <Text text="min"/>
                                            <DatePicker value="{createTM>entryDate}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="100%"/>
                                            <Input value="{createTM>remarks}" width="100%" placeholder="Enter remarks..."/>
                                        </cells>
                                    </ColumnListItem>
                                </items>
                            </Table>
                        </ScrollContainer>
                        
                        <!-- Add button at bottom -->
                        <HBox justifyContent="Center" class="sapUiSmallMarginTop" visible="{= ${createTM>/mileageEntries}.length > 0 }">
                            <Button icon="sap-icon://add" type="Transparent" tooltip="Add Entry" press=".onAddCreateMileageRow"/>
                        </HBox>
                    </content>
                </Panel>
                
                <!-- ========== TIME & MATERIAL - TABLE BASED ========== -->
                <!-- Visible for all other Service Products -->
                <VBox 
                    visible="{= ${createTM>/serviceProductExternalId} !== 'Z40000001' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z40000007' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z50000000' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z40000038' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z40000008' }"
                    class="sapUiSmallMarginTop"
                >
                    <!-- ===== MATERIAL TABLE ===== -->
                    <Panel expandable="false" expanded="true" class="tmTypePanel sapUiTinyMarginBottom">
                        <headerToolbar>
                            <OverflowToolbar design="Info">
                                <core:Icon src="sap-icon://product" class="sapUiTinyMarginEnd" color="#107E3E"/>
                                <Title text="Material" level="H5"/>
                                <ToolbarSpacer/>
                                <Button 
                                    text="Add Material" 
                                    icon="sap-icon://add" 
                                    type="Emphasized" 
                                    press=".onAddCreateMaterialRow" 
                                    class="sapUiTinyMarginBegin"
                                />
                                <ObjectNumber number="{= ${createTM>/materialEntries}.length }" unit="entries" class="sapUiSmallMarginBegin"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <!-- Empty state when no entries -->
                            <VBox visible="{= ${createTM>/materialEntries}.length === 0 }" alignItems="Center" class="sapUiMediumMarginTopBottom">
                                <core:Icon src="sap-icon://product" size="2.5rem" color="#107E3E"/>
                                <Text text="No material entries yet" class="sapUiSmallMarginTop"/>
                                <Text text="Click 'Add Material' to create a material entry" class="sapUiTinyMarginTop sapMTextGrey"/>
                            </VBox>
                            
                            <!-- Material Table -->
                            <ScrollContainer horizontal="true" vertical="false" width="100%">
                                <Table
                                    items="{path: 'createTM>/materialEntries', templateShareable: false}"
                                    visible="{= ${createTM>/materialEntries}.length > 0 }"
                                    class="tmMTable"
                                    width="auto"
                                >
                                    <columns>
                                        <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                        <Column width="11rem" hAlign="Begin"><Text text="Item"/></Column>
                                        <Column width="11rem" hAlign="Begin"><Text text="Technician"/></Column>
                                        <Column width="6.5rem" hAlign="Begin"><Text text="Qty"/></Column>
                                        <Column width="2.5rem" hAlign="Begin"><Text text=""/></Column>
                                        <Column width="9rem" hAlign="Begin"><Text text="Date"/></Column>
                                        <Column hAlign="Begin"><Text text="Remarks"/></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem type="Inactive">
                                            <cells>
                                                <Button icon="sap-icon://decline" type="Transparent" press=".onRemoveCreateMaterialRow"/>
                                                <Text text="{createTM>itemDisplay}"/>
                                                <Select 
                                                    selectedKey="{createTM>technicianId}" 
                                                    items="{path: 'createTM>/activityTechnicians', templateShareable: false}" 
                                                    change=".onCreateMaterialTechnicianSelect"
                                                    forceSelection="false"
                                                    width="100%"
                                                >
                                                    <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                                </Select>
                                                <StepInput 
                                                    value="{createTM>quantity}" 
                                                    min="0" 
                                                    step="1" 
                                                    displayValuePrecision="2" 
                                                    width="100%"
                                                    valueState="{= parseFloat(${createTM>quantity}) > parseFloat(${createTM>/maxQuantity}) ? 'Warning' : 'None'}"
                                                    valueStateText="Quantity exceeds Activity quantity"
                                                />
                                                <Text text="pcs"/>
                                                <DatePicker value="{createTM>entryDate}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="100%"/>
                                                <Input value="{createTM>remarks}" placeholder="Remarks..." width="100%"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </ScrollContainer>
                            
                            <!-- Add button at bottom -->
                            <HBox justifyContent="Center" class="sapUiSmallMarginTop" visible="{= ${createTM>/materialEntries}.length > 0 }">
                                <Button icon="sap-icon://add" type="Transparent" tooltip="Add Material" press=".onAddCreateMaterialRow"/>
                            </HBox>
                        </content>
                    </Panel>
                    
                    <!-- ===== TIME ENTRIES - ARBEITSZEIT (AZ) ===== -->
                    <Panel expandable="false" expanded="true" class="tmTypePanel sapUiTinyMarginBottom">
                        <headerToolbar>
                            <OverflowToolbar design="Info">
                                <core:Icon src="sap-icon://time-entry-request" class="sapUiTinyMarginEnd" color="#0854A0"/>
                                <Title text="Time - Arbeitszeit (AZ)" level="H5"/>
                                <ToolbarSpacer/>
                                <Button 
                                    text="Add Time Entry" 
                                    icon="sap-icon://add" 
                                    type="Emphasized" 
                                    press=".onAddCreateTimeEntryAZ" 
                                    class="sapUiTinyMarginBegin"
                                />
                                <ObjectNumber number="{= ${createTM>/timeEntriesAZ}.length }" unit="entries" class="sapUiSmallMarginBegin"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <!-- Empty state when no entries -->
                            <VBox visible="{= ${createTM>/timeEntriesAZ}.length === 0 }" alignItems="Center" class="sapUiMediumMarginTopBottom">
                                <core:Icon src="sap-icon://time-entry-request" size="2.5rem" color="#0854A0"/>
                                <Text text="No Arbeitszeit entries yet" class="sapUiSmallMarginTop"/>
                                <Text text="Click 'Add Time Entry' to create an Arbeitszeit entry" class="sapUiTinyMarginTop sapMTextGrey"/>
                            </VBox>
                            
                            <!-- Time Entries Table -->
                            <ScrollContainer horizontal="true" vertical="false" width="100%">
                                <Table
                                    items="{path: 'createTM>/timeEntriesAZ', templateShareable: false}"
                                    visible="{= ${createTM>/timeEntriesAZ}.length > 0 }"
                                    class="tmMTable"
                                    width="auto"
                                >
                                    <columns>
                                        <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                        <Column width="11rem" hAlign="Begin"><Text text="Task"/></Column>
                                        <Column width="14rem" hAlign="Begin"><Text text="Technician"/></Column>
                                        <Column width="6.5rem" hAlign="Begin"><Text text="Duration"/></Column>
                                        <Column width="2.5rem" hAlign="Begin"><Text text=""/></Column>
                                        <Column width="9rem" hAlign="Begin"><Text text="Date"/></Column>
                                        <Column hAlign="Begin"><Text text="Remarks"/></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem type="Inactive">
                                            <cells>
                                                <Button icon="sap-icon://decline" type="Transparent" press=".onRemoveCreateTimeEntryAZ"/>
                                                <Select 
                                                    selectedKey="{createTM>taskCode}" 
                                                    items="{path: 'createTM>/taskSuggestionsAZ', templateShareable: false}" 
                                                    forceSelection="false"
                                                    width="100%"
                                                    valueState="{= ${createTM>taskCode} ? 'None' : 'Error'}"
                                                >
                                                    <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                                </Select>
                                                <MultiInput
                                                    tokens="{path: 'createTM>selectedTechnicians', templateShareable: false}"
                                                    showSuggestion="true"
                                                    suggestionItems="{path: 'createTM>technicianSuggestions', templateShareable: false}"
                                                    liveChange=".onCreateTimeEntryTechnicianLiveChange"
                                                    suggestionItemSelected=".onCreateTimeEntryMultiTechnicianSelect"
                                                    tokenUpdate=".onTimeEntryTechnicianTokenUpdate"
                                                    placeholder="Add technicians..."
                                                    width="100%"
                                                    maxSuggestionWidth="400px"
                                                    startSuggestion="2"
                                                    valueState="{= ${createTM>selectedTechnicians}.length > 0 ? 'None' : 'Error'}"
                                                >
                                                    <tokens>
                                                        <Token key="{createTM>id}" text="{createTM>displayText}"/>
                                                    </tokens>
                                                    <suggestionItems>
                                                        <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                                    </suggestionItems>
                                                </MultiInput>
                                                <StepInput value="{createTM>durationHrs}" min="0" step="0.25" displayValuePrecision="2" width="100%"/>
                                                <Text text="hrs"/>
                                                <DatePicker value="{createTM>entryDate}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="100%"/>
                                                <Input value="{createTM>remarks}" placeholder="Remarks..." width="100%"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </ScrollContainer>
                            
                            <!-- Add button at bottom -->
                            <HBox justifyContent="Center" class="sapUiSmallMarginTop" visible="{= ${createTM>/timeEntriesAZ}.length > 0 }">
                                <Button icon="sap-icon://add" type="Transparent" tooltip="Add Time Entry" press=".onAddCreateTimeEntryAZ"/>
                            </HBox>
                        </content>
                    </Panel>
                    
                    <!-- ===== TIME ENTRIES - FAHRZEIT (FZ) ===== -->
                    <Panel expandable="false" expanded="true" class="tmTypePanel sapUiTinyMarginBottom">
                        <headerToolbar>
                            <OverflowToolbar design="Info">
                                <core:Icon src="sap-icon://car-rental" class="sapUiTinyMarginEnd" color="#E9730C"/>
                                <Title text="Time - Fahrzeit (FZ)" level="H5"/>
                                <ToolbarSpacer/>
                                <Button 
                                    text="Add Time Entry" 
                                    icon="sap-icon://add" 
                                    type="Emphasized" 
                                    press=".onAddCreateTimeEntryFZ" 
                                    class="sapUiTinyMarginBegin"
                                />
                                <ObjectNumber number="{= ${createTM>/timeEntriesFZ}.length }" unit="entries" class="sapUiSmallMarginBegin"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <!-- Empty state when no entries -->
                            <VBox visible="{= ${createTM>/timeEntriesFZ}.length === 0 }" alignItems="Center" class="sapUiMediumMarginTopBottom">
                                <core:Icon src="sap-icon://car-rental" size="2.5rem" color="#E9730C"/>
                                <Text text="No Fahrzeit entries yet" class="sapUiSmallMarginTop"/>
                                <Text text="Click 'Add Time Entry' to create a Fahrzeit entry" class="sapUiTinyMarginTop sapMTextGrey"/>
                            </VBox>
                            
                            <!-- Time Entries Table -->
                            <ScrollContainer horizontal="true" vertical="false" width="100%">
                                <Table
                                    items="{path: 'createTM>/timeEntriesFZ', templateShareable: false}"
                                    visible="{= ${createTM>/timeEntriesFZ}.length > 0 }"
                                    class="tmMTable"
                                    width="auto"
                                >
                                    <columns>
                                        <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                        <Column width="11rem" hAlign="Begin"><Text text="Task"/></Column>
                                        <Column width="14rem" hAlign="Begin"><Text text="Technician"/></Column>
                                        <Column width="6.5rem" hAlign="Begin"><Text text="Duration"/></Column>
                                        <Column width="2.5rem" hAlign="Begin"><Text text=""/></Column>
                                        <Column width="9rem" hAlign="Begin"><Text text="Date"/></Column>
                                        <Column hAlign="Begin"><Text text="Remarks"/></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem type="Inactive">
                                            <cells>
                                                <Button icon="sap-icon://decline" type="Transparent" press=".onRemoveCreateTimeEntryFZ"/>
                                                <Select 
                                                    selectedKey="{createTM>taskCode}" 
                                                    items="{path: 'createTM>/taskSuggestionsFZ', templateShareable: false}" 
                                                    forceSelection="false"
                                                    width="100%"
                                                    valueState="{= ${createTM>taskCode} ? 'None' : 'Error'}"
                                                >
                                                    <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                                </Select>
                                                <MultiInput
                                                    tokens="{path: 'createTM>selectedTechnicians', templateShareable: false}"
                                                    showSuggestion="true"
                                                    suggestionItems="{path: 'createTM>technicianSuggestions', templateShareable: false}"
                                                    liveChange=".onCreateTimeEntryTechnicianLiveChange"
                                                    suggestionItemSelected=".onCreateTimeEntryMultiTechnicianSelect"
                                                    tokenUpdate=".onTimeEntryTechnicianTokenUpdate"
                                                    placeholder="Add technicians..."
                                                    width="100%"
                                                    maxSuggestionWidth="400px"
                                                    startSuggestion="2"
                                                    valueState="{= ${createTM>selectedTechnicians}.length > 0 ? 'None' : 'Error'}"
                                                >
                                                    <tokens>
                                                        <Token key="{createTM>id}" text="{createTM>displayText}"/>
                                                    </tokens>
                                                    <suggestionItems>
                                                        <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                                    </suggestionItems>
                                                </MultiInput>
                                                <StepInput value="{createTM>durationHrs}" min="0" step="0.25" displayValuePrecision="2" width="100%"/>
                                                <Text text="hrs"/>
                                                <DatePicker value="{createTM>entryDate}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="100%"/>
                                                <Input value="{createTM>remarks}" placeholder="Remarks..." width="100%"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </ScrollContainer>
                            
                            <!-- Add button at bottom -->
                            <HBox justifyContent="Center" class="sapUiSmallMarginTop" visible="{= ${createTM>/timeEntriesFZ}.length > 0 }">
                                <Button icon="sap-icon://add" type="Transparent" tooltip="Add Time Entry" press=".onAddCreateTimeEntryFZ"/>
                            </HBox>
                        </content>
                    </Panel>
                    
                    <!-- ===== TIME ENTRIES - WARTEZEIT (WZ) ===== -->
                    <Panel expandable="false" expanded="true" class="tmTypePanel sapUiTinyMarginBottom">
                        <headerToolbar>
                            <OverflowToolbar design="Info">
                                <core:Icon src="sap-icon://pending" class="sapUiTinyMarginEnd" color="#BB0000"/>
                                <Title text="Time - Wartezeit (WZ)" level="H5"/>
                                <ToolbarSpacer/>
                                <Button 
                                    text="Add Time Entry" 
                                    icon="sap-icon://add" 
                                    type="Emphasized" 
                                    press=".onAddCreateTimeEntryWZ" 
                                    class="sapUiTinyMarginBegin"
                                />
                                <ObjectNumber number="{= ${createTM>/timeEntriesWZ}.length }" unit="entries" class="sapUiSmallMarginBegin"/>
                            </OverflowToolbar>
                        </headerToolbar>
                        <content>
                            <!-- Empty state when no entries -->
                            <VBox visible="{= ${createTM>/timeEntriesWZ}.length === 0 }" alignItems="Center" class="sapUiMediumMarginTopBottom">
                                <core:Icon src="sap-icon://pending" size="2.5rem" color="#BB0000"/>
                                <Text text="No Wartezeit entries yet" class="sapUiSmallMarginTop"/>
                                <Text text="Click 'Add Time Entry' to create a Wartezeit entry" class="sapUiTinyMarginTop sapMTextGrey"/>
                            </VBox>
                            
                            <!-- Time Entries Table -->
                            <ScrollContainer horizontal="true" vertical="false" width="100%">
                                <Table
                                    items="{path: 'createTM>/timeEntriesWZ', templateShareable: false}"
                                    visible="{= ${createTM>/timeEntriesWZ}.length > 0 }"
                                    class="tmMTable"
                                    width="auto"
                                >
                                    <columns>
                                        <Column width="3rem" hAlign="Begin"><Text text=""/></Column>
                                        <Column width="11rem" hAlign="Begin"><Text text="Task"/></Column>
                                        <Column width="14rem" hAlign="Begin"><Text text="Technician"/></Column>
                                        <Column width="6.5rem" hAlign="Begin"><Text text="Duration"/></Column>
                                        <Column width="2.5rem" hAlign="Begin"><Text text=""/></Column>
                                        <Column width="9rem" hAlign="Begin"><Text text="Date"/></Column>
                                        <Column hAlign="Begin"><Text text="Remarks"/></Column>
                                    </columns>
                                    <items>
                                        <ColumnListItem type="Inactive">
                                            <cells>
                                                <Button icon="sap-icon://decline" type="Transparent" press=".onRemoveCreateTimeEntryWZ"/>
                                                <Select 
                                                    selectedKey="{createTM>taskCode}" 
                                                    items="{path: 'createTM>/taskSuggestionsWZ', templateShareable: false}" 
                                                    forceSelection="false"
                                                    width="100%"
                                                    valueState="{= ${createTM>taskCode} ? 'None' : 'Error'}"
                                                >
                                                    <core:Item key="{createTM>code}" text="{createTM>name}"/>
                                                </Select>
                                                <MultiInput
                                                    tokens="{path: 'createTM>selectedTechnicians', templateShareable: false}"
                                                    showSuggestion="true"
                                                    suggestionItems="{path: 'createTM>technicianSuggestions', templateShareable: false}"
                                                    liveChange=".onCreateTimeEntryTechnicianLiveChange"
                                                    suggestionItemSelected=".onCreateTimeEntryMultiTechnicianSelect"
                                                    tokenUpdate=".onTimeEntryTechnicianTokenUpdate"
                                                    placeholder="Add technicians..."
                                                    width="100%"
                                                    maxSuggestionWidth="400px"
                                                    startSuggestion="2"
                                                    valueState="{= ${createTM>selectedTechnicians}.length > 0 ? 'None' : 'Error'}"
                                                >
                                                    <tokens>
                                                        <Token key="{createTM>id}" text="{createTM>displayText}"/>
                                                    </tokens>
                                                    <suggestionItems>
                                                        <core:Item key="{createTM>id}" text="{createTM>displayText}"/>
                                                    </suggestionItems>
                                                </MultiInput>
                                                <StepInput value="{createTM>durationHrs}" min="0" step="0.25" displayValuePrecision="2" width="100%"/>
                                                <Text text="hrs"/>
                                                <DatePicker value="{createTM>entryDate}" valueFormat="yyyy-MM-dd" displayFormat="dd.MM.yyyy" width="100%"/>
                                                <Input value="{createTM>remarks}" placeholder="Remarks..." width="100%"/>
                                            </cells>
                                        </ColumnListItem>
                                    </items>
                                </Table>
                            </ScrollContainer>
                            
                            <!-- Add button at bottom -->
                            <HBox justifyContent="Center" class="sapUiSmallMarginTop" visible="{= ${createTM>/timeEntriesWZ}.length > 0 }">
                                <Button icon="sap-icon://add" type="Transparent" tooltip="Add Time Entry" press=".onAddCreateTimeEntryWZ"/>
                            </HBox>
                        </content>
                    </Panel>
                </VBox>
                
            </VBox>
        </content>
        
        <!-- ========== DIALOG BUTTONS ========== -->
        <buttons>
            <!-- Send for Approval - Expense Report -->
            <Button 
                text="Send for Approval" 
                icon="sap-icon://paper-plane" 
                type="Emphasized" 
                press=".onSaveAllCreateExpense"
                visible="{= (${createTM>/serviceProductExternalId} === 'Z40000001' || ${createTM>/serviceProductExternalId} === 'Z40000007' || ${createTM>/serviceProductExternalId} === 'Z50000000') &amp;&amp; ${createTM>/expenseEntries}.length > 0 }"
            />
            <!-- Send for Approval - Mileage Report -->
            <Button 
                text="Send for Approval" 
                icon="sap-icon://paper-plane" 
                type="Emphasized" 
                press=".onSaveAllCreateMileage"
                visible="{= (${createTM>/serviceProductExternalId} === 'Z40000038' || ${createTM>/serviceProductExternalId} === 'Z40000008') &amp;&amp; ${createTM>/mileageEntries}.length > 0 }"
            />
            <!-- Send for Approval - Time & Material -->
            <Button 
                text="Send for Approval" 
                icon="sap-icon://paper-plane" 
                type="Emphasized" 
                press=".onSaveAllCreateTM"
                visible="{= ${createTM>/serviceProductExternalId} !== 'Z40000001' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z40000007' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z50000000' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z40000038' &amp;&amp; ${createTM>/serviceProductExternalId} !== 'Z40000008' &amp;&amp; (${createTM>/materialEntries}.length + ${createTM>/timeEntriesAZ}.length + ${createTM>/timeEntriesFZ}.length + ${createTM>/timeEntriesWZ}.length) > 0 }"
            />
            <Button text="Close" press=".onCancelCreateTM"/>
        </buttons>
    </Dialog>
</core:FragmentDefinition>