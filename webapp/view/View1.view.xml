<mvc:View
    controllerName="mobileappsc.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
>
    <Page
        id="mobileAppServiceConfirmationPage"
        title="Service Confirmation"
        showNavButton="false"
        class="sapUiContentPadding"
    >
        <content>
            <layout:VerticalLayout
                id="mobileAppMainLayout"
                width="100%"
                class="sapUiContentPadding"
            >
                <!-- Web Container Session Context Fragment -->
                <core:Fragment
                    fragmentName="mobileappsc.view.fragments.WebContainerContext"
                    type="XML"
                />

                <!-- Service Order Details Fragment -->
                <core:Fragment
                    fragmentName="mobileappsc.view.fragments.ServiceCall"
                    type="XML"
                />

                <!-- Organization Level Fragment -->
                <core:Fragment
                    fragmentName="mobileappsc.view.fragments.OrganizationLevel"
                    type="XML"
                />

                <!-- Product Groups Fragment -->
                <VBox 
                    id="productGroupsOuterContainer"
                    visible="{view>/organizationSelected}"
                    width="100%"
                >
                    <core:Fragment
                        fragmentName="mobileappsc.view.fragments.ProductGroups"
                        type="XML"
                    />
                </VBox>
            </layout:VerticalLayout>
        </content>

        <!-- Footer Toolbar -->
        <footer>
            <OverflowToolbar id="mobileAppFooterToolbar">
                <ToolbarSpacer id="mobileAppFooterSpacer" />
                <Button
                    id="mobileAppRefreshButton"
                    icon="sap-icon://refresh"
                    text="Refresh"
                    press=".onRefresh"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>