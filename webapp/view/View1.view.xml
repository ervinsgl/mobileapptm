<mvc:View
    controllerName="mobileappsc.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
>
    <Page
        id="mobileAppServiceConfirmationPage"
        title="Service Confirmation"
        showNavButton="false"
        class="sapUiContentPadding"
    >
        <content>
            <layout:VerticalLayout
                id="mobileAppMainLayout"
                width="100%"
                class="sapUiContentPadding"
            >
                <!-- Service Order Details Fragment - ALWAYS VISIBLE -->
                <core:Fragment
                    fragmentName="mobileappsc.view.fragments.ServiceCall"
                    type="XML"
                />

                <!-- Organization Level Fragment - ALWAYS VISIBLE -->
                <core:Fragment
                    fragmentName="mobileappsc.view.fragments.OrganizationLevel"
                    type="XML"
                />

                <!-- ACTIVITIES DROPDOWN - ONLY AFTER ORG SELECTION -->
                <VBox 
                    id="activitiesDropdownContainer"
                    visible="{view>/organizationSelected}"
                    width="100%"
                >
                    <!-- Activities List Fragment (now dropdown) -->
                    <core:Fragment
                        fragmentName="mobileappsc.view.fragments.ActivitiesList"
                        type="XML"
                    />
                </VBox>

                <!-- ACTIVITY PANELS - ONLY AFTER ACTIVITY SELECTION -->
                <VBox 
                    id="activityPanelsContainer"
                    visible="{view>/activitySelected}"
                    width="100%"
                >
                    <!-- Activity Selection Fragment - ONLY AFTER ACTIVITY SELECTION -->
                    <core:Fragment
                        fragmentName="mobileappsc.view.fragments.ActivitySelection"
                        type="XML"
                    />

                    <!-- Activity Details Fragment - ONLY AFTER ACTIVITY SELECTION -->
                    <core:Fragment
                        fragmentName="mobileappsc.view.fragments.ActivityDetails"
                        type="XML"
                    />
                </VBox>
            </layout:VerticalLayout>
        </content>

        <!-- Footer Toolbar -->
        <footer>
            <OverflowToolbar id="mobileAppFooterToolbar">
                <ToolbarSpacer id="mobileAppFooterSpacer" />
                <Button
                    id="mobileAppRefreshButton"
                    icon="sap-icon://refresh"
                    text="Refresh"
                    press=".onRefresh"
                />
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>