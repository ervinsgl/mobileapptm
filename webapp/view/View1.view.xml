<mvc:View
    controllerName="mobileappsc.controller.View1"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:layout="sap.ui.layout"
>
    <!-- 
        View1: Main view for FSM Service Confirmation application.
        
        Layout Structure:
        1. Session Context Panel (FSM Mobile web container info)
        2. Service Order Panel (service call header details)
        3. Product Groups (activities grouped by product)
        
        Controller: mobileappsc.controller.View1
    -->
    <Page
        id="mobileAppServiceConfirmationPage"
        title="Service Confirmation"
        showNavButton="false"
        class="sapUiContentPadding"
    >
        <content>
            <layout:VerticalLayout id="mobileAppMainLayout" width="100%" class="sapUiContentPadding">
                
                <!-- Session Context (visible when launched from FSM Mobile) -->
                <core:Fragment fragmentName="mobileappsc.view.fragments.WebContainerContext" type="XML"/>

                <!-- Service Order Header -->
                <core:Fragment fragmentName="mobileappsc.view.fragments.ServiceCall" type="XML"/>

                <!-- Activities by Product Group -->
                <VBox id="productGroupsOuterContainer" visible="{view>/organizationSelected}" width="100%">
                    <core:Fragment fragmentName="mobileappsc.view.fragments.ProductGroups" type="XML"/>
                </VBox>
                
            </layout:VerticalLayout>
        </content>

        <!-- Footer -->
        <footer>
            <OverflowToolbar id="mobileAppFooterToolbar">
                <ToolbarSpacer id="mobileAppFooterSpacer"/>
                <Button id="mobileAppRefreshButton" icon="sap-icon://refresh" text="Refresh" press=".onRefresh"/>
            </OverflowToolbar>
        </footer>
    </Page>
</mvc:View>